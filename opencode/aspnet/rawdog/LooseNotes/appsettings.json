{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=loosenotes.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FileUpload": {
    "MaxFileSizeMB": 10,
    "AllowedExtensions": [".pdf", ".doc", ".docx", ".txt", ".png", ".jpg", ".jpeg"],
    "UploadPath": "wwwroot/uploads"
  }
}
