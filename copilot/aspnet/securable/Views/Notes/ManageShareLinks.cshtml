@model ManageShareLinksViewModel
@{
    ViewData["Title"] = "Manage share links";
}

<div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
    <div>
        <h1 class="mb-1">Share links</h1>
        <p class="text-muted mb-0">Manage share links for <strong>@Model.NoteTitle</strong>. Anyone with an active link can read the note and download its attachments.</p>
    </div>
    <form asp-action="RegenerateShareLink" method="post">
        <input type="hidden" name="noteId" value="@Model.NoteId" />
        <button type="submit" class="btn btn-primary">Generate new link</button>
    </form>
</div>

@if (Model.ActiveLinks.Count == 0)
{
    <div class="card shadow-sm">
        <div class="card-body p-4 text-center text-muted">No active share links exist yet.</div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>URL</th>
                        <th>Created</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var link in Model.ActiveLinks)
                    {
                        <tr>
                            <td><code class="small">@link.Url</code></td>
                            <td>@link.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                            <td class="text-end">
                                <form asp-action="RevokeShareLink" method="post" class="d-inline">
                                    <input type="hidden" name="noteId" value="@Model.NoteId" />
                                    <input type="hidden" name="shareLinkId" value="@link.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Revoke</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
