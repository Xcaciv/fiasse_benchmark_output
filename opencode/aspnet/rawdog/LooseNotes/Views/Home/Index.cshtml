@{
    ViewData["Title"] = "Home";
}
@model IEnumerable<LooseNotes.Models.Note>

<div class="row">
    <div class="col-md-12">
        <h1>Welcome to LooseNotes</h1>
        <p class="lead">A multi-user note-taking platform for creating, managing, sharing, and rating notes.</p>
    </div>
</div>

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="row mb-4">
        <div class="col-md-12">
            <a asp-controller="Notes" asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Create New Note
            </a>
            <a asp-controller="Notes" asp-action="Index" class="btn btn-secondary">
                <i class="bi bi-journal"></i> My Notes
            </a>
        </div>
    </div>
}
else
{
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Get Started</h5>
                    <p class="card-text">Create an account to start creating and sharing notes.</p>
                    <a asp-controller="Account" asp-action="Register" class="btn btn-primary">Register</a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary">Login</a>
                </div>
            </div>
        </div>
    </div>
}

@if (Model.Any())
{
    <div class="row">
        <div class="col-md-12">
            <h2>Recent Public Notes</h2>
        </div>
    </div>
    
    <div class="row">
        @foreach (var note in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">
                            <a asp-controller="Notes" asp-action="Details" asp-route-id="@note.Id">@note.Title</a>
                        </h5>
                        <p class="card-text text-muted">
                            by @note.User?.UserName | @note.CreatedAt.ToString("MMM dd, yyyy")
                        </p>
                        <p class="card-text">
                            @(note.Content.Length > 150 ? note.Content.Substring(0, 150) + "..." : note.Content)
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                @if (note.Ratings.Count > 0)
                                {
                                    <span class="badge bg-warning">
                                        @note.Ratings.Average(r => r.Value).ToString("F1") / 5
                                        (@note.Ratings.Count ratings)
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">No ratings yet</span>
                                }
                            </div>
                            <small class="text-muted">
                                @if (note.Attachments.Count > 0)
                                {
                                    <span>@note.Attachments.Count attachment(s)</span>
                                }
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="row">
        <div class="col-md-12">
            <div class="alert alert-info">
                No public notes available yet. Be the first to create one!
            </div>
        </div>
    </div>
}
