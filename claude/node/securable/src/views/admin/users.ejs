<div class="page-header">
  <h1>Manage Users</h1>
  <a href="/admin" class="btn btn-secondary">Back to Dashboard</a>
</div>

<form method="GET" action="/admin/users" class="search-form">
  <div class="search-input-group">
    <input type="text" name="search" value="<%= search %>" placeholder="Search by username or email…" maxlength="100" />
    <button type="submit" class="btn btn-primary">Search</button>
    <% if (search) { %><a href="/admin/users" class="btn btn-secondary">Clear</a><% } %>
  </div>
</form>

<% if (users.length === 0) { %>
  <p class="empty-state">No users found.</p>
<% } else { %>
  <table class="data-table">
    <thead>
      <tr>
        <th>Username</th>
        <th>Email</th>
        <th>Role</th>
        <th>Notes</th>
        <th>Registered</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(u => { %>
        <tr class="<%= !u.isActive ? 'row-inactive' : '' %>">
          <td><%= u.username %></td>
          <td><%= u.email %></td>
          <td><span class="badge <%= u.role === 'admin' ? 'badge-admin' : '' %>"><%= u.role %></span></td>
          <td><%= u.notes ? u.notes.length : 0 %></td>
          <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
          <td><%= u.isActive ? 'Active' : 'Inactive' %></td>
          <td>
            <% if (u.id !== user.id) { %>
              <form method="POST" action="/admin/users/<%= u.id %>/toggle-active" style="display:inline">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn btn-xs <%= u.isActive ? 'btn-danger' : 'btn-secondary' %>">
                  <%= u.isActive ? 'Deactivate' : 'Activate' %>
                </button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>
