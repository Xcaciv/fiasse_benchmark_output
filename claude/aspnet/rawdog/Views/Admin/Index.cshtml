@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2><i class="bi bi-shield-shaded"></i> Admin Dashboard</h2>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-center bg-primary text-white">
            <div class="card-body">
                <h3>@Model.TotalUsers</h3>
                <p class="mb-0">Total Users</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center bg-success text-white">
            <div class="card-body">
                <h3>@Model.TotalNotes</h3>
                <p class="mb-0">Total Notes</p>
            </div>
        </div>
    </div>
</div>

<h4>Users</h4>
<form asp-action="Index" method="get" class="mb-3">
    <div class="input-group" style="max-width: 400px;">
        <input type="text" name="search" value="@Model.SearchQuery" class="form-control"
               placeholder="Search by username or email..." />
        <button type="submit" class="btn btn-outline-secondary">Search</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Registered</th>
                <th>Notes</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.UserName</td>
                    <td>@user.Email</td>
                    <td>@user.CreatedAt.ToString("MMM d, yyyy")</td>
                    <td>@user.NoteCount</td>
                    <td></td>
                </tr>
            }
        </tbody>
    </table>
</div>
