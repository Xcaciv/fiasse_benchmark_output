<h2 class="mb-4">Top Rated Notes</h2>
<p class="text-muted">Public notes with at least 3 ratings, sorted by average score.</p>

{{#if notes.length}}
  <div class="list-group">
    {{#each notes}}
      <a href="/notes/{{this.id}}" class="list-group-item list-group-item-action">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <strong>{{this.title}}</strong>
            <small class="text-muted ms-2">by {{this.author}}</small>
          </div>
          <div class="text-warning">
            {{stars this.avgRating}} <strong>{{this.avgRating}}</strong>
            <small class="text-muted">({{this.ratingCount}})</small>
          </div>
        </div>
        <p class="mb-0 text-muted small mt-1">{{this.excerpt}}</p>
      </a>
    {{/each}}
  </div>
{{else}}
  <p class="text-muted">No notes have reached the minimum rating threshold yet.</p>
{{/if}}
