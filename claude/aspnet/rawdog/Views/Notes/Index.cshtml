@model List<Note>
@{
    ViewData["Title"] = "My Notes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My Notes</h2>
    <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus"></i> New Note</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">You have no notes yet. <a asp-action="Create">Create your first note!</a></div>
}
else
{
    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var note in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <a asp-action="Details" asp-route-id="@note.Id" class="text-decoration-none">@note.Title</a>
                        </h5>
                        <p class="card-text text-muted small">
                            @(note.Content.Length > 120 ? note.Content[..120] + "..." : note.Content)
                        </p>
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center">
                        <small class="text-muted">@note.CreatedAt.ToString("MMM d, yyyy")</small>
                        <div>
                            @if (note.IsPublic)
                            {
                                <span class="badge bg-success me-1">Public</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary me-1">Private</span>
                            }
                            @if (note.Ratings.Any())
                            {
                                <span class="badge bg-warning text-dark">
                                    <i class="bi bi-star-fill"></i> @note.Ratings.Average(r => r.Stars).ToString("F1")
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
