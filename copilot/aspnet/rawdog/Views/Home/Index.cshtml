@model IEnumerable<LooseNotes.Models.Note>
@{
    ViewData["Title"] = "Home";
}
<div class="jumbotron bg-light p-5 rounded mb-4">
    <h1 class="display-5">Welcome to Loose Notes</h1>
    <p class="lead">A multi-user note-taking platform. Capture, share, and discover notes.</p>
    @if (!User.Identity?.IsAuthenticated ?? true)
    {
        <a asp-controller="Account" asp-action="Register" class="btn btn-primary me-2">Get Started</a>
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">Login</a>
    }
    else
    {
        <a asp-controller="Notes" asp-action="Create" class="btn btn-primary me-2">Create Note</a>
        <a asp-controller="Notes" asp-action="Index" class="btn btn-outline-secondary">My Notes</a>
    }
</div>

<h3>Recent Public Notes</h3>
@if (!Model.Any())
{
    <p class="text-muted">No public notes yet. Be the first!</p>
}
<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var note in Model)
    {
        <div class="col">
            <div class="card h-100">
                <div class="card-body">
                    <h5 class="card-title">
                        <a asp-controller="Notes" asp-action="Details" asp-route-id="@note.Id">@note.Title</a>
                    </h5>
                    <p class="card-text text-muted small">by @note.User?.UserName · @note.CreatedAt.ToString("MMM d, yyyy")</p>
                    <p class="card-text">@(note.Content.Length > 120 ? note.Content.Substring(0, 120) + "..." : note.Content)</p>
                </div>
                @if (note.Ratings.Any())
                {
                    <div class="card-footer text-muted small">
                        ⭐ @note.Ratings.Average(r => r.Stars).ToString("F1") (@note.Ratings.Count ratings)
                    </div>
                }
            </div>
        </div>
    }
</div>
