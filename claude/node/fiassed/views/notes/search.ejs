<div class="page-header">
  <h1>Search Notes</h1>
</div>

<form method="GET" action="/notes/search" class="search-form">
  <div class="form-group form-inline">
    <input
      type="text"
      name="q"
      value="<%= typeof q !== 'undefined' ? q : '' %>"
      placeholder="Search notes..."
      maxlength="200"
      class="search-input"
    >
    <button type="submit" class="btn btn-primary">Search</button>
  </div>
</form>

<% if (typeof q !== 'undefined' && q) { %>
  <p>Found <%= count %> result<%= count !== 1 ? 's' : '' %> for "<%= q %>"</p>

  <% if (typeof notes !== 'undefined' && notes.length > 0) { %>
    <div class="notes-list">
      <% notes.forEach(function(note) { %>
        <div class="note-card">
          <div class="note-card-header">
            <h2 class="note-title">
              <a href="/notes/<%= note.id %>"><%= note.title %></a>
            </h2>
            <span class="badge badge-<%= note.visibility %>"><%= note.visibility %></span>
          </div>
          <% if (note.owner) { %>
            <small class="note-author">by <%= note.owner.username %></small>
          <% } %>
          <p class="note-preview"><%= note.content.substring(0, 200) %><%= note.content.length > 200 ? '...' : '' %></p>
          <small>Updated <%= new Date(note.updatedAt).toLocaleDateString() %></small>
        </div>
      <% }); %>
    </div>

    <% const totalPages = Math.ceil(count / pageSize); %>
    <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (page > 1) { %>
          <a href="/notes/search?q=<%= encodeURIComponent(q) %>&page=<%= page - 1 %>" class="btn btn-sm btn-secondary">Previous</a>
        <% } %>
        <span>Page <%= page %> of <%= totalPages %></span>
        <% if (page < totalPages) { %>
          <a href="/notes/search?q=<%= encodeURIComponent(q) %>&page=<%= page + 1 %>" class="btn btn-sm btn-secondary">Next</a>
        <% } %>
      </div>
    <% } %>
  <% } else { %>
    <p class="empty-state">No notes found for your search.</p>
  <% } %>
<% } %>
