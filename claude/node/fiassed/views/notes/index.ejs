<div class="page-header">
  <h1>My Notes</h1>
  <a href="/notes/create" class="btn btn-primary">New Note</a>
</div>

<% if (typeof notes !== 'undefined' && notes.length > 0) { %>
  <div class="notes-list">
    <% notes.forEach(function(note) { %>
      <div class="note-card">
        <div class="note-card-header">
          <h2 class="note-title">
            <a href="/notes/<%= note.id %>"><%= note.title %></a>
          </h2>
          <span class="badge badge-<%= note.visibility %>"><%= note.visibility %></span>
        </div>
        <p class="note-preview"><%= note.content.substring(0, 150) %><%= note.content.length > 150 ? '...' : '' %></p>
        <div class="note-meta">
          <small>Updated <%= new Date(note.updatedAt).toLocaleDateString() %></small>
          <div class="note-actions">
            <a href="/notes/<%= note.id %>/edit" class="btn btn-sm btn-secondary">Edit</a>
            <form method="POST" action="/notes/<%= note.id %>/delete" style="display:inline;" onsubmit="return confirm('Delete this note?')">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-sm btn-danger">Delete</button>
            </form>
          </div>
        </div>
      </div>
    <% }); %>
  </div>

  <% const totalPages = Math.ceil(count / pageSize); %>
  <% if (totalPages > 1) { %>
    <div class="pagination">
      <% if (page > 1) { %>
        <a href="/notes?page=<%= page - 1 %>" class="btn btn-sm btn-secondary">Previous</a>
      <% } %>
      <span>Page <%= page %> of <%= totalPages %></span>
      <% if (page < totalPages) { %>
        <a href="/notes?page=<%= page + 1 %>" class="btn btn-sm btn-secondary">Next</a>
      <% } %>
    </div>
  <% } %>

<% } else { %>
  <div class="empty-state">
    <p>You have no notes yet.</p>
    <a href="/notes/create" class="btn btn-primary">Create your first note</a>
  </div>
<% } %>
