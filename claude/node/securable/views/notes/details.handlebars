<div class="d-flex justify-content-between align-items-start mb-3">
  <div>
    <h2>{{note.title}}</h2>
    <small class="text-muted">
      By {{note.owner.username}} &middot; {{formatDate note.createdAt}}
      &middot;
      <span class="badge {{#if note.isPublic}}bg-success{{else}}bg-secondary{{/if}}">
        {{#if note.isPublic}}Public{{else}}Private{{/if}}
      </span>
      {{#if avgRating}}<span class="ms-2">{{stars avgRating}} {{avgRating}} ({{note.ratings.length}} ratings)</span>{{/if}}
    </small>
  </div>
  {{#if isOwner}}
    <div class="btn-group">
      <a href="/notes/{{note.id}}/edit" class="btn btn-outline-primary btn-sm">Edit</a>
      <a href="/notes/{{note.id}}/delete" class="btn btn-outline-danger btn-sm">Delete</a>
    </div>
  {{/if}}
</div>

<div class="card mb-4">
  <div class="card-body">
    <pre class="mb-0" style="white-space:pre-wrap">{{note.content}}</pre>
  </div>
</div>

{{!-- Attachments --}}
<h5>Attachments</h5>
{{#if note.attachments.length}}
  <ul class="list-group mb-3">
    {{#each note.attachments}}
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <a href="/notes/{{../note.id}}/attachments/{{this.id}}">{{this.originalFilename}}</a>
        <div class="text-muted small me-2">{{this.mimeType}}</div>
        {{#if ../isOwner}}
          <form action="/notes/{{../note.id}}/attachments/{{this.id}}/delete" method="POST" class="d-inline">
            <input type="hidden" name="_csrf" value="{{../csrfToken}}">
            <button type="submit" class="btn btn-outline-danger btn-sm"
                    onclick="return confirm('Delete this attachment?')">Remove</button>
          </form>
        {{/if}}
      </li>
    {{/each}}
  </ul>
{{else}}
  <p class="text-muted small">No attachments.</p>
{{/if}}

{{#if isOwner}}
  <form action="/notes/{{note.id}}/attachments" method="POST" enctype="multipart/form-data" class="mb-4">
    <input type="hidden" name="_csrf" value="{{csrfToken}}">
    <div class="input-group">
      <input type="file" name="file" class="form-control" accept=".pdf,.doc,.docx,.txt,.png,.jpg,.jpeg">
      <button type="submit" class="btn btn-outline-secondary">Attach File</button>
    </div>
    <div class="form-text">Allowed: PDF, DOC, DOCX, TXT, PNG, JPG, JPEG. Max 10 MB.</div>
  </form>
{{/if}}

{{!-- Share Links --}}
{{#if isOwner}}
  <h5>Share Link</h5>
  <div class="mb-4">
    <form action="/notes/{{note.id}}/share" method="POST" class="d-inline">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">
      <button type="submit" class="btn btn-outline-success btn-sm">Generate Share Link</button>
    </form>
    <form action="/notes/{{note.id}}/share/revoke" method="POST" class="d-inline ms-2">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">
      <button type="submit" class="btn btn-outline-warning btn-sm"
              onclick="return confirm('Revoke all share links?')">Revoke All Links</button>
    </form>
  </div>
{{/if}}

{{!-- Rating Form --}}
<h5>Rate This Note</h5>
<form action="/notes/{{note.id}}/rate" method="POST" class="mb-4">
  <input type="hidden" name="_csrf" value="{{csrfToken}}">
  <div class="row g-2 align-items-end">
    <div class="col-auto">
      <label for="value" class="form-label">Stars</label>
      <select id="value" name="value" class="form-select">
        <option value="1" {{#if (eq userRating.value 1)}}selected{{/if}}>1</option>
        <option value="2" {{#if (eq userRating.value 2)}}selected{{/if}}>2</option>
        <option value="3" {{#if (eq userRating.value 3)}}selected{{/if}}>3</option>
        <option value="4" {{#if (eq userRating.value 4)}}selected{{/if}}>4</option>
        <option value="5" {{#if (eq userRating.value 5)}}selected{{/if}}>5</option>
      </select>
    </div>
    <div class="col">
      <label for="comment" class="form-label">Comment (optional)</label>
      <input type="text" id="comment" name="comment" class="form-control" maxlength="1000"
             value="{{userRating.comment}}">
    </div>
    <div class="col-auto">
      <button type="submit" class="btn btn-primary">{{#if userRating}}Update{{else}}Submit{{/if}} Rating</button>
    </div>
  </div>
</form>

{{!-- Ratings List --}}
{{#if note.ratings.length}}
  <h5>Ratings</h5>
  <div class="list-group">
    {{#each note.ratings}}
      <div class="list-group-item">
        <div class="d-flex justify-content-between">
          <strong>{{stars this.value}} {{this.value}}/5</strong>
          <small class="text-muted">{{this.rater.username}} &middot; {{formatDate this.createdAt}}</small>
        </div>
        {{#if this.comment}}<p class="mb-0 mt-1">{{this.comment}}</p>{{/if}}
      </div>
    {{/each}}
  </div>
{{/if}}

{{#if isAdmin}}
  <div class="mt-4">
    <a href="/admin/reassign/{{note.id}}" class="btn btn-outline-secondary btn-sm">Admin: Reassign Note</a>
  </div>
{{/if}}
