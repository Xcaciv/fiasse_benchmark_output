<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Notes - Loose Notes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container">
      <a class="navbar-brand" href="/"><i class="bi bi-journal-text"></i> Loose Notes</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/notes">My Notes</a>
        <a class="nav-link" href="/admin">Admin</a>
        <div class="dropdown">
          <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
            <i class="bi bi-person-circle"></i> <%= user.username %>
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/auth/profile">Profile</a></li>
            <li><hr class="dropdown-divider"></li>
            <li>
              <form action="/auth/logout" method="POST" class="d-inline">
                <button type="submit" class="dropdown-item">Logout</button>
              </form>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2><i class="bi bi-journal-text"></i> Manage Notes</h2>
      <a href="/admin" class="btn btn-outline-secondary">Back to Dashboard</a>
    </div>

    <form method="GET" action="/admin/notes" class="mb-4">
      <div class="input-group">
        <input type="text" class="form-control" name="q" placeholder="Search by title or content..." 
               value="<%= query || '' %>">
        <button class="btn btn-primary" type="submit">
          <i class="bi bi-search"></i> Search
        </button>
        <% if (query) { %>
          <a href="/admin/notes" class="btn btn-outline-secondary">Clear</a>
        <% } %>
      </div>
    </form>

    <div class="card">
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Author</th>
                <th>Visibility</th>
                <th>Created</th>
                <th>Updated</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% if (notes.length === 0) { %>
                <tr>
                  <td colspan="7" class="text-center text-muted">No notes found</td>
                </tr>
              <% } else { %>
                <% notes.forEach(function(note) { %>
                  <tr>
                    <td><%= note.id %></td>
                    <td><%= note.title.substring(0, 50) %><% if (note.title.length > 50) { %>...<% } %></td>
                    <td><%= note.author %></td>
                    <td>
                      <% if (note.is_public) { %>
                        <span class="badge bg-success">Public</span>
                      <% } else { %>
                        <span class="badge bg-secondary">Private</span>
                      <% } %>
                    </td>
                    <td><small><%= new Date(note.created_at).toLocaleDateString() %></small></td>
                    <td><small><%= new Date(note.updated_at).toLocaleDateString() %></small></td>
                    <td>
                      <a href="/notes/<%= note.id %>" class="btn btn-sm btn-outline-primary">View</a>
                      <a href="/admin/notes/<%= note.id %>/reassign" class="btn btn-sm btn-outline-warning">Reassign</a>
                    </td>
                  </tr>
                <% }); %>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
