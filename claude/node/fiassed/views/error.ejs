<div class="error-page">
  <h1><%= typeof title !== 'undefined' ? title : 'Error' %></h1>
  <p class="error-message"><%= typeof message !== 'undefined' ? message : 'An unexpected error occurred.' %></p>

  <% if (typeof correlationId !== 'undefined' && correlationId) { %>
    <p class="correlation-id">
      Reference ID: <code><%= correlationId %></code><br>
      <small>Please include this ID if you contact support.</small>
    </p>
  <% } %>

  <div class="error-actions">
    <a href="/" class="btn btn-primary">Go Home</a>
    <a href="javascript:history.back()" class="btn btn-secondary">Go Back</a>
  </div>
</div>
