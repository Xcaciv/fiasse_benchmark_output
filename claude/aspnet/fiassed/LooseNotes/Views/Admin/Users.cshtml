@model LooseNotes.ViewModels.Admin.UserListViewModel
@{
    ViewData["Title"] = "Manage Users";
}
<div class="admin-users">
    <h2>Users</h2>
    <form asp-action="Users" method="get" class="search-bar">
        <input type="text" name="search" value="@Model.SearchQuery" class="form-control" placeholder="Search by username or email..." />
        <button type="submit" class="btn btn-secondary">Search</button>
    </form>

    <p>@Model.TotalCount users found.</p>

    <table class="table">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Registered</th>
                <th>Last Login</th>
                <th>Notes</th>
                <th>Role</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <!-- Password hash, tokens, session IDs never rendered (Confidentiality) -->
                    <td>@Html.Encode(user.Username)</td>
                    <td>@Html.Encode(user.Email)</td>
                    <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                    <td>@(user.LastLoginAt?.ToString("yyyy-MM-dd") ?? "Never")</td>
                    <td>@user.NoteCount</td>
                    <td>@(user.IsAdmin ? "Admin" : "User")</td>
                    <td>
                        <form asp-action="TerminateUserSessions" method="post" style="display:inline;">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-warning">Terminate Sessions</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="pagination">
        @if (Model.CurrentPage > 1)
        {
            <a asp-action="Users" asp-route-page="@(Model.CurrentPage - 1)" asp-route-search="@Model.SearchQuery">Previous</a>
        }
        <span>Page @Model.CurrentPage of @Model.TotalPages</span>
        @if (Model.CurrentPage < Model.TotalPages)
        {
            <a asp-action="Users" asp-route-page="@(Model.CurrentPage + 1)" asp-route-search="@Model.SearchQuery">Next</a>
        }
    </div>
</div>
