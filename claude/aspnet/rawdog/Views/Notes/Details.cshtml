@model NoteDetailsViewModel
@{
    ViewData["Title"] = Model.Note.Title;
    var note = Model.Note;
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <h2>@note.Title</h2>
    <span class="badge @(note.IsPublic ? "bg-success" : "bg-secondary") fs-6">
        @(note.IsPublic ? "Public" : "Private")
    </span>
</div>

<p class="text-muted">
    By <strong>@note.User?.UserName</strong> &middot;
    Created @note.CreatedAt.ToString("MMM d, yyyy") &middot;
    Updated @note.UpdatedAt.ToString("MMM d, yyyy")
</p>

<div class="card mb-4">
    <div class="card-body">
        <pre style="white-space: pre-wrap; font-family: inherit;">@note.Content</pre>
    </div>
</div>

@if (note.Attachments.Any())
{
    <h5>Attachments</h5>
    <ul class="list-group mb-4">
        @foreach (var att in note.Attachments)
        {
            <li class="list-group-item">
                <a asp-action="DownloadAttachment" asp-route-id="@att.Id">@att.OriginalFileName</a>
                <span class="text-muted small ms-2">(@(att.FileSize / 1024) KB)</span>
            </li>
        }
    </ul>
}

@if (Model.IsOwner)
{
    <div class="mb-4 d-flex gap-2 flex-wrap">
        <a asp-action="Edit" asp-route-id="@note.Id" class="btn btn-outline-primary">Edit</a>
        <a asp-action="Delete" asp-route-id="@note.Id" class="btn btn-outline-danger">Delete</a>

        @if (Model.ShareToken != null)
        {
            <div class="input-group" style="max-width: 400px;">
                <input type="text" class="form-control form-control-sm" id="shareUrl"
                       value="@Url.Action("View", "Share", new { token = Model.ShareToken }, Context.Request.Scheme)" readonly />
                <button class="btn btn-sm btn-outline-secondary" onclick="copyShare()">Copy</button>
            </div>
            <form asp-action="RevokeShareLink" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="noteId" value="@note.Id" />
                <button type="submit" class="btn btn-outline-warning btn-sm">Revoke Link</button>
            </form>
        }
        else
        {
            <form asp-action="GenerateShareLink" method="post" class="d-inline">
                @Html.AntiForgeryToken()
                <input type="hidden" name="noteId" value="@note.Id" />
                <button type="submit" class="btn btn-outline-success btn-sm">Generate Share Link</button>
            </form>
        }
    </div>
}

<hr />
<h5>Ratings (@note.Ratings.Count)</h5>

@if (note.Ratings.Any())
{
    <p>
        Average:
        <span class="star-rating">
            @for (int i = 1; i <= 5; i++)
            {
                <span>@(i <= Math.Round(note.AverageRating) ? "★" : "☆")</span>
            }
        </span>
        @note.AverageRating.ToString("0.0")
    </p>

    @foreach (var rating in note.Ratings.OrderByDescending(r => r.UpdatedAt))
    {
        <div class="card mb-2">
            <div class="card-body py-2">
                <div class="d-flex justify-content-between">
                    <strong>@rating.User?.UserName</strong>
                    <span class="star-rating">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span>@(i <= rating.Value ? "★" : "☆")</span>
                        }
                    </span>
                </div>
                @if (!string.IsNullOrEmpty(rating.Comment))
                {
                    <p class="mb-0 mt-1">@rating.Comment</p>
                }
                <small class="text-muted">@rating.UpdatedAt.ToString("MMM d, yyyy")</small>
            </div>
        </div>
    }
}

@if (User.Identity?.IsAuthenticated == true && note.UserId != (User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value))
{
    <h6 class="mt-3">@(Model.UserRating != null ? "Edit Your Rating" : "Rate This Note")</h6>
    <form asp-action="Rate" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="NoteId" value="@note.Id" />
        <div class="mb-2">
            <label class="form-label">Stars</label>
            <select name="Value" class="form-select" style="max-width: 120px;">
                @for (int i = 5; i >= 1; i--)
                {
                    @if (Model.UserRating?.Value == i) {
                        <option value="@i" selected>@i Star@(i > 1 ? "s" : "")</option>
                    } else {
                        <option value="@i">@i Star@(i > 1 ? "s" : "")</option>
                    }
                }
            </select>
        </div>
        <div class="mb-2">
            <label class="form-label">Comment (optional)</label>
            <textarea name="Comment" class="form-control" rows="2" maxlength="500">@Model.UserRating?.Comment</textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-sm">Submit Rating</button>
    </form>
}

@section Scripts {
    <script>
        function copyShare() {
            var el = document.getElementById('shareUrl');
            el.select();
            document.execCommand('copy');
            alert('Link copied!');
        }
    </script>
}
