  <div class="nav-brand">
    <a href="/">Loose Notes</a>
  </div>
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
      <li><a href="/notes">My Notes</a></li>
