<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Top Rated Notes - Loose Notes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container">
      <a class="navbar-brand" href="/"><i class="bi bi-journal-text"></i> Loose Notes</a>
      <div class="navbar-nav ms-auto">
        <% if (user) { %>
          <a class="nav-link" href="/notes">My Notes</a>
          <a class="nav-link" href="/search">Search</a>
          <div class="dropdown">
            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle"></i> <%= user.username %>
            </a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="/auth/profile">Profile</a></li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <form action="/auth/logout" method="POST" class="d-inline">
                  <button type="submit" class="dropdown-item">Logout</button>
                </form>
              </li>
            </ul>
          </div>
        <% } else { %>
          <a class="nav-link" href="/auth/login">Login</a>
          <a class="nav-link" href="/auth/register">Register</a>
        <% } %>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <h2 class="mb-4"><i class="bi bi-star-fill text-warning"></i> Top Rated Notes</h2>
    <p class="text-muted mb-4">Public notes with at least 3 ratings, sorted by average rating.</p>

    <% if (notes.length === 0) { %>
      <div class="text-center py-5">
        <i class="bi bi-star display-1 text-muted"></i>
        <p class="mt-3 text-muted">No top rated notes yet. Be the first to rate some notes!</p>
        <% if (!user) { %>
          <a href="/auth/login" class="btn btn-primary">Login to Rate Notes</a>
        <% } %>
      </div>
    <% } else { %>
      <div class="row g-3">
        <% notes.forEach(function(note, index) { %>
          <div class="col-md-6 col-lg-4">
            <div class="card h-100">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                  <h5 class="card-title"><%= note.title %></h5>
                  <span class="badge bg-warning text-dark">#<%= index + 1 %></span>
                </div>
                <p class="card-text text-muted small">
                  <%= note.excerpt %>
                </p>
                <div class="d-flex justify-content-between align-items-center">
                  <small class="text-muted">
                    <i class="bi bi-person"></i> <%= note.author %>
                  </small>
                  <small class="text-warning">
                    <i class="bi bi-star-fill"></i>
                    <%= note.avg_rating %> (<%= note.rating_count %> ratings)
                  </small>
                </div>
              </div>
              <div class="card-footer bg-transparent">
                <a href="/notes/share/<%= note.id %>" class="btn btn-sm btn-outline-primary">View</a>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
