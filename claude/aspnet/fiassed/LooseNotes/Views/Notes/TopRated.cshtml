@model IList<LooseNotes.ViewModels.Notes.TopRatedNoteViewModel>
@{
    ViewData["Title"] = "Top Rated Notes";
}
<div class="page-header">
    <h2>Top Rated Notes</h2>
    <p>Public notes with the highest average rating (minimum 3 ratings).</p>
</div>

@if (!Model.Any())
{
    <p class="empty-state">No top-rated notes yet.</p>
}
else
{
    <div class="notes-grid">
        @foreach (var note in Model)
        {
            <div class="note-card">
                <div class="note-card-header">
                    <a asp-action="Details" asp-controller="Notes" asp-route-id="@note.Id" class="note-title">
                        @Html.Encode(note.Title)
                    </a>
                    <span class="rating-badge">⭐ @note.AverageRating.ToString("F1") (@note.RatingCount)</span>
                </div>
                <p class="note-author">by @Html.Encode(note.AuthorUsername)</p>
                <!-- Preview output-encoded by Razor default encoding (GSR-07) -->
                <p class="note-preview">@note.Preview</p>
            </div>
        }
    </div>
}
