@model IList<LooseNotes.ViewModels.Notes.NoteListItemViewModel>
@{
    ViewData["Title"] = "My Notes";
}
<div class="page-header">
    <h2>My Notes</h2>
    <a asp-action="Create" class="btn btn-primary">New Note</a>
</div>

@if (!Model.Any())
{
    <p class="empty-state">You don't have any notes yet. <a asp-action="Create">Create your first note</a>.</p>
}
else
{
    <div class="notes-grid">
        @foreach (var note in Model)
        {
            <div class="note-card @(note.IsPublic ? "public" : "private")">
                <div class="note-card-header">
                    <a asp-action="Details" asp-route-id="@note.Id" class="note-title">@Html.Encode(note.Title)</a>
                    <span class="badge @(note.IsPublic ? "badge-public" : "badge-private")">
                        @(note.IsPublic ? "Public" : "Private")
                    </span>
                </div>
                <!-- Preview is first 200 chars; Razor default encoding prevents XSS (GSR-07) -->
                <p class="note-preview">@note.Preview</p>
                <div class="note-meta">
                    <span>Updated @note.UpdatedAt.ToString("MMM d, yyyy")</span>
                    @if (note.RatingCount > 0)
                    {
                        <span>⭐ @note.AverageRating.ToString("F1") (@note.RatingCount)</span>
                    }
                    @if (note.AttachmentCount > 0)
                    {
                        <span>📎 @note.AttachmentCount</span>
                    }
                </div>
                <div class="note-actions">
                    <a asp-action="Edit" asp-route-id="@note.Id">Edit</a>
                    <a asp-action="Delete" asp-route-id="@note.Id">Delete</a>
                </div>
            </div>
        }
    </div>
}
