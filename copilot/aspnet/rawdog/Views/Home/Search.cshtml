@model SearchViewModel
@{
    ViewData["Title"] = "Search";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="h2 mb-1">Search notes</h1>
        <p class="text-muted mb-0">Results include your own notes and public notes from other users.</p>
    </div>
</div>

<form asp-action="Search" method="get" class="row g-2 mb-4">
    <div class="col-md-10">
        <input class="form-control" type="search" name="q" value="@Model.Query" placeholder="Enter keywords" />
    </div>
    <div class="col-md-2 d-grid">
        <button class="btn btn-primary" type="submit">Search</button>
    </div>
</form>

@if (string.IsNullOrWhiteSpace(Model.Query))
{
    <div class="alert alert-info">Enter a keyword to search note titles and content.</div>
}
else if (Model.Results.Count == 0)
{
    <div class="alert alert-warning">No notes matched <strong>@Model.Query</strong>.</div>
}
else
{
    <div class="vstack gap-3">
        @foreach (var result in Model.Results)
        {
            <article class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div>
                            <h2 class="h5 mb-1">
                                <a asp-controller="Notes" asp-action="Details" asp-route-id="@result.Id" class="text-decoration-none">@result.Title</a>
                            </h2>
                            <p class="text-muted small mb-2">By @result.Author on @result.CreatedAtUtc.ToLocalTime().ToString("g")</p>
                        </div>
                        <span class="badge @(result.IsPublic ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")">
                            @(result.IsPublic ? "Public" : "Your private note")
                        </span>
                    </div>
                    <p class="mb-0 note-preview">@result.Excerpt</p>
                </div>
            </article>
        }
    </div>
}
