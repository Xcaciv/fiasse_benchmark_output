<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>My Notes</h2>
  <a href="/notes/create" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>New Note</a>
</div>
<% if (notes.length === 0) { %>
  <div class="text-center py-5 text-muted">
    <i class="bi bi-journal-x display-4"></i>
    <p class="mt-3">No notes yet. <a href="/notes/create">Create your first note!</a></p>
  </div>
<% } else { %>
  <div class="row g-3">
    <% notes.forEach(note => { %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <div class="d-flex justify-content-between mb-1">
              <span class="badge <%= note.visibility === 'public' ? 'bg-success' : 'bg-secondary' %>">
                <%= note.visibility %>
              </span>
              <small class="text-muted"><%= new Date(note.updatedAt).toLocaleDateString() %></small>
            </div>
            <h6 class="card-title mt-2">
              <a href="/notes/<%= note.id %>" class="text-decoration-none text-dark"><%= note.title %></a>
            </h6>
            <p class="card-text text-muted small"><%= note.content.substring(0, 100) %><% if (note.content.length > 100) { %>…<% } %></p>
          </div>
          <div class="card-footer d-flex gap-2">
            <a href="/notes/<%= note.id %>/edit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a>
            <form method="POST" action="/notes/<%= note.id %>/delete" onsubmit="return confirm('Delete this note?')">
              <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
            </form>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
<%- include('../partials/footer') %>
