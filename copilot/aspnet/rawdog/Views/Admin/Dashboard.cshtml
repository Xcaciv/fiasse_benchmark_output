@model LooseNotes.ViewModels.Admin.DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}
<h2>Admin Dashboard</h2>

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <h3>@Model.TotalUsers</h3>
                <p class="mb-0">Total Users</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <h3>@Model.TotalNotes</h3>
                <p class="mb-0">Total Notes</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card bg-info text-white">
            <div class="card-body text-center">
                <h3>@Model.PublicNotes</h3>
                <p class="mb-0">Public Notes</p>
            </div>
        </div>
    </div>
</div>

<div class="d-flex gap-2 mb-4">
    <a asp-action="Users" class="btn btn-outline-primary">Manage Users</a>
    <a asp-action="Notes" class="btn btn-outline-secondary">Manage Notes</a>
</div>

<h4>Recent Activity</h4>
@if (!Model.RecentActivity.Any())
{
    <p class="text-muted">No activity yet.</p>
}
else
{
    <table class="table table-sm">
        <thead><tr><th>Timestamp</th><th>User</th><th>Action</th><th>Entity</th><th>ID</th></tr></thead>
        <tbody>
            @foreach (var log in Model.RecentActivity)
            {
                <tr>
                    <td><small>@log.Timestamp.ToString("MMM d HH:mm")</small></td>
                    <td><small>@(log.User?.UserName ?? "—")</small></td>
                    <td><small>@log.Action</small></td>
                    <td><small>@log.EntityType</small></td>
                    <td><small>@log.EntityId</small></td>
                </tr>
            }
        </tbody>
    </table>
}
