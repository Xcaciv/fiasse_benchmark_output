<%- include('../partials/head', {title}) %>
<%- include('../partials/nav') %>
<div class="container mt-4">
  <%- include('../partials/flash') %>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">My Notes</h1>
    <a href="/notes/create" class="btn btn-primary">+ New Note</a>
  </div>

  <% if (!notes.length) { %>
    <div class="text-center py-5 text-muted">
      <p class="fs-5">No notes yet.</p>
      <a href="/notes/create" class="btn btn-outline-primary">Create your first note</a>
    </div>
  <% } else { %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
      <% notes.forEach(note => { %>
        <div class="col">
          <div class="card h-100 shadow-sm">
            <div class="card-body">
              <div class="d-flex justify-content-between mb-1">
                <span class="badge <%= note.is_public ? 'bg-success' : 'bg-secondary' %>">
                  <%= note.is_public ? 'Public' : 'Private' %>
                </span>
                <% if (note.avg_rating > 0) { %>
                  <span class="text-warning small">★ <%= note.avg_rating %> (<%= note.rating_count %>)</span>
                <% } %>
              </div>
              <h5 class="card-title mt-1">
                <a href="/notes/<%= note.id %>" class="text-decoration-none text-dark"><%= note.title %></a>
              </h5>
              <p class="card-text text-muted small">
                <%= note.content.substring(0, 150) %><%= note.content.length > 150 ? '…' : '' %>
              </p>
            </div>
            <div class="card-footer d-flex justify-content-between align-items-center bg-transparent small text-muted">
              <span><%= new Date(note.updated_at).toLocaleDateString() %></span>
              <div>
                <a href="/notes/<%= note.id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
