<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= note.title %> - Loose Notes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container">
      <a class="navbar-brand" href="/"><i class="bi bi-journal-text"></i> Loose Notes</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/auth/login">Login</a>
        <a class="nav-link" href="/auth/register">Register</a>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <div class="row justify-content-center">
      <div class="col-lg-8">
        <div class="card mb-4">
          <div class="card-body">
            <h1 class="card-title"><%= note.title %></h1>
            
            <p class="text-muted mb-3">
              By <strong><%= note.author %></strong> | 
              <%= new Date(note.created_at).toLocaleDateString() %>
            </p>

            <% if (avgRating && avgRating.count > 0) { %>
              <div class="mb-3">
                <span class="text-warning">
                  <% for (let i = 1; i <= 5; i++) { %>
                    <% if (i <= Math.round(avgRating.avg)) { %>
                      <i class="bi bi-star-fill"></i>
                    <% } else { %>
                      <i class="bi bi-star"></i>
                    <% } %>
                  <% } %>
                </span>
                <span class="text-muted">
                  <%= parseFloat(avgRating.avg).toFixed(1) %> (<%= avgRating.count %> rating<%= avgRating.count > 1 ? 's' : '' %>)
                </span>
              </div>
            <% } %>

            <hr>

            <div class="card-text note-content">
              <%= note.content %>
            </div>

            <% if (attachments.length > 0) { %>
              <hr>
              <h5>Attachments</h5>
              <div class="list-group">
                <% attachments.forEach(function(attachment) { %>
                  <div class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                      <i class="bi bi-paperclip"></i>
                      <%= attachment.original_filename %>
                      <small class="text-muted">(<%= (attachment.file_size / 1024).toFixed(1) %> KB)</small>
                    </div>
                    <a href="/uploads/<%= attachment.stored_filename %>" class="btn btn-sm btn-outline-primary" download="<%= attachment.original_filename %>">
                      <i class="bi bi-download"></i> Download
                    </a>
                  </div>
                <% }); %>
              </div>
            <% } %>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <h5 class="mb-0">Ratings & Reviews</h5>
          </div>
          <div class="card-body">
            <% if (ratings.length > 0) { %>
              <h6>All Ratings (<%= ratings.length %>)</h6>
              <% ratings.forEach(function(rating) { %>
                <div class="border-bottom pb-3 mb-3">
                  <div class="d-flex justify-content-between">
                    <strong><%= rating.username %></strong>
                    <small class="text-muted"><%= new Date(rating.created_at).toLocaleDateString() %></small>
                  </div>
                  <div class="text-warning">
                    <% for (let i = 1; i <= 5; i++) { %>
                      <% if (i <= rating.rating) { %>
                        <i class="bi bi-star-fill"></i>
                      <% } else { %>
                        <i class="bi bi-star"></i>
                      <% } %>
                    <% } %>
                  </div>
                  <% if (rating.comment) { %>
                    <p class="mb-0 mt-2"><%= rating.comment %></p>
                  <% } %>
                </div>
              <% }); %>
            <% } else { %>
              <p class="text-muted">No ratings yet.</p>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
