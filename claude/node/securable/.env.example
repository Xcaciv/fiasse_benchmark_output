# Application
NODE_ENV=development
PORT=3000

# Session — generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
SESSION_SECRET=replace-with-64-byte-hex-random-value

# Database (SQLite path relative to project root)
DB_PATH=./data/loosenotes.sqlite

# File uploads
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE_BYTES=5242880
ALLOWED_EXTENSIONS=pdf,doc,docx,txt,png,jpg,jpeg

# Password reset token expiry (milliseconds, default 1 hour)
RESET_TOKEN_EXPIRY_MS=3600000

# Email (SMTP) — set to real values in production
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@loosenotes.local

# Admin bootstrap (first user with this email gets admin role on registration)
ADMIN_EMAIL=admin@loosenotes.local

# Rate limiting
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=10
GENERAL_RATE_LIMIT_WINDOW_MS=900000
GENERAL_RATE_LIMIT_MAX=300
