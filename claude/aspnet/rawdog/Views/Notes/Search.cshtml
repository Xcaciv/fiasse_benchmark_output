@model SearchViewModel
@{
    ViewData["Title"] = "Search Notes";
}

<h2>Search Notes</h2>
<form asp-action="Search" method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="q" value="@Model.Query" class="form-control" placeholder="Search by title or content..." />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@if (Model.Query != null)
{
    <p class="text-muted">@Model.Results.Count result(s) for "@Model.Query"</p>

    @if (!Model.Results.Any())
    {
        <div class="alert alert-info">No notes found matching your search.</div>
    }

    @foreach (var result in Model.Results)
    {
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <h5 class="card-title">
                        <a asp-action="Details" asp-route-id="@result.Id">@result.Title</a>
                    </h5>
                    @if (result.IsPublic)
                    {
                        <span class="badge bg-success">Public</span>
                    }
                </div>
                <p class="card-text">@result.Excerpt</p>
                <small class="text-muted">By @result.AuthorName &middot; @result.CreatedAt.ToString("MMM d, yyyy")</small>
            </div>
        </div>
    }
}
