<h2 class="mb-4">Reassign Note</h2>
<div class="card mb-4">
  <div class="card-body">
    <strong>Note:</strong> {{note.title}}<br>
    <strong>Current Owner:</strong> {{note.owner.username}}
  </div>
</div>

<form action="/admin/reassign/{{note.id}}" method="POST">
  <input type="hidden" name="_csrf" value="{{csrfToken}}">
  <div class="mb-3">
    <label for="newOwnerId" class="form-label">Assign to User</label>
    <select id="newOwnerId" name="newOwnerId" class="form-select" required>
      <option value="">— Select user —</option>
      {{#each users}}
        <option value="{{this.id}}">{{this.username}}</option>
      {{/each}}
    </select>
  </div>
  <button type="submit" class="btn btn-warning">Reassign Note</button>
  <a href="/admin/users" class="btn btn-outline-secondary ms-2">Cancel</a>
</form>
