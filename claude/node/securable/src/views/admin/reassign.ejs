<div class="card form-card">
  <h1>Reassign Note Ownership</h1>

  <div class="note-info">
    <p><strong>Note:</strong> <%= note.title %></p>
    <p><strong>Current Owner:</strong> <%= note.owner.username %></p>
  </div>

  <form method="POST" action="/admin/reassign/<%= note.id %>">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <div class="form-group">
      <label for="newUserId">Assign to User</label>
      <select id="newUserId" name="newUserId" required>
        <option value="">Select a user…</option>
        <% users.forEach(u => { %>
          <option value="<%= u.id %>" <%= u.id === note.userId ? 'disabled' : '' %>>
            <%= u.username %><%= u.id === note.userId ? ' (current owner)' : '' %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary"
              onclick="return confirm('Reassign this note to the selected user?')">
        Reassign Note
      </button>
      <a href="/admin/users" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>
