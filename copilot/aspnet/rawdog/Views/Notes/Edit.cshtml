@model NoteFormViewModel
@{
    ViewData["Title"] = "Edit Note";
}

<div class="row justify-content-center">
    <div class="col-xl-9">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h1 class="h3 mb-3">Edit note</h1>
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data" novalidate>
                    <partial name="_NoteForm" model="Model" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save changes</button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Back</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
