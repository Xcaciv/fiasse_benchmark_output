@model IEnumerable<Note>
@{
    ViewData["Title"] = "Top Rated Notes";
}

<h1>Top Rated Notes</h1>
<p class="text-muted">Notes with at least 3 ratings, sorted by average rating</p>

@if (Model.Any())
{
    <div class="row">
        @foreach (var note in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title">
                                <a asp-controller="Home" asp-action="ViewNote" asp-route-id="@note.Id">
                                    @note.Title
                                </a>
                            </h5>
                            <span class="badge bg-warning text-dark">
                                @note.AverageRating.ToString("F1") / 5
                            </span>
                        </div>
                        <p class="card-text text-muted">
                            @if (note.Content.Length > 150)
                            {
                                @note.Content.Substring(0, 150)
                                <text>...</text>
                            }
                            else
                            {
                                @note.Content
                            }
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">by @note.User?.UserName</small>
                            <small class="text-muted">@note.RatingCount ratings</small>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <h3>No top rated notes yet</h3>
        <p>Notes need at least 3 ratings to appear here.</p>
    </div>
}
