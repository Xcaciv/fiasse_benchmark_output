@model HomeIndexViewModel
@{
    ViewData["Title"] = "Home";
}

<div class="hero-card p-4 p-lg-5 mb-4 rounded-4">
    <div class="row align-items-center g-4">
        <div class="col-lg-8">
            <h1 class="display-6 fw-bold">Capture, share, and rate notes without losing control.</h1>
            <p class="lead mb-4">Loose Notes is a multi-user ASP.NET Core MVC application with Identity authentication, secure share links, attachment handling, note search, and admin moderation tools.</p>
            <div class="d-flex flex-wrap gap-2">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="btn btn-primary" asp-controller="Notes" asp-action="Create">Create a note</a>
                    <a class="btn btn-outline-primary" asp-controller="Notes" asp-action="Index">View my notes</a>
                }
                else
                {
                    <a class="btn btn-primary" asp-controller="Account" asp-action="Register">Create an account</a>
                    <a class="btn btn-outline-primary" asp-controller="Account" asp-action="Login">Sign in</a>
                }
            </div>
        </div>
        <div class="col-lg-4">
            <div class="metric-card">
                <div class="metric-value">@Model.PublicNoteCount</div>
                <div class="metric-label">Public notes</div>
            </div>
            <div class="metric-card mt-3">
                <div class="metric-value">@Model.UserCount</div>
                <div class="metric-label">Registered users</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h4 mb-0">Recent public notes</h2>
                    <a asp-controller="Notes" asp-action="Search" class="btn btn-sm btn-outline-secondary">Search all</a>
                </div>
                @if (Model.RecentPublicNotes.Count == 0)
                {
                    <p class="text-muted mb-0">No public notes are available yet.</p>
                }
                else
                {
                    <div class="vstack gap-3">
                        @foreach (var note in Model.RecentPublicNotes)
                        {
                            <div class="note-card p-3 rounded-3 border">
                                <h3 class="h6 mb-1"><a asp-controller="Notes" asp-action="Details" asp-route-id="@note.Id">@note.Title</a></h3>
                                <p class="small text-muted mb-2">By @note.OwnerUserName on @note.CreatedAtUtc.ToLocalTime().ToString("g")</p>
                                <p class="mb-0">@note.Excerpt</p>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h4 mb-0">Top rated public notes</h2>
                    <a asp-controller="Notes" asp-action="TopRated" class="btn btn-sm btn-outline-secondary">Open leaderboard</a>
                </div>
                @if (Model.TopRatedNotes.Count == 0)
                {
                    <p class="text-muted mb-0">Top rated notes appear after at least three ratings.</p>
                }
                else
                {
                    <div class="vstack gap-3">
                        @foreach (var note in Model.TopRatedNotes)
                        {
                            <div class="note-card p-3 rounded-3 border">
                                <h3 class="h6 mb-1"><a asp-controller="Notes" asp-action="Details" asp-route-id="@note.Id">@note.Title</a></h3>
                                <p class="small text-muted mb-2">By @note.OwnerUserName</p>
                                <p class="mb-2">@note.Excerpt</p>
                                <span class="badge text-bg-warning">@note.AverageRating.ToString("0.0") / 5</span>
                                <span class="badge text-bg-light">@note.RatingCount ratings</span>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
