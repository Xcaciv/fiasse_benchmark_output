<div class="page-header">
  <h1>User Management</h1>
</div>

<form method="GET" action="/admin/users" class="search-form">
  <div class="form-group form-inline">
    <input
      type="text"
      name="search"
      value="<%= typeof search !== 'undefined' ? search : '' %>"
      placeholder="Search by username or email..."
      maxlength="100"
      class="search-input"
    >
    <button type="submit" class="btn btn-secondary">Search</button>
  </div>
</form>

<p>Total: <%= count %> user<%= count !== 1 ? 's' : '' %></p>

<% if (typeof users !== 'undefined' && users.length > 0) { %>
  <div class="table-wrapper">
    <table class="data-table">
      <thead>
        <tr>
          <th>Username</th>
          <th>Email</th>
          <th>Role</th>
          <th>Status</th>
          <th>Created</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(function(user) { %>
          <tr>
            <td><%= user.username %></td>
            <td><%= user.email %></td>
            <td><span class="badge badge-<%= user.role %>"><%= user.role %></span></td>
            <td>
              <span class="badge badge-<%= user.isActive ? 'active' : 'inactive' %>">
                <%= user.isActive ? 'Active' : 'Inactive' %>
              </span>
            </td>
            <td><%= new Date(user.createdAt).toLocaleDateString() %></td>
            <td>
              <% if (user.id !== currentUser.id) { %>
                <form method="POST" action="/admin/users/<%= user.id %>/toggle-active" style="display:inline;">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="isActive" value="<%= !user.isActive %>">
                  <button type="submit" class="btn btn-sm <%= user.isActive ? 'btn-warning' : 'btn-success' %>">
                    <%= user.isActive ? 'Deactivate' : 'Activate' %>
                  </button>
                </form>
              <% } else { %>
                <small>(you)</small>
              <% } %>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <% const totalPages = Math.ceil(count / pageSize); %>
  <% if (totalPages > 1) { %>
    <div class="pagination">
      <% if (page > 1) { %>
        <a href="/admin/users?page=<%= page - 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="btn btn-sm btn-secondary">Previous</a>
      <% } %>
      <span>Page <%= page %> of <%= totalPages %></span>
      <% if (page < totalPages) { %>
        <a href="/admin/users?page=<%= page + 1 %><%= search ? '&search=' + encodeURIComponent(search) : '' %>" class="btn btn-sm btn-secondary">Next</a>
      <% } %>
    </div>
  <% } %>
<% } else { %>
  <p class="empty-state">No users found.</p>
<% } %>
