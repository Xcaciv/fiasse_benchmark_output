@model LooseNotes.Models.Note
@{
    ViewData["Title"] = Model.Title;
    var currentUserId = ViewBag.CurrentUserId as string;
    var userRating = ViewBag.UserRating as LooseNotes.Models.Rating;
    var isSharedView = ViewBag.IsSharedView as bool? ?? false;
    bool isOwner = currentUserId != null && Model.UserId == currentUserId;
}
<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2>@Model.Title</h2>
        <p class="text-muted">
            by <strong>@Model.User?.UserName</strong> · 
            @Model.CreatedAt.ToString("MMMM d, yyyy") ·
            @if (Model.IsPublic)
            {
                <span class="badge bg-success">Public</span>
            }
            else
            {
                <span class="badge bg-secondary">Private</span>
            }
        </p>
    </div>
    @if (isOwner && !isSharedView)
    {
        <div>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
            <a asp-action="Share" asp-route-id="@Model.Id" class="btn btn-outline-info btn-sm">Share</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Delete</a>
        </div>
    }
</div>

<div class="card mb-4">
    <div class="card-body">
        <pre style="white-space: pre-wrap; font-family: inherit;">@Model.Content</pre>
    </div>
</div>

@if (Model.Attachments.Any())
{
    <h4>Attachments</h4>
    <ul class="list-group mb-4">
        @foreach (var att in Model.Attachments)
        {
            <li class="list-group-item d-flex justify-content-between">
                <span>📎 @att.FileName <small class="text-muted">(@((att.FileSize / 1024.0).ToString("F1")) KB)</small></span>
                <a asp-action="DownloadAttachment" asp-route-id="@att.Id" class="btn btn-sm btn-outline-primary">Download</a>
            </li>
        }
    </ul>
}

<h4>Ratings (@Model.Ratings.Count)</h4>
@if (Model.Ratings.Any())
{
    var avg = Model.Ratings.Average(r => r.Stars);
    <p>Average: <strong>⭐ @avg.ToString("F1")</strong></p>
    <div class="list-group mb-3">
        @foreach (var rating in Model.Ratings.OrderByDescending(r => r.UpdatedAt))
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between">
                    <strong>@rating.User?.UserName</strong>
                    <span>@string.Concat(Enumerable.Repeat("⭐", rating.Stars))</span>
                </div>
                @if (!string.IsNullOrEmpty(rating.Comment))
                {
                    <p class="mb-0 small">@rating.Comment</p>
                }
                <small class="text-muted">@rating.UpdatedAt.ToString("MMM d, yyyy")</small>
            </div>
        }
    </div>
}
else
{
    <p class="text-muted">No ratings yet.</p>
}

@if (User.Identity?.IsAuthenticated == true && !isOwner && !isSharedView)
{
    <h5>@(userRating != null ? "Update Your Rating" : "Rate This Note")</h5>
    <form asp-action="Rate" method="post" class="mb-4">
        <input type="hidden" name="NoteId" value="@Model.Id" />
        <div class="mb-2">
            <label class="form-label">Stars</label>
            <select name="Stars" class="form-select w-auto">
                @for (int i = 1; i <= 5; i++)
                {
                    if (userRating?.Stars == i)
                    {
                        <option value="@i" selected>@i ⭐</option>
                    }
                    else
                    {
                        <option value="@i">@i ⭐</option>
                    }
                }
            </select>
        </div>
        <div class="mb-2">
            <label class="form-label">Comment (optional)</label>
            <textarea name="Comment" class="form-control" rows="2">@userRating?.Comment</textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-sm">Submit Rating</button>
    </form>
}
