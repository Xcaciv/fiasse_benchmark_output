@model LooseNotes.ViewModels.Admin.AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}
<div class="admin-dashboard">
    <h2>Admin Dashboard</h2>
    <div class="stats-grid">
        <div class="stat-card">
            <h3>@Model.TotalUsers</h3>
            <p>Total Users</p>
        </div>
        <div class="stat-card">
            <h3>@Model.TotalNotes</h3>
            <p>Total Notes</p>
        </div>
        <div class="stat-card">
            <h3>@Model.TotalPublicNotes</h3>
            <p>Public Notes</p>
        </div>
        <div class="stat-card">
            <h3>@Model.TotalAttachments</h3>
            <p>File Attachments</p>
        </div>
    </div>

    <div class="admin-actions">
        <a asp-action="Users" class="btn btn-secondary">Manage Users</a>
    </div>

    <section class="audit-log">
        <h3>Recent Activity</h3>
        <!-- Paginated to prevent oversized responses (ASVS V13 / FIASSE S2.2) -->
        <table class="table">
            <thead>
                <tr>
                    <th>Time (UTC)</th>
                    <th>User</th>
                    <th>Event</th>
                    <th>Resource</th>
                    <th>Outcome</th>
                    <th>IP</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.RecentAuditLogs)
                {
                    <tr class="@(log.Outcome == "failed" ? "row-warning" : "")">
                        <td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@Html.Encode(log.Username ?? "anonymous")</td>
                        <td>@Html.Encode(log.EventType)</td>
                        <td>@Html.Encode($"{log.ResourceType}/{log.ResourceId}")</td>
                        <td>@Html.Encode(log.Outcome ?? "")</td>
                        <td>@Html.Encode(log.SourceIp ?? "")</td>
                    </tr>
                }
            </tbody>
        </table>
        <div class="pagination">
            @if (Model.CurrentPage > 1)
            {
                <a asp-action="Dashboard" asp-route-page="@(Model.CurrentPage - 1)">Previous</a>
            }
            <span>Page @Model.CurrentPage of @Model.TotalPages</span>
            @if (Model.CurrentPage < Model.TotalPages)
            {
                <a asp-action="Dashboard" asp-route-page="@(Model.CurrentPage + 1)">Next</a>
            }
        </div>
    </section>
</div>
