# JWT secret - use a strong random value in production (min 32 chars)
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars

# JWT token expiry
JWT_EXPIRES_IN=7d

# Password reset token expiry in seconds (3600 = 1 hour)
PASSWORD_RESET_EXPIRES=3600

# Max file upload size in bytes (10MB)
MAX_FILE_SIZE=10485760

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173,https://your-app.vercel.app

# Node environment
NODE_ENV=development
