@model CreateNoteViewModel
@{
    ViewData["Title"] = "New Note";
}
<div class="row justify-content-center">
    <div class="col-md-8">
        <h2>New Note</h2>
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" maxlength="300" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Content" class="form-label"></label>
                <textarea asp-for="Content" class="form-control" rows="10"></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsPublic" class="form-check-input" />
                <label asp-for="IsPublic" class="form-check-label"></label>
            </div>
            <div class="mb-3">
                <label asp-for="Attachment" class="form-label">Attachment (optional)</label>
                <input asp-for="Attachment" type="file" class="form-control"
                       accept=".pdf,.doc,.docx,.txt,.png,.jpg,.jpeg" />
                <div class="form-text">Allowed: PDF, DOC, DOCX, TXT, PNG, JPG, JPEG. Max 10 MB.</div>
                <span asp-validation-for="Attachment" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Note</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
