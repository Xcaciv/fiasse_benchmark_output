@model ProfileIndexViewModel
@{
    ViewData["Title"] = "Profile";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="h2 mb-1">Profile</h1>
        <p class="text-muted mb-0">Manage your account details and password.</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" class="btn btn-primary">Edit profile</a>
        <a asp-action="ChangePassword" class="btn btn-outline-secondary">Change password</a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-3">Username</dt>
            <dd class="col-sm-9">@Model.UserName</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Registered</dt>
            <dd class="col-sm-9">@Model.RegisteredAtUtc.ToLocalTime().ToString("f")</dd>

            <dt class="col-sm-3">Note count</dt>
            <dd class="col-sm-9">@Model.NoteCount</dd>
        </dl>
    </div>
</div>
