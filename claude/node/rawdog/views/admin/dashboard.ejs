<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0"><i class="bi bi-speedometer2 text-primary me-2"></i>Admin Dashboard</h1>
  <a href="/admin/users" class="btn btn-outline-primary">
    <i class="bi bi-people me-2"></i>Manage Users
  </a>
</div>

<!-- Stats Cards -->
<div class="row g-4 mb-5">
  <div class="col-sm-6 col-lg-3">
    <div class="card shadow-sm text-center border-0 bg-primary text-white">
      <div class="card-body p-4">
        <i class="bi bi-people display-4 mb-2 opacity-75"></i>
        <h2 class="card-title fw-bold mb-0"><%= stats.userCount %></h2>
        <p class="card-text opacity-75 mb-0">Total Users</p>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card shadow-sm text-center border-0 bg-success text-white">
      <div class="card-body p-4">
        <i class="bi bi-journal-richtext display-4 mb-2 opacity-75"></i>
        <h2 class="card-title fw-bold mb-0"><%= stats.noteCount %></h2>
        <p class="card-text opacity-75 mb-0">Total Notes</p>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card shadow-sm text-center border-0 bg-info text-white">
      <div class="card-body p-4">
        <i class="bi bi-globe display-4 mb-2 opacity-75"></i>
        <h2 class="card-title fw-bold mb-0"><%= stats.publicNoteCount %></h2>
        <p class="card-text opacity-75 mb-0">Public Notes</p>
      </div>
    </div>
  </div>
  <div class="col-sm-6 col-lg-3">
    <div class="card shadow-sm text-center border-0 bg-warning text-dark">
      <div class="card-body p-4">
        <i class="bi bi-paperclip display-4 mb-2 opacity-75"></i>
        <h2 class="card-title fw-bold mb-0"><%= stats.attachmentCount %></h2>
        <p class="card-text opacity-75 mb-0">Attachments</p>
      </div>
    </div>
  </div>
</div>

<!-- Recent Activity Log -->
<div class="card shadow-sm">
  <div class="card-header bg-transparent">
    <h4 class="mb-0"><i class="bi bi-activity me-2"></i>Recent Activity</h4>
  </div>
  <div class="card-body p-0">
    <% if (recentActivity && recentActivity.length > 0) { %>
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Time</th>
            <th>User</th>
            <th>Action</th>
            <th>Details</th>
            <th>IP</th>
          </tr>
        </thead>
        <tbody>
          <% recentActivity.forEach(function(log) { %>
          <tr>
            <td class="text-nowrap text-muted small">
              <%= new Date(log.createdAt).toLocaleString() %>
            </td>
            <td>
              <% if (log.User) { %>
              <span class="badge bg-light text-dark border">
                <i class="bi bi-person me-1"></i><%= log.User.username %>
              </span>
              <% } else { %>
              <span class="text-muted small">System</span>
              <% } %>
            </td>
            <td>
              <%
              var actionBadges = {
                'user_login': 'bg-success',
                'user_register': 'bg-primary',
                'note_create': 'bg-info text-dark',
                'note_edit': 'bg-warning text-dark',
                'note_delete': 'bg-danger',
                'note_reassign': 'bg-secondary',
                'password_reset': 'bg-warning text-dark',
                'profile_update': 'bg-light text-dark border',
                'admin_toggle': 'bg-danger'
              };
              var badgeClass = actionBadges[log.action] || 'bg-secondary';
              %>
              <span class="badge <%= badgeClass %>"><%= log.action.replace(/_/g, ' ') %></span>
            </td>
            <td class="small text-muted"><%= log.details || '-' %></td>
            <td class="small text-muted"><%= log.ipAddress || '-' %></td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } else { %>
    <div class="text-center py-5 text-muted">
      <i class="bi bi-clock-history display-4 mb-3"></i>
      <p>No activity recorded yet.</p>
    </div>
    <% } %>
  </div>
</div>

<%- include('../partials/footer') %>
