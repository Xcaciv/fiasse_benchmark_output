<div class="row g-4">
  <div class="col-lg-6">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h1 class="h3 mb-3">Profile details</h1>

        <% if (typeof errors !== 'undefined' && errors.length) { %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% for (const error of errors) { %><li><%= error %></li><% } %>
            </ul>
          </div>
        <% } %>

        <form method="post" action="/profile" class="vstack gap-3">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div>
            <label class="form-label" for="username">Username</label>
            <input class="form-control" id="username" name="username" maxlength="30" value="<%= form.username || '' %>" required>
          </div>
          <div>
            <label class="form-label" for="email">Email address</label>
            <input class="form-control" id="email" name="email" type="email" maxlength="200" value="<%= form.email || '' %>" required>
          </div>
          <button class="btn btn-primary" type="submit">Save profile</button>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h2 class="h3 mb-3">Change password</h2>

        <% if (typeof passwordErrors !== 'undefined' && passwordErrors.length) { %>
          <div class="alert alert-danger">
            <ul class="mb-0">
              <% for (const error of passwordErrors) { %><li><%= error %></li><% } %>
            </ul>
          </div>
        <% } %>

        <form method="post" action="/profile/password" class="vstack gap-3">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div>
            <label class="form-label" for="currentPassword">Current password</label>
            <input class="form-control" id="currentPassword" name="currentPassword" type="password" required>
          </div>
          <div>
            <label class="form-label" for="newPassword">New password</label>
            <input class="form-control" id="newPassword" name="newPassword" type="password" required>
          </div>
          <div>
            <label class="form-label" for="confirmPassword">Confirm new password</label>
            <input class="form-control" id="confirmPassword" name="confirmPassword" type="password" required>
          </div>
          <button class="btn btn-primary" type="submit">Update password</button>
        </form>
      </div>
    </div>
  </div>
</div>
