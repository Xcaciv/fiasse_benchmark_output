<%- include('partials/header') %>
<h2 class="mb-4"><i class="bi bi-star-fill text-warning me-2"></i>Top Rated Notes</h2>
<p class="text-muted mb-4">Public notes with at least 3 ratings, sorted by average score.</p>
<% if (notes.length === 0) { %>
  <div class="text-center py-5 text-muted">
    <i class="bi bi-star display-4"></i>
    <p class="mt-3">No notes have enough ratings yet. Rate some notes to see them here!</p>
  </div>
<% } else { %>
  <div class="row g-3">
    <% notes.forEach((note, idx) => { %>
      <% const avg = parseFloat(note.get('avgRating')).toFixed(1); %>
      <% const count = parseInt(note.get('ratingCount')); %>
      <div class="col-md-6">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
              <h6 class="card-title">
                <span class="text-muted me-2">#<%= idx + 1 %></span>
                <a href="/notes/<%= note.id %>" class="text-decoration-none"><%= note.title %></a>
              </h6>
              <span class="badge bg-warning text-dark ms-2">
                <i class="bi bi-star-fill"></i> <%= avg %>
              </span>
            </div>
            <p class="card-text text-muted small"><%= note.content.substring(0, 200) %><% if (note.content.length > 200) { %>…<% } %></p>
          </div>
          <div class="card-footer d-flex justify-content-between text-muted small">
            <span>By <strong><%= note.author ? note.author.username : 'Unknown' %></strong></span>
            <span><i class="bi bi-people me-1"></i><%= count %> ratings</span>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
<%- include('partials/footer') %>
