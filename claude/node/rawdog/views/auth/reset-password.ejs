<%- include('../partials/header', { title: title }) %>

<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h2 class="card-title mb-4 text-center">
          <i class="bi bi-shield-lock me-2 text-primary"></i>Reset Password
        </h2>
        <form action="/auth/reset-password/<%= token %>" method="POST">
          <div class="mb-3">
            <label for="password" class="form-label">New Password</label>
            <input type="password" class="form-control" id="password" name="password" required minlength="6" autofocus>
            <div class="form-text">At least 6 characters.</div>
          </div>
          <div class="mb-4">
            <label for="confirmPassword" class="form-label">Confirm New Password</label>
            <input type="password" class="form-control" id="confirmPassword" name="confirmPassword" required>
          </div>
          <div class="d-grid">
            <button type="submit" class="btn btn-primary btn-lg">Reset Password</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
