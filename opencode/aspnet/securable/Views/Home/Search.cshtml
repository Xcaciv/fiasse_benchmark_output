@model IEnumerable<Note>
@{
    ViewData["Title"] = "Search Results";
    var query = ViewData["Query"] as string;
}

<h1>Search Results</h1>
@if (!string.IsNullOrEmpty(query))
{
    <p class="text-muted">Showing results for: "@query"</p>
}

<form asp-controller="Home" asp-action="Search" method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="query" class="form-control" value="@query" 
               placeholder="Search notes..." />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@if (Model.Any())
{
    <div class="row">
        @foreach (var note in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title">
                                <a asp-controller="Home" asp-action="ViewNote" asp-route-id="@note.Id">
                                    @note.Title
                                </a>
                            </h5>
                            @if (note.IsPublic)
                            {
                                <span class="badge bg-success">Public</span>
                            }
                        </div>
                        <p class="card-text text-muted">
                            @if (note.Content.Length > 200)
                            {
                                @note.Content.Substring(0, 200)
                                <text>...</text>
                            }
                            else
                            {
                                @note.Content
                            }
                        </p>
                        <small class="text-muted">
                            by @note.User?.UserName | 
                            @note.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
                        </small>
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (!string.IsNullOrEmpty(query))
{
    <div class="text-center py-5">
        <h3>No results found</h3>
        <p>Try different keywords or browse public notes.</p>
        <a asp-controller="Home" asp-action="Browse" class="btn btn-primary">Browse Notes</a>
    </div>
}
