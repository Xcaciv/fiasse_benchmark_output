# LooseNotes Environment Configuration
# Copy this file to .env.local for local development.
# NEVER commit actual secrets to version control.

# JWT signing secret — generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_WITH_STRONG_SECRET_AT_LEAST_64_CHARS

# Application base URL (used for share link generation)
APP_BASE_URL=http://localhost:3000

# CSRF secret — generate with: openssl rand -base64 32
CSRF_SECRET=REPLACE_WITH_STRONG_CSRF_SECRET

# Attachment storage base directory (absolute path)
# IMPORTANT: Must be outside the web root in production
ATTACHMENTS_DIR=/var/data/loosenotes/attachments

# Environment: development | production
NODE_ENV=development

# Seed admin credentials (used only on first startup; remove after seeding)
# These override defaults and must be rotated immediately after first login
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD
