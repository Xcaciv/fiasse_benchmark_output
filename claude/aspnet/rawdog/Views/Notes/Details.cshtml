@model NoteDetailsViewModel
@{
    ViewData["Title"] = "Note Details";
    var note = Model.Note;
}

<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr; My Notes</a>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="mb-0">
            @* Title inserted without encoding (§6) *@
            @Html.Raw(note.Title)
        </h3>
        <div class="d-flex gap-2 align-items-center">
            <span class="badge @(note.IsPublic ? "bg-success" : "bg-secondary")">
                @(note.IsPublic ? "Public" : "Private")
            </span>
            <a asp-action="Edit" asp-route-id="@note.Id" class="btn btn-sm btn-outline-primary">Edit</a>
            <a asp-action="Delete" asp-route-id="@note.Id" class="btn btn-sm btn-outline-danger">Delete</a>
        </div>
    </div>
    <div class="card-body">
        @* Content inserted without encoding (§6) *@
        <div class="note-content">@Html.Raw(note.Content)</div>

        @if (!string.IsNullOrEmpty(note.Tags))
        {
            <p class="mt-2"><small class="text-muted">Tags: @note.Tags</small></p>
        }

        <p class="text-muted small mt-3">
            By @(note.Owner?.Username ?? "Unknown") &bull; @note.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy HH:mm")
        </p>
    </div>
</div>

@* Share link section *@
<div class="card mb-4">
    <div class="card-header">Share this note</div>
    <div class="card-body">
        <form asp-action="GenerateShareLink" method="post">
            <input type="hidden" name="noteId" value="@note.Id" />
            <button type="submit" class="btn btn-outline-primary btn-sm">Generate Share Link</button>
        </form>
        @if (TempData["ShareUrl"] != null)
        {
            <div class="mt-2">
                <strong>Share URL:</strong>
                <a href="@TempData["ShareUrl"]">@TempData["ShareUrl"]</a>
            </div>
        }
    </div>
</div>

@* Attachments *@
@if (note.Attachments.Any())
{
    <div class="card mb-4">
        <div class="card-header">Attachments</div>
        <ul class="list-group list-group-flush">
            @foreach (var att in note.Attachments)
            {
                <li class="list-group-item d-flex justify-content-between">
                    <span>@att.OriginalName</span>
                    <a asp-action="Download" asp-route-filename="@att.FileName" class="btn btn-sm btn-outline-secondary">Download</a>
                </li>
            }
        </ul>
    </div>
}

<div class="mb-3">
    <a asp-action="Attach" asp-route-noteId="@note.Id" class="btn btn-sm btn-outline-secondary">+ Attach File</a>
</div>

@* Ratings *@
<div class="card mb-4">
    <div class="card-header">Ratings &amp; Comments</div>
    <div class="card-body">
        @if (!Model.Ratings.Any())
        {
            <p class="text-muted">No ratings yet.</p>
        }
        else
        {
            @foreach (var rating in Model.Ratings)
            {
                <div class="border-bottom pb-2 mb-2">
                    <span class="text-warning">@string.Concat(Enumerable.Repeat("★", rating.Score))@string.Concat(Enumerable.Repeat("☆", 5 - rating.Score))</span>
                    <span class="text-muted small ms-2">@rating.SubmitterEmail</span>
                    <div>
                        @* Rating comment inserted without encoding (§6) *@
                        @Html.Raw(rating.Comment)
                    </div>
                </div>
            }
        }

        <hr />
        <h6>Leave a Rating</h6>
        <form asp-action="Rate" method="post">
            <input type="hidden" name="noteId" value="@note.Id" />
            <div class="mb-2">
                <label class="form-label">Score</label>
                <select name="score" class="form-select form-select-sm" style="width:100px">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <option value="@i">@i</option>
                    }
                </select>
            </div>
            <div class="mb-2">
                <label class="form-label">Comment</label>
                <textarea name="comment" class="form-control" rows="2"></textarea>
            </div>
            <button type="submit" class="btn btn-primary btn-sm">Submit Rating</button>
        </form>
    </div>
</div>
