<%- include('partials/header') %>
<div class="row">
  <div class="col-lg-8">
    <h1 class="mb-1">Welcome to Loose Notes</h1>
    <p class="text-muted mb-4">A simple, powerful multi-user note-taking platform.</p>
    <% if (!currentUser) { %>
      <div class="mb-4">
        <a href="/auth/register" class="btn btn-primary me-2"><i class="bi bi-person-plus me-1"></i>Create Account</a>
        <a href="/auth/login" class="btn btn-outline-secondary"><i class="bi bi-box-arrow-in-right me-1"></i>Sign In</a>
      </div>
    <% } else { %>
      <a href="/notes/create" class="btn btn-primary mb-4"><i class="bi bi-plus-circle me-1"></i>New Note</a>
    <% } %>
    <h4 class="mb-3">Recent Public Notes</h4>
    <% if (notes.length === 0) { %>
      <p class="text-muted">No notes yet. Be the first to write one!</p>
    <% } else { %>
      <div class="row g-3">
        <% notes.forEach(note => { %>
          <div class="col-md-6">
            <div class="card h-100 shadow-sm">
              <div class="card-body">
                <h6 class="card-title"><a href="/notes/<%= note.id %>" class="text-decoration-none"><%= note.title %></a></h6>
                <p class="card-text text-muted small"><%= note.content.substring(0, 120) %><% if (note.content.length > 120) { %>…<% } %></p>
              </div>
              <div class="card-footer text-muted small">
                By <strong><%= note.author ? note.author.username : 'Unknown' %></strong> &bull;
                <%= new Date(note.createdAt).toLocaleDateString() %>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
  <div class="col-lg-4">
    <div class="card shadow-sm">
      <div class="card-body">
        <h5 class="card-title"><i class="bi bi-lightning me-1"></i>Features</h5>
        <ul class="list-unstyled mb-0">
          <li><i class="bi bi-check2 text-success me-2"></i>Create & manage notes</li>
          <li><i class="bi bi-check2 text-success me-2"></i>Public & private visibility</li>
          <li><i class="bi bi-check2 text-success me-2"></i>File attachments</li>
          <li><i class="bi bi-check2 text-success me-2"></i>Shareable links</li>
          <li><i class="bi bi-check2 text-success me-2"></i>Star ratings & comments</li>
          <li><i class="bi bi-check2 text-success me-2"></i>Full-text search</li>
        </ul>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
