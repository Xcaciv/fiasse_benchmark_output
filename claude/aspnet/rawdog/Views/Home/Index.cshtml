@{
    ViewData["Title"] = "Welcome";
}

<div class="jumbotron text-center py-5 bg-light rounded">
    <h1 class="display-4"><i class="bi bi-journal-text"></i> Loose Notes</h1>
    <p class="lead">Create, share, and discover notes with the community.</p>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-controller="Notes" asp-action="Index" class="btn btn-primary btn-lg me-2">My Notes</a>
        <a asp-controller="Notes" asp-action="Create" class="btn btn-success btn-lg">New Note</a>
    }
    else
    {
        <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg me-2">Get Started</a>
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-lg">Login</a>
    }
</div>

<div class="row mt-4">
    <div class="col-md-4 text-center">
        <i class="bi bi-pencil-square fs-1 text-primary"></i>
        <h4>Create Notes</h4>
        <p>Write and organize your notes with titles and rich content.</p>
    </div>
    <div class="col-md-4 text-center">
        <i class="bi bi-share fs-1 text-success"></i>
        <h4>Share Easily</h4>
        <p>Generate share links to share notes with anyone.</p>
    </div>
    <div class="col-md-4 text-center">
        <i class="bi bi-star fs-1 text-warning"></i>
        <h4>Rate & Discover</h4>
        <p>Rate public notes and discover the best content.</p>
    </div>
</div>
