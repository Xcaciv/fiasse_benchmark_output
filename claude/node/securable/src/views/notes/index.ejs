<div class="page-header">
  <h1>My Notes</h1>
  <a href="/notes/new" class="btn btn-primary">New Note</a>
</div>

<% if (notes.length === 0) { %>
  <p class="empty-state">You have no notes yet. <a href="/notes/new">Create your first note</a>.</p>
<% } else { %>
  <div class="notes-list">
    <% notes.forEach(note => { %>
      <div class="note-card">
        <div class="note-card-header">
          <a href="/notes/<%= note.id %>"><h2><%= note.title %></h2></a>
          <span class="badge <%= note.isPublic ? 'badge-public' : 'badge-private' %>">
            <%= note.isPublic ? 'Public' : 'Private' %>
          </span>
        </div>
        <p class="note-excerpt"><%= note.content.substring(0, 200) %><%= note.content.length > 200 ? '…' : '' %></p>
        <div class="note-meta">
          <span>Created <%= new Date(note.createdAt).toLocaleDateString() %></span>
          <% if (note.ratings && note.ratings.length > 0) { %>
            <span>★ <%= (note.ratings.reduce((s,r) => s+r.value,0) / note.ratings.length).toFixed(1) %> (<%= note.ratings.length %>)</span>
          <% } %>
        </div>
        <div class="note-actions">
          <a href="/notes/<%= note.id %>/edit" class="btn btn-sm btn-secondary">Edit</a>
          <form method="POST" action="/notes/<%= note.id %>/delete" style="display:inline"
                onsubmit="return confirm('Delete this note and all its attachments?')">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
          </form>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
