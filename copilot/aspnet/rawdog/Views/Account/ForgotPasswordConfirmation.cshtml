@{
    ViewData["Title"] = "Password Reset";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="alert alert-info">
            <h4>Reset Link Generated</h4>
            <p>If an account with that email exists, a password reset link has been generated.</p>
            @if (TempData["ResetLink"] != null)
            {
                <p><strong>Demo reset link:</strong></p>
                <a href="@TempData["ResetLink"]" class="btn btn-sm btn-outline-primary">Click to Reset Password</a>
            }
        </div>
        <a asp-action="Login" class="btn btn-secondary">Back to Login</a>
    </div>
</div>
