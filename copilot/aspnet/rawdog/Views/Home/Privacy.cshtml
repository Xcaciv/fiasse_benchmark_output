@{
    ViewData["Title"] = "Privacy";
}

<div class="card shadow-sm">
    <div class="card-body">
        <h1 class="h3">Privacy</h1>
        <p>
            Loose Notes stores account data, note content, ratings, attachments, and audit events in the local application data store.
            Password reset messages are written to the configured local email folder for development and evaluation scenarios.
        </p>
        <p class="mb-0">
            Private notes remain visible only to their owners and admins unless you explicitly generate a share link.
        </p>
    </div>
</div>
