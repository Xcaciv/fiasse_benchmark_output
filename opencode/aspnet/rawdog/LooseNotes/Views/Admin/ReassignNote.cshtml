@model LooseNotes.Models.Note
@{
    ViewData["Title"] = "Reassign Note";
}

<h1>@ViewData["Title"]</h1>

<div class="alert alert-info">
    <h4>Reassign: @Model.Title</h4>
    <p>Current owner: <strong>@ViewBag.Note?.User?.UserName</strong></p>
</div>

<div class="row">
    <div class="col-md-6">
        <form asp-action="ReassignNote" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="noteId" value="@Model.Id" />
            
            <div class="form-group mb-3">
                <label class="form-label">Select New Owner</label>
                <select name="newOwnerId" class="form-select" required>
                    <option value="">-- Select User --</option>
                    @foreach (var user in ViewBag.Users)
                    {
                        <option value="@user.Id">@user.UserName</option>
                    }
                </select>
            </div>
            
            <div class="form-group">
                <button type="submit" class="btn btn-warning">Reassign Note</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
