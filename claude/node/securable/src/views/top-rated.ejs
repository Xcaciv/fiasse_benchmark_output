<%- include('partials/head', {title}) %>
<%- include('partials/nav') %>
<div class="container mt-4">
  <h1 class="h3 mb-1">Top Rated Notes</h1>
  <p class="text-muted mb-4">Public notes with at least 3 ratings, sorted by average star rating.</p>

  <% if (!notes.length) { %>
    <div class="text-center py-5 text-muted">
      <p>No notes have enough ratings yet. Be the first to rate some notes!</p>
      <a href="/search" class="btn btn-outline-primary">Browse Notes</a>
    </div>
  <% } else { %>
    <div class="list-group">
      <% notes.forEach((note, idx) => { %>
        <a href="/notes/<%= note.id %>" class="list-group-item list-group-item-action">
          <div class="d-flex align-items-center gap-3">
            <span class="fs-4 fw-bold text-muted">#<%= idx + 1 %></span>
            <div class="flex-grow-1">
              <div class="d-flex justify-content-between align-items-start">
                <h6 class="mb-0"><%= note.title %></h6>
                <span class="text-warning fs-5">★ <%= note.avg_rating %></span>
              </div>
              <p class="mb-1 small text-muted">
                <%= note.content.substring(0, 200) %><%= note.content.length > 200 ? '…' : '' %>
              </p>
              <small class="text-muted">
                By <strong><%= note.username %></strong> &middot;
                <%= note.rating_count %> rating<%= note.rating_count === 1 ? '' : 's' %> &middot;
                <%= new Date(note.created_at).toLocaleDateString() %>
              </small>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</div>
<%- include('partials/footer') %>
