<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Loose Notes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body { background-color: #f8f9fa; }
    .navbar-brand { font-weight: 700; letter-spacing: -0.5px; }
    .note-excerpt { color: #6c757d; font-size: 0.9rem; }
    .star-rating { color: #ffc107; }
    .visibility-badge-public { background-color: #198754; }
    .visibility-badge-private { background-color: #6c757d; }
    .note-card:hover { box-shadow: 0 4px 12px rgba(0,0,0,.1); transition: box-shadow .2s; }
    pre { white-space: pre-wrap; word-break: break-word; }
    .rating-stars { font-size: 1.3rem; }
    footer { margin-top: 4rem; padding: 2rem 0; border-top: 1px solid #dee2e6; }
  </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand" href="/"><i class="bi bi-journal-text me-2"></i>Loose Notes</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarMain">
      <ul class="navbar-nav me-auto">
        <% if (user) { %>
          <li class="nav-item"><a class="nav-link" href="/notes"><i class="bi bi-journals me-1"></i>My Notes</a></li>
          <li class="nav-item"><a class="nav-link" href="/notes/create"><i class="bi bi-plus-circle me-1"></i>New Note</a></li>
        <% } %>
        <li class="nav-item"><a class="nav-link" href="/notes/search"><i class="bi bi-search me-1"></i>Search</a></li>
        <li class="nav-item"><a class="nav-link" href="/notes/top-rated"><i class="bi bi-star me-1"></i>Top Rated</a></li>
        <% if (user && user.role === 'admin') { %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
              <i class="bi bi-shield-check me-1"></i>Admin
            </a>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="/admin/dashboard">Dashboard</a></li>
              <li><a class="dropdown-item" href="/admin/users">Manage Users</a></li>
            </ul>
          </li>
        <% } %>
      </ul>
      <ul class="navbar-nav">
        <% if (user) { %>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
              <i class="bi bi-person-circle me-1"></i><%= user.username %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/profile/edit"><i class="bi bi-pencil me-2"></i>Edit Profile</a></li>
              <li><hr class="dropdown-divider"></li>
              <li>
                <form action="/auth/logout" method="POST" class="d-inline w-100">
                  <button type="submit" class="dropdown-item text-danger">
                    <i class="bi bi-box-arrow-right me-2"></i>Logout
                  </button>
                </form>
              </li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/auth/login">Login</a></li>
          <li class="nav-item"><a class="nav-link btn btn-outline-light btn-sm px-3 ms-1" href="/auth/register">Register</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<div class="container mt-4">
  <% if (success && success.length > 0) { %>
    <% success.forEach(msg => { %>
      <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle me-2"></i><%= msg %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% }) %>
  <% } %>
  <% if (error && error.length > 0) { %>
    <% error.forEach(msg => { %>
      <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-circle me-2"></i><%= msg %>
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
      </div>
    <% }) %>
  <% } %>
