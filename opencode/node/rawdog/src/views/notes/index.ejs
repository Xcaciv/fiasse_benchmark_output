<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Notes - Loose Notes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container">
      <a class="navbar-brand" href="/"><i class="bi bi-journal-text"></i> Loose Notes</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/search">Search</a>
        <a class="nav-link" href="/search/top-rated">Top Rated</a>
        <div class="dropdown">
          <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
            <i class="bi bi-person-circle"></i> <%= user.username %>
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/auth/profile">Profile</a></li>
            <li><hr class="dropdown-divider"></li>
            <li>
              <form action="/auth/logout" method="POST" class="d-inline">
                <button type="submit" class="dropdown-item">Logout</button>
              </form>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2>My Notes</h2>
      <a href="/notes/new" class="btn btn-primary"><i class="bi bi-plus-circle"></i> New Note</a>
    </div>

    <% if (success && success.length > 0) { %>
      <div class="alert alert-success">
        <%= success[0] %>
      </div>
    <% } %>

    <% if (notes.length === 0) { %>
      <div class="text-center py-5">
        <i class="bi bi-journal-text display-1 text-muted"></i>
        <p class="mt-3 text-muted">You don't have any notes yet.</p>
        <a href="/notes/new" class="btn btn-primary">Create Your First Note</a>
      </div>
    <% } else { %>
      <div class="row g-3">
        <% notes.forEach(function(note) { %>
          <div class="col-md-6 col-lg-4">
            <div class="card h-100">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                  <h5 class="card-title"><%= note.title %></h5>
                  <% if (note.is_public) { %>
                    <span class="badge bg-success">Public</span>
                  <% } else { %>
                    <span class="badge bg-secondary">Private</span>
                  <% } %>
                </div>
                <p class="card-text text-muted small">
                  <%= note.content.substring(0, 100) %><% if (note.content.length > 100) { %>...<% } %>
                </p>
                <div class="d-flex justify-content-between align-items-center">
                  <small class="text-muted">
                    <i class="bi bi-star-fill text-warning"></i>
                    <% if (note.avg_rating) { %>
                      <%= parseFloat(note.avg_rating).toFixed(1) %> (<%= note.rating_count %>)
                    <% } else { %>
                      No ratings
                    <% } %>
                  </small>
                  <small class="text-muted"><%= new Date(note.created_at).toLocaleDateString() %></small>
                </div>
              </div>
              <div class="card-footer bg-transparent">
                <a href="/notes/<%= note.id %>" class="btn btn-sm btn-outline-primary">View</a>
                <a href="/notes/<%= note.id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
                <form action="/notes/<%= note.id %>/delete" method="POST" class="d-inline">
                  <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Are you sure you want to delete this note?')">Delete</button>
                </form>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
