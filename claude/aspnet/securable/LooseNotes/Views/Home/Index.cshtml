@{
    ViewData["Title"] = "Welcome";
}
<div class="row justify-content-center">
    <div class="col-md-8 text-center py-5">
        <h1 class="display-4">Loose Notes</h1>
        <p class="lead mt-3">A secure multi-user note-taking platform. Create, share, and rate notes.</p>
        <div class="mt-4 d-flex gap-3 justify-content-center">
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg">Get Started</a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-lg">Sign In</a>
        </div>
        <hr class="my-5" />
        <div class="row g-4">
            <div class="col-md-4">
                <h5>Create &amp; Organise</h5>
                <p>Write notes with rich text, attach files, and control visibility.</p>
            </div>
            <div class="col-md-4">
                <h5>Share Securely</h5>
                <p>Generate share links for specific notes without exposing your account.</p>
            </div>
            <div class="col-md-4">
                <h5>Discover &amp; Rate</h5>
                <p>Search public notes and rate them to surface the best content.</p>
            </div>
        </div>
    </div>
</div>
