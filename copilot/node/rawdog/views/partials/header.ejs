<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> — Loose Notes</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/"><i class="bi bi-journal-text me-2"></i>Loose Notes</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><a class="nav-link" href="/notes/top-rated"><i class="bi bi-star me-1"></i>Top Rated</a></li>
        <% if (currentUser) { %>
          <li class="nav-item"><a class="nav-link" href="/notes"><i class="bi bi-sticky me-1"></i>My Notes</a></li>
          <li class="nav-item"><a class="nav-link" href="/notes/search"><i class="bi bi-search me-1"></i>Search</a></li>
          <% if (currentUser.role === 'admin') { %>
            <li class="nav-item"><a class="nav-link" href="/admin"><i class="bi bi-shield-lock me-1"></i>Admin</a></li>
          <% } %>
        <% } %>
      </ul>
      <ul class="navbar-nav">
        <% if (currentUser) { %>
          <li class="nav-item"><a class="nav-link" href="/profile"><i class="bi bi-person me-1"></i><%= currentUser.username %></a></li>
          <li class="nav-item"><a class="nav-link" href="/auth/logout"><i class="bi bi-box-arrow-right me-1"></i>Logout</a></li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/auth/login">Login</a></li>
          <li class="nav-item"><a class="nav-link" href="/auth/register">Register</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
<main class="container mt-4">
  <% const msgs = typeof messages !== 'undefined' ? messages : {}; %>
  <% if (msgs.success && msgs.success.length) { %>
    <% msgs.success.forEach(m => { %><div class="alert alert-success alert-dismissible fade show"><%= m %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% }) %>
  <% } %>
  <% if (msgs.error && msgs.error.length) { %>
    <% msgs.error.forEach(m => { %><div class="alert alert-danger alert-dismissible fade show"><%= m %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% }) %>
  <% } %>
  <% if (msgs.info && msgs.info.length) { %>
    <% msgs.info.forEach(m => { %><div class="alert alert-info alert-dismissible fade show"><%= m %><button type="button" class="btn-close" data-bs-dismiss="alert"></button></div><% }) %>
  <% } %>
