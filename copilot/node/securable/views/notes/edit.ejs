<%- include('../partials/header') %>
<div class="row">
  <div class="col-md-8">
    <h2 class="mb-4">Edit Note</h2>
    <form action="/notes/<%= note.id %>?_method=PUT" method="POST" novalidate>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input type="hidden" name="_method" value="PUT">
      <div class="mb-3">
        <label for="title" class="form-label">Title <span class="text-danger">*</span></label>
        <input type="text" id="title" name="title" class="form-control" required maxlength="255" value="<%= note.title %>">
      </div>
      <div class="mb-3">
        <label for="content" class="form-label">Content <span class="text-danger">*</span></label>
        <textarea id="content" name="content" class="form-control" rows="12" required maxlength="50000"><%= note.content %></textarea>
      </div>
      <div class="mb-3">
        <label for="visibility" class="form-label">Visibility</label>
        <select id="visibility" name="visibility" class="form-select">
          <option value="private" <%= note.visibility === 'private' ? 'selected' : '' %>>Private</option>
          <option value="public" <%= note.visibility === 'public' ? 'selected' : '' %>>Public</option>
        </select>
      </div>
      <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        <a href="/notes/<%= note.id %>" class="btn btn-outline-secondary">Cancel</a>
      </div>
    </form>

    <% if (note.Attachments && note.Attachments.length > 0) { %>
      <hr>
      <h5>Attachments</h5>
      <ul class="list-group mb-3">
        <% note.Attachments.forEach(function(att) { %>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <span><%= att.originalName %> <small class="text-muted">(<%= Math.round(att.size/1024) %> KB)</small></span>
            <form action="/notes/<%= note.id %>/attachments/<%= att.id %>?_method=DELETE" method="POST" class="d-inline confirm-delete">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="hidden" name="_method" value="DELETE">
              <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
            </form>
          </li>
        <% }) %>
      </ul>
    <% } %>

    <hr>
    <h5>Upload Attachment</h5>
    <p class="text-muted small">Allowed: PDF, DOC, DOCX, TXT, PNG, JPG, JPEG. Max 10 MB. Max 5 files per note.</p>
    <form action="/notes/<%= note.id %>/attachments" method="POST" enctype="multipart/form-data">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="input-group">
        <input type="file" name="file" class="form-control" accept=".pdf,.doc,.docx,.txt,.png,.jpg,.jpeg">
        <button type="submit" class="btn btn-outline-primary">Upload</button>
      </div>
    </form>
  </div>
</div>
<%- include('../partials/footer') %>
