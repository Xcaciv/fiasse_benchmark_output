@model List<NoteListItemViewModel>
@{
    ViewData["Title"] = "My Notes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-journal"></i> My Notes</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> New Note
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-journal-x display-3"></i>
        <p class="mt-3">You haven't created any notes yet.</p>
        <a asp-action="Create" class="btn btn-primary">Create Your First Note</a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        @foreach (var note in Model)
        {
            <div class="col">
                <div class="card h-100 note-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0">
                                <a asp-action="Details" asp-route-id="@note.Id" class="text-decoration-none">@note.Title</a>
                            </h5>
                            @if (note.IsPublic)
                            {
                                <span class="badge bg-success ms-2">Public</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary ms-2">Private</span>
                            }
                        </div>
                        <p class="card-text text-muted small">@note.Excerpt</p>
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center small text-muted">
                        <span>
                            @if (note.RatingCount > 0)
                            {
                                <span class="star-rating"><i class="bi bi-star-fill"></i> @note.AverageRating</span>
                                <span class="ms-1">(@note.RatingCount)</span>
                            }
                            @if (note.AttachmentCount > 0)
                            {
                                <span class="ms-2"><i class="bi bi-paperclip"></i> @note.AttachmentCount</span>
                            }
                        </span>
                        <span>@note.CreatedAt.ToString("MMM d, yyyy")</span>
                    </div>
                </div>
            </div>
        }
    </div>
}
