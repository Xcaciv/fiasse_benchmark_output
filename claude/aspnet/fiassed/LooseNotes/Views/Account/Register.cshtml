@model LooseNotes.ViewModels.Account.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}
<div class="form-container">
    <h2>Create Account</h2>
    <form asp-action="Register" method="post">
        <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>
        <div class="form-group">
            <label asp-for="Username">Username</label>
            <input asp-for="Username" class="form-control" autocomplete="username" />
            <span asp-validation-for="Username" class="field-error"></span>
        </div>
        <div class="form-group">
            <label asp-for="Email">Email</label>
            <input asp-for="Email" class="form-control" autocomplete="email" />
            <span asp-validation-for="Email" class="field-error"></span>
        </div>
        <div class="form-group">
            <label asp-for="Password">Password</label>
            <!-- type=password required (ASVS V6.2.6); paste not blocked (ASVS V6.2.7) -->
            <input asp-for="Password" class="form-control password-field" autocomplete="new-password" />
            <button type="button" class="btn-toggle-password" aria-label="Show/hide password">Show</button>
            <span asp-validation-for="Password" class="field-error"></span>
            <small class="help-text">Minimum 8 characters. No composition rules.</small>
        </div>
        <div class="form-group">
            <label asp-for="ConfirmPassword">Confirm Password</label>
            <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="field-error"></span>
        </div>
        <button type="submit" class="btn btn-primary">Create Account</button>
    </form>
    <div class="form-links">
        <a asp-action="Login">Already have an account? Sign in</a>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
