<%- include('../partials/header') %>

<div class="mb-4">
  <h1 class="mb-3"><i class="bi bi-search text-primary me-2"></i>Search Notes</h1>

  <form action="/notes/search" method="GET" class="mb-4">
    <div class="input-group input-group-lg">
      <input
        type="text"
        name="q"
        class="form-control"
        placeholder="Search by keyword in title or content..."
        value="<%= q %>"
        autocomplete="off"
      >
      <button class="btn btn-primary" type="submit">
        <i class="bi bi-search me-1"></i>Search
      </button>
    </div>
    <div class="form-text mt-1">
      <i class="bi bi-info-circle me-1"></i>Searches your own notes and all public notes.
    </div>
  </form>

  <% if (q) { %>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0">
      Results for "<strong><%= q %></strong>"
      <span class="badge bg-secondary ms-2"><%= results.length %> found</span>
    </h5>
  </div>

  <% if (results && results.length > 0) { %>
  <div class="list-group">
    <% results.forEach(function(note) { %>
    <a href="/notes/<%= note.id %>" class="list-group-item list-group-item-action">
      <div class="d-flex w-100 justify-content-between align-items-center mb-1">
        <h5 class="mb-0 fw-semibold"><%= note.title %></h5>
        <div class="ms-2 flex-shrink-0">
          <% if (note.isPublic) { %>
          <span class="badge bg-success me-1"><i class="bi bi-globe me-1"></i>Public</span>
          <% } else { %>
          <span class="badge bg-secondary me-1"><i class="bi bi-lock me-1"></i>Private</span>
          <% } %>
          <small class="text-muted"><%= new Date(note.createdAt).toLocaleDateString() %></small>
        </div>
      </div>
      <p class="mb-1 text-muted small"><%= note.content.substring(0, 200) %><%= note.content.length > 200 ? '...' : '' %></p>
      <small class="text-muted">
        <i class="bi bi-person me-1"></i>
        <%= note.author ? note.author.username : 'Unknown' %>
        <% if (user && note.userId === user.id) { %>
        <span class="badge bg-info text-dark ms-1">Your note</span>
        <% } %>
      </small>
    </a>
    <% }); %>
  </div>
  <% } else { %>
  <div class="text-center py-5">
    <i class="bi bi-search display-3 text-muted mb-3"></i>
    <h5 class="text-muted">No results found</h5>
    <p class="text-muted">Try different keywords or check your spelling.</p>
  </div>
  <% } %>
  <% } else { %>
  <div class="text-center py-5 text-muted">
    <i class="bi bi-search display-3 mb-3"></i>
    <p class="lead">Enter a keyword above to search your notes and public notes.</p>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
