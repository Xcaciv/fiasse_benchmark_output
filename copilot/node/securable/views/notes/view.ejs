<%- include('../partials/header') %>
<div class="row">
  <div class="col-md-8">
    <div class="d-flex justify-content-between align-items-start mb-2">
      <h2><%= note.title %></h2>
      <% if (note.visibility === 'public') { %>
        <span class="badge bg-success ms-2 mt-1">Public</span>
      <% } else { %>
        <span class="badge bg-secondary ms-2 mt-1">Private</span>
      <% } %>
    </div>
    <p class="text-muted small">
      By <strong><%= note.author ? note.author.username : 'Unknown' %></strong>
      &mdash; Created <%= note.createdAt.toLocaleDateString() %>
      &mdash; Updated <%= note.updatedAt.toLocaleDateString() %>
    </p>

    <% if (isOwner) { %>
      <div class="mb-3 d-flex gap-2">
        <a href="/notes/<%= note.id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
        <form action="/notes/<%= note.id %>?_method=DELETE" method="POST" class="d-inline confirm-delete">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="_method" value="DELETE">
          <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
        </form>
      </div>
    <% } %>

    <div class="note-content border rounded p-3 bg-light mb-4">
      <pre class="mb-0" style="white-space: pre-wrap; word-break: break-word;"><%= note.content %></pre>
    </div>

    <% if (note.Attachments && note.Attachments.length > 0) { %>
      <h5>Attachments</h5>
      <ul class="list-group mb-4">
        <% note.Attachments.forEach(function(att) { %>
          <li class="list-group-item">
            <a href="/notes/<%= note.id %>/attachments/<%= att.id %>/download<%= typeof shareToken !== 'undefined' ? '?token=' + shareToken : '' %>">
              <%= att.originalName %>
            </a>
            <span class="text-muted small ms-2">(<%= Math.round(att.size/1024) %> KB)</span>
          </li>
        <% }) %>
      </ul>
    <% } %>

    <% if (isOwner) { %>
      <h5>Share Links</h5>
      <% if (shareLinks && shareLinks.length > 0) { %>
        <% shareLinks.forEach(function(sl) { %>
          <div class="input-group mb-2">
            <input type="text" class="form-control form-control-sm" readonly
              value="<%= process.env.BASE_URL || 'http://localhost:3000' %>/share/<%= sl.token %>">
          </div>
        <% }) %>
        <form action="/notes/<%= note.id %>/share?_method=DELETE" method="POST" class="d-inline confirm-delete">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input type="hidden" name="_method" value="DELETE">
          <button type="submit" class="btn btn-sm btn-outline-danger">Revoke All Share Links</button>
        </form>
      <% } else { %>
        <p class="text-muted">No active share links.</p>
      <% } %>
      <form action="/notes/<%= note.id %>/share" method="POST" class="mt-2">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button type="submit" class="btn btn-sm btn-outline-primary">Generate Share Link</button>
      </form>
      <hr>
    <% } %>

    <h5>Ratings
      <% if (avgRating) { %>
        <span class="text-warning">★</span> <%= avgRating %>
        <small class="text-muted">(<%= note.Ratings ? note.Ratings.length : 0 %> ratings)</small>
      <% } %>
    </h5>

    <% if (note.Ratings && note.Ratings.length > 0) { %>
      <% note.Ratings.forEach(function(r) { %>
        <div class="card mb-2">
          <div class="card-body py-2 px-3">
            <div class="d-flex justify-content-between">
              <strong><%= r.rater ? r.rater.username : 'User' %></strong>
              <span class="text-warning"><%= '★'.repeat(r.value) %><%= '☆'.repeat(5 - r.value) %></span>
            </div>
            <% if (r.comment) { %><p class="mb-0 text-muted small"><%= r.comment %></p><% } %>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <p class="text-muted">No ratings yet.</p>
    <% } %>

    <% if (user && !isOwner) { %>
      <hr>
      <h5>Rate this Note</h5>
      <form action="/notes/<%= note.id %>/ratings" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="mb-2 star-rating" id="starRating">
          <% for (let i = 1; i <= 5; i++) { %>
            <label>
              <input type="radio" name="value" value="<%= i %>" required>
              <span class="star">★</span>
            </label>
          <% } %>
        </div>
        <div class="mb-2">
          <textarea name="comment" class="form-control" rows="2" maxlength="1000" placeholder="Optional comment"></textarea>
        </div>
        <button type="submit" class="btn btn-sm btn-primary">Submit Rating</button>
      </form>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
