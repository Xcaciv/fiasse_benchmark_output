@model LooseNotes.Models.Note
@{
    ViewData["Title"] = "Delete Note";
}
<div class="form-container">
    <h2>Delete Note</h2>
    <div class="alert alert-warning">
        <p>Are you sure you want to permanently delete "<strong>@Html.Encode(Model.Title)</strong>"?</p>
        <p>This will also delete all attachments, ratings, and share links associated with this note.</p>
    </div>
    <form asp-action="Delete" method="post">
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="btn btn-danger">Delete Permanently</button>
        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">Cancel</a>
    </form>
</div>
