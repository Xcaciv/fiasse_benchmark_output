@model IEnumerable<Note>
@{
    ViewData["Title"] = "Browse Notes";
}

<h1>Browse Public Notes</h1>

@if (Model.Any())
{
    <div class="row">
        @foreach (var note in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">
                            <a asp-controller="Home" asp-action="ViewNote" asp-route-id="@note.Id">
                                @note.Title
                            </a>
                        </h5>
                        <p class="card-text text-muted">
                            @if (note.Content.Length > 150)
                            {
                                @note.Content.Substring(0, 150)
                                <text>...</text>
                            }
                            else
                            {
                                @note.Content
                            }
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">
                                by @note.User?.UserName | 
                                @note.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
                            </small>
                            @if (note.RatingCount > 0)
                            {
                                <small class="badge bg-warning text-dark">
                                    @note.AverageRating.ToString("F1")/5
                                </small>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <h3>No public notes yet</h3>
        <p>Be the first to share a note!</p>
        @if (User.Identity?.IsAuthenticated == true)
        {
            <a asp-controller="Notes" asp-action="Create" class="btn btn-primary">Create Note</a>
        }
        else
        {
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary">Register to Create</a>
        }
    </div>
}
