<h1>Top Rated Notes</h1>
<p class="page-subtitle">Public notes with at least 3 ratings, sorted by average rating.</p>

<% if (notes.length === 0) { %>
  <p class="empty-state">No notes have enough ratings yet.</p>
<% } else { %>
  <div class="notes-list">
    <% notes.forEach((note, i) => { %>
      <div class="note-card note-card-ranked">
        <div class="rank">#<%= i + 1 %></div>
        <div class="note-card-body">
          <a href="/notes/<%= note.id %>"><h2><%= note.title %></h2></a>
          <p class="note-excerpt"><%= note.content.substring(0, 200) %><%= note.content.length > 200 ? '…' : '' %></p>
          <div class="note-meta">
            By <strong><%= note.owner.username %></strong> &nbsp;|&nbsp;
            ★ <%= parseFloat(note.dataValues.avgRating).toFixed(1) %>
            (<%= note.dataValues.ratingCount %> ratings)
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
