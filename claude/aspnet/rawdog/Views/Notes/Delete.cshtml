@model LooseNotes.Models.Note
@{
    ViewData["Title"] = "Delete Note";
}

<h2>Delete Note</h2>
<div class="alert alert-danger">
    <strong>Are you sure you want to delete this note?</strong>
    This will permanently remove the note, all attachments, ratings, and share links.
</div>

<dl class="row">
    <dt class="col-sm-3">Title</dt>
    <dd class="col-sm-9">@Model.Title</dd>
    <dt class="col-sm-3">Created</dt>
    <dd class="col-sm-9">@Model.CreatedAt.ToString("MMM d, yyyy")</dd>
</dl>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary ms-2">Cancel</a>
</form>
