@model IEnumerable<LooseNotes.Models.Note>
@{
    ViewData["Title"] = "Top Rated Notes";
}
<h2>⭐ Top Rated Notes</h2>
<p class="text-muted">Public notes with at least 3 ratings, sorted by average rating.</p>

@if (!Model.Any())
{
    <div class="alert alert-info">No notes have enough ratings yet. Start rating notes!</div>
}
else
{
    <div class="list-group">
        @foreach (var note in Model)
        {
            var avg = note.Ratings.Average(r => r.Stars);
            <a asp-controller="Notes" asp-action="Details" asp-route-id="@note.Id" class="list-group-item list-group-item-action">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-1">@note.Title</h5>
                        <small class="text-muted">by @note.User?.UserName · @note.CreatedAt.ToString("MMM d, yyyy")</small>
                        <p class="mb-0 small mt-1">@(note.Content.Length > 200 ? note.Content.Substring(0, 200) + "..." : note.Content)</p>
                    </div>
                    <div class="text-end ms-3">
                        <span class="badge bg-warning text-dark fs-6">⭐ @avg.ToString("F1")</span>
                        <div class="small text-muted">@note.Ratings.Count ratings</div>
                    </div>
                </div>
            </a>
        }
    </div>
}
