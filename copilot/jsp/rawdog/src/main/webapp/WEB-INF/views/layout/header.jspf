<%@ page import="com.loosenotes.model.User,com.loosenotes.util.CsrfUtil,com.loosenotes.util.HtmlUtil" %>
<%
    User currentUser = (User) session.getAttribute("authUser");
    String flashSuccess = (String) session.getAttribute("flashSuccess");
    String flashError = (String) session.getAttribute("flashError");
    session.removeAttribute("flashSuccess");
    session.removeAttribute("flashError");
    String pageTitle = (String) request.getAttribute("pageTitle");
    if (pageTitle == null || pageTitle.isBlank()) {
        pageTitle = "Loose Notes";
    }
%>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= HtmlUtil.escape(pageTitle) %> - Loose Notes</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="<%= request.getContextPath() %>/assets/app.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container">
        <a class="navbar-brand" href="<%= request.getContextPath() %>/">Loose Notes</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link" href="<%= request.getContextPath() %>/">Search</a></li>
                <li class="nav-item"><a class="nav-link" href="<%= request.getContextPath() %>/top-rated">Top Rated</a></li>
                <% if (currentUser != null) { %>
                    <li class="nav-item"><a class="nav-link" href="<%= request.getContextPath() %>/notes">My Notes</a></li>
                    <li class="nav-item"><a class="nav-link" href="<%= request.getContextPath() %>/notes/create">Create Note</a></li>
                    <li class="nav-item"><a class="nav-link" href="<%= request.getContextPath() %>/profile">Profile</a></li>
                    <% if (currentUser.isAdmin()) { %>
                        <li class="nav-item"><a class="nav-link" href="<%= request.getContextPath() %>/admin">Admin</a></li>
                    <% } %>
                <% } %>
            </ul>
            <div class="d-flex align-items-center gap-2 text-white">
                <% if (currentUser == null) { %>
                    <a class="btn btn-outline-light btn-sm" href="<%= request.getContextPath() %>/auth/login">Sign In</a>
                    <a class="btn btn-warning btn-sm" href="<%= request.getContextPath() %>/auth/register">Register</a>
                <% } else { %>
                    <span class="small">Signed in as <strong><%= HtmlUtil.escape(currentUser.getUsername()) %></strong></span>
                    <form action="<%= request.getContextPath() %>/auth/logout" method="post" class="mb-0">
                        <input type="hidden" name="csrfToken" value="<%= CsrfUtil.token(session) %>">
                        <button class="btn btn-outline-light btn-sm" type="submit">Logout</button>
                    </form>
                <% } %>
            </div>
        </div>
    </div>
</nav>
<div class="container pb-5">
    <% if (flashSuccess != null) { %>
        <div class="alert alert-success"><%= HtmlUtil.escape(flashSuccess) %></div>
    <% } %>
    <% if (flashError != null) { %>
        <div class="alert alert-danger"><%= HtmlUtil.escape(flashError) %></div>
    <% } %>
    <% String errorMessage = (String) request.getAttribute("errorMessage");
       if (errorMessage != null) { %>
        <div class="alert alert-danger"><%= HtmlUtil.escape(errorMessage) %></div>
    <% } %>
    <% String successMessage = (String) request.getAttribute("successMessage");
       if (successMessage != null) { %>
        <div class="alert alert-success"><%= HtmlUtil.escape(successMessage) %></div>
    <% } %>
