@model List<LooseNotes.ViewModels.TopRatedNoteViewModel>
@{
    ViewData["Title"] = "Top Rated Notes";
}

<h2>Top Rated Notes</h2>
<p class="text-muted">Public notes with at least 3 ratings, sorted by average rating.</p>

@if (!Model.Any())
{
    <div class="alert alert-info">No notes have reached the minimum 3 ratings yet.</div>
}

@foreach (var note in Model)
{
    <div class="card mb-3">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
                <h5 class="card-title">
                    <a asp-action="Details" asp-route-id="@note.Id">@note.Title</a>
                </h5>
                <div class="star-rating">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <span>@(i <= Math.Round(note.AverageRating) ? "★" : "☆")</span>
                    }
                    <span class="text-muted small ms-1">@note.AverageRating.ToString("0.0") (@note.RatingCount ratings)</span>
                </div>
            </div>
            <p class="text-muted small">By @note.AuthorName</p>
            <p class="card-text">@note.Preview</p>
        </div>
    </div>
}
