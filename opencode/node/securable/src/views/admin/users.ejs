<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manage Users - Loose Notes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include ../partials/navbar %>
  <%- include ../partials/flash %>
  <main class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h1>Manage Users</h1>
      <a href="/admin" class="btn btn-outline-secondary">Back to Dashboard</a>
    </div>

    <form action="/admin/users" method="GET" class="mb-4">
      <div class="input-group">
        <input type="text" class="form-control" name="search" placeholder="Search by username or email..." value="<%= typeof search !== 'undefined' ? search : '' %>">
        <button class="btn btn-outline-secondary" type="submit">Search</button>
        <% if (search) { %>
          <a href="/admin/users" class="btn btn-outline-secondary">Clear</a>
        <% } %>
      </div>
    </form>

    <div class="table-responsive">
      <table class="table table-hover">
        <thead>
          <tr>
            <th>ID</th>
            <th>Username</th>
            <th>Email</th>
            <th>Role</th>
            <th>Notes</th>
            <th>Joined</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (users && users.length > 0) { %>
            <% users.forEach(function(u) { %>
              <tr>
                <td><%= u.id %></td>
                <td><%= u.username %></td>
                <td><%= u.email %></td>
                <td><span class="badge bg-<%= u.role === 'admin' ? 'danger' : 'secondary' %>"><%= u.role %></span></td>
                <td><%= u.note_count %></td>
                <td><%= new Date(u.created_at).toLocaleDateString() %></td>
                <td>
                  <a href="/admin/users/<%= u.id %>" class="btn btn-sm btn-outline-primary">View</a>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr><td colspan="7" class="text-center">No users found</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </main>
  <%- include ../partials/footer %>
</body>
</html>
