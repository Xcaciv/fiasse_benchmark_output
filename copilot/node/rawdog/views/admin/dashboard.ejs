<div class="row">
  <div class="col-md-4 mb-4">
    <div class="card shadow-sm text-center">
      <div class="card-body py-4">
        <h1 class="display-4 text-primary fw-bold"><%= totalUsers %></h1>
        <p class="text-muted mb-0">Total Users</p>
      </div>
    </div>
  </div>
  <div class="col-md-4 mb-4">
    <div class="card shadow-sm text-center">
      <div class="card-body py-4">
        <h1 class="display-4 text-success fw-bold"><%= totalNotes %></h1>
        <p class="text-muted mb-0">Total Notes</p>
      </div>
    </div>
  </div>
  <div class="col-md-4 mb-4">
    <div class="card shadow-sm text-center">
      <div class="card-body py-4">
        <a href="/admin/users" class="btn btn-outline-primary btn-lg">Manage Users</a>
      </div>
    </div>
  </div>
</div>

<div class="card shadow-sm">
  <div class="card-header"><strong>Recent Activity (last 20)</strong></div>
  <% if (recentActivity.length === 0) { %>
    <div class="card-body text-muted">No activity yet.</div>
  <% } else { %>
    <ul class="list-group list-group-flush">
      <% recentActivity.forEach(log => { %>
        <li class="list-group-item">
          <div class="d-flex justify-content-between">
            <span>
              <strong><%= log.User ? log.User.username : 'System' %></strong>
              — <code><%= log.action %></code>
              <% if (log.details) { %><span class="text-muted"> — <%= log.details %></span><% } %>
            </span>
            <small class="text-muted"><%= new Date(log.createdAt).toLocaleString() %></small>
          </div>
        </li>
      <% }) %>
    </ul>
  <% } %>
</div>
