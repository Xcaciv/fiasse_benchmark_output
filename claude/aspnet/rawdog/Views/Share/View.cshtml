@model Note
@{
    ViewData["Title"] = Model.Title;
    Layout = "_Layout";
}

<div class="row">
    <div class="col-lg-8">
        <div class="alert alert-info py-2">
            <i class="bi bi-link-45deg"></i> You are viewing a shared note.
            @if (!User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Account" asp-action="Register" class="ms-2">Create an account</a><text> to save your own notes.</text>
            }
        </div>

        <h1 class="h2">@Model.Title</h1>
        <small class="text-muted">
            By <strong>@Model.Owner?.UserName</strong> &bull;
            @Model.CreatedAt.ToString("MMMM d, yyyy")
        </small>

        <div class="card my-4">
            <div class="card-body" style="white-space: pre-wrap;">@Model.Content</div>
        </div>

        @if (Model.Attachments.Any())
        {
            <div class="mb-4">
                <h5><i class="bi bi-paperclip"></i> Attachments</h5>
                <ul class="list-group">
                    @foreach (var att in Model.Attachments)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <span><i class="bi bi-file-earmark"></i> @att.OriginalFileName</span>
                            <a asp-controller="Notes" asp-action="DownloadAttachment" asp-route-id="@att.Id"
                               class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-download"></i> Download
                            </a>
                        </li>
                    }
                </ul>
            </div>
        }

        @if (Model.Ratings.Any())
        {
            var avg = Model.Ratings.Average(r => r.Stars);
            <div>
                <h5>
                    <i class="bi bi-star"></i> Ratings
                    <span class="text-muted small ms-2">
                        <span class="star-rating">@avg.ToString("F1") <i class="bi bi-star-fill"></i></span>
                        (@Model.Ratings.Count)
                    </span>
                </h5>
                @foreach (var r in Model.Ratings.OrderByDescending(r => r.CreatedAt))
                {
                    <div class="card mb-2">
                        <div class="card-body py-2">
                            <div class="d-flex justify-content-between">
                                <strong>@r.User?.UserName</strong>
                                <span class="star-rating">@r.Stars ★</span>
                            </div>
                            @if (!string.IsNullOrEmpty(r.Comment))
                            {
                                <p class="mb-0 mt-1 text-muted small">@r.Comment</p>
                            }
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
