{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=loosenotes.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "LooseNotes.Controllers": "Information"
    }
  },
  "AllowedHosts": "*",
  "FileStorage": {
    "AttachmentsPath": "attachments",
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [ ".pdf", ".txt", ".md", ".png", ".jpg", ".jpeg", ".gif", ".csv", ".docx", ".xlsx" ]
  },
  "Security": {
    "PasswordResetTokenExpiryMinutes": 60,
    "ShareTokenLength": 32
  },
  "SeedAccounts": []
}
