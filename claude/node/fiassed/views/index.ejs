<div class="hero">
  <h1>Welcome to Loose Notes</h1>
  <p class="hero-subtitle">A secure note-taking application built with FIASSE/SSEM engineering principles.</p>

  <% if (typeof currentUser !== 'undefined' && currentUser) { %>
    <div class="hero-actions">
      <a href="/notes" class="btn btn-primary">My Notes</a>
      <a href="/notes/create" class="btn btn-secondary">Create Note</a>
    </div>
  <% } else { %>
    <div class="hero-actions">
      <a href="/auth/register" class="btn btn-primary">Get Started</a>
      <a href="/auth/login" class="btn btn-secondary">Sign In</a>
    </div>
    <p><a href="/notes/top-rated">Browse top-rated public notes</a></p>
  <% } %>
</div>

<section class="features">
  <div class="feature-card">
    <h3>Secure by Design</h3>
    <p>All notes are private by default. Share publicly only when you choose to.</p>
  </div>
  <div class="feature-card">
    <h3>File Attachments</h3>
    <p>Attach PDF, Office, text, and image files with MIME-type validation.</p>
  </div>
  <div class="feature-card">
    <h3>Community Ratings</h3>
    <p>Rate and discover top-rated public notes from the community.</p>
  </div>
  <div class="feature-card">
    <h3>Share Links</h3>
    <p>Generate revocable share links for any note you own.</p>
  </div>
</section>
