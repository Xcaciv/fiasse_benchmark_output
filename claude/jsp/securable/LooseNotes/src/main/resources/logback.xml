<?xml version="1.0" encoding="UTF-8"?>
<!--
    Logback configuration – SSEM Transparency / Accountability
    Structured JSON-style output for machine-parseable audit logs.
    Security events use a dedicated appender to separate audit trail from debug noise.
-->
<configuration>

    <!-- Console appender: human-readable for local development -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Application log file with daily rolling -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>./logs/loose-notes.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>./logs/loose-notes.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Audit log: security-sensitive events only – append-only, separate file -->
    <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>./logs/loose-notes-audit.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>./logs/loose-notes-audit.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>90</maxHistory>
        </rollingPolicy>
        <encoder>
            <!-- Structured key=value log format for easy parsing -->
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} AUDIT [%thread] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Dedicated logger for audit events – goes ONLY to the audit file -->
    <logger name="AUDIT" level="INFO" additivity="false">
        <appender-ref ref="AUDIT_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Reduce H2 and connection-pool noise in dev -->
    <logger name="com.zaxxer.hikari" level="WARN"/>
    <logger name="org.h2" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>
