@model DashboardViewModel
@{
    ViewData["Title"] = "Admin dashboard";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">Admin dashboard</h1>
        <p class="text-muted mb-0">Monitor users, notes, and administrative activity.</p>
    </div>
    <a asp-action="Users" class="btn btn-outline-primary">Manage users</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-6">
        <div class="metric-card h-100">
            <div class="metric-value">@Model.TotalUserCount</div>
            <div class="metric-label">Registered users</div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="metric-card h-100">
            <div class="metric-value">@Model.TotalNoteCount</div>
            <div class="metric-label">Notes in database</div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body p-4">
        <h2 class="h4 mb-3">Recent activity</h2>
        @if (Model.RecentActivity.Count == 0)
        {
            <p class="text-muted mb-0">No activity has been recorded yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Action</th>
                            <th>Actor</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.RecentActivity)
                        {
                            <tr>
                                <td>@item.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                                <td><code>@item.ActionType</code></td>
                                <td>@(item.ActorUserName ?? "System")</td>
                                <td>@item.Description</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
