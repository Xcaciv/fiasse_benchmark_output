@model LooseNotes.ViewModels.Account.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
}
<div class="form-container">
    <h2>Reset Password</h2>
    <p>Enter your email address and we'll send you a reset link.</p>
    <form asp-action="ForgotPassword" method="post">
        <div class="form-group">
            <label asp-for="Email">Email</label>
            <input asp-for="Email" class="form-control" autocomplete="email" />
            <span asp-validation-for="Email" class="field-error"></span>
        </div>
        <button type="submit" class="btn btn-primary">Send Reset Link</button>
    </form>
    <div class="form-links">
        <a asp-action="Login">Back to sign in</a>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
