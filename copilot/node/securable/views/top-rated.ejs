<section class="mb-4">
  <div class="p-4 bg-white rounded-3 shadow-sm border">
    <h1 class="h3 mb-2">Top rated public notes</h1>
    <p class="text-body-secondary mb-0">Only notes with at least three ratings appear here.</p>
  </div>
</section>

<section>
  <% if (!notes.length) { %>
    <div class="alert alert-light border">No public notes have reached the minimum rating threshold yet.</div>
  <% } %>

  <div class="row g-3">
    <% for (const note of notes) { %>
      <div class="col-12">
        <article class="card shadow-sm">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start gap-3">
              <div>
                <h2 class="h5 mb-1"><a class="text-decoration-none" href="/notes/<%= note.id %>"><%= note.title %></a></h2>
                <div class="small text-body-secondary">By <%= note.author %></div>
              </div>
              <div class="text-end">
                <div class="fw-semibold"><%= note.average_rating %>/5</div>
                <div class="small text-body-secondary"><%= note.rating_count %> rating(s)</div>
              </div>
            </div>
            <p class="mt-3 mb-0"><%= note.excerpt %></p>
          </div>
        </article>
      </div>
    <% } %>
  </div>
</section>
