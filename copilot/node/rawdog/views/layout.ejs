<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — Loose Notes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: #f8f9fa; }
    .navbar-brand { font-weight: bold; font-size: 1.4rem; }
    .star { color: #ffc107; }
    .star-empty { color: #dee2e6; }
    footer { margin-top: 3rem; padding: 1.5rem 0; border-top: 1px solid #dee2e6; color: #6c757d; }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container">
      <a class="navbar-brand" href="/notes">📝 Loose Notes</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navMenu">
        <ul class="navbar-nav me-auto">
          <% if (locals.currentUser) { %>
            <li class="nav-item"><a class="nav-link" href="/notes">My Notes</a></li>
            <li class="nav-item"><a class="nav-link" href="/notes/new">New Note</a></li>
            <li class="nav-item"><a class="nav-link" href="/notes/search">Search</a></li>
            <li class="nav-item"><a class="nav-link" href="/notes/top-rated">Top Rated</a></li>
            <% if (locals.currentUser.role === 'admin') { %>
              <li class="nav-item"><a class="nav-link text-warning" href="/admin">Admin</a></li>
            <% } %>
          <% } %>
        </ul>
        <ul class="navbar-nav ms-auto">
          <% if (locals.currentUser) { %>
            <li class="nav-item"><a class="nav-link" href="/profile"><%= locals.currentUser.username %></a></li>
            <li class="nav-item">
              <form action="/auth/logout" method="POST" class="d-inline">
                <button type="submit" class="btn btn-link nav-link">Logout</button>
              </form>
            </li>
          <% } else { %>
            <li class="nav-item"><a class="nav-link" href="/auth/login">Login</a></li>
            <li class="nav-item"><a class="nav-link" href="/auth/register">Register</a></li>
          <% } %>
        </ul>
      </div>
    </div>
  </nav>

  <div class="container">
    <%- include('partials/flash') %>
    <%- body %>
  </div>

  <footer class="text-center">
    <div class="container">Loose Notes &copy; <%= new Date().getFullYear() %></div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
