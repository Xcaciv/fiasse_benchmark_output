<%- include('partials/header') %>
<div class="text-center py-5">
  <h1 class="display-1 text-muted"><%= statusCode %></h1>
  <h2 class="mb-3"><% if (statusCode === 404) { %>Page Not Found<% } else if (statusCode === 403) { %>Access Denied<% } else { %>Something Went Wrong<% } %></h2>
  <p class="text-muted mb-4"><%= message %></p>
  <a href="/" class="btn btn-primary">Go Home</a>
  <% if (typeof user !== 'undefined' && user) { %>
    <a href="/notes" class="btn btn-outline-secondary ms-2">My Notes</a>
  <% } %>
</div>
<%- include('partials/footer') %>
