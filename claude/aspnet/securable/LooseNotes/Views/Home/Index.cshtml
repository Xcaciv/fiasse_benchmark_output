@{
    ViewData["Title"] = "Welcome";
}
<div class="text-center py-5">
    <h1 class="display-4">Loose Notes</h1>
    <p class="lead">Capture, organize, and share your notes with the world.</p>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-controller="Notes" asp-action="Index" class="btn btn-primary btn-lg me-2">My Notes</a>
        <a asp-controller="Notes" asp-action="Create" class="btn btn-success btn-lg">New Note</a>
    }
    else
    {
        <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg me-2">Get Started</a>
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-lg">Log In</a>
    }
</div>
<div class="row mt-4 text-center">
    <div class="col-md-4">
        <h4>Create</h4>
        <p>Write notes with titles and rich content. Keep them private or share with the world.</p>
    </div>
    <div class="col-md-4">
        <h4>Share</h4>
        <p>Generate shareable links for any note. Revoke access at any time.</p>
    </div>
    <div class="col-md-4">
        <h4>Discover</h4>
        <p>Search public notes or browse the top-rated collection.</p>
    </div>
</div>
