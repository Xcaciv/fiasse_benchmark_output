@model LooseNotes.ViewModels.Account.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}
<div class="form-container">
    <h2>Set New Password</h2>
    <form asp-action="ResetPassword" method="post">
        <input type="hidden" asp-for="Token" />
        <input type="hidden" asp-for="Email" />
        <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>
        <div class="form-group">
            <label asp-for="NewPassword">New Password</label>
            <input asp-for="NewPassword" class="form-control password-field" autocomplete="new-password" />
            <button type="button" class="btn-toggle-password" aria-label="Show/hide password">Show</button>
            <span asp-validation-for="NewPassword" class="field-error"></span>
            <small class="help-text">Minimum 8 characters.</small>
        </div>
        <div class="form-group">
            <label asp-for="ConfirmPassword">Confirm Password</label>
            <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="field-error"></span>
        </div>
        <button type="submit" class="btn btn-primary">Set New Password</button>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
