## .NET / ASP.NET Core gitignore

# Build outputs
bin/
obj/

# Database files — never commit
*.db
*.db-shm
*.db-wal

# Upload directory — user data, not source
uploads/

# Log files
logs/

# User secrets (Confidentiality — secrets must not be committed)
**/secrets.json
appsettings.Production.json

# IDE
.vs/
.vscode/
*.user
