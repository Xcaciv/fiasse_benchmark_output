<% if (locals.flash) { %>
  <% const typeMap = { success: 'success', error: 'danger', info: 'info', warning: 'warning' }; %>
  <% const bsType = typeMap[flash.type] || 'info'; %>
  <div class="alert alert-<%= bsType %> alert-dismissible fade show" role="alert">
    <%= flash.message %>
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
<% } %>
