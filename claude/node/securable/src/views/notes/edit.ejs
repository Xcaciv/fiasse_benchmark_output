<div class="card form-card form-card-wide">
  <h1>Edit Note</h1>
  <form method="POST" action="/notes/<%= note.id %>/edit">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <div class="form-group">
      <label for="title">Title <span class="required">*</span></label>
      <input type="text" id="title" name="title" value="<%= note.title %>"
             required maxlength="255" />
    </div>

    <div class="form-group">
      <label for="content">Content <span class="required">*</span></label>
      <textarea id="content" name="content" rows="12" required><%= note.content %></textarea>
    </div>

    <div class="form-group form-check">
      <input type="checkbox" id="isPublic" name="isPublic" value="on"
             <%= note.isPublic ? 'checked' : '' %> />
      <label for="isPublic">Make this note public</label>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Save Changes</button>
      <a href="/notes/<%= note.id %>" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>
