@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}
<h2>Admin Dashboard</h2>
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3 class="card-title">@Model.TotalUsers</h3>
                <p class="card-text text-muted">Total Users</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <h3 class="card-title">@Model.TotalNotes</h3>
                <p class="card-text text-muted">Total Notes</p>
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-2">
    <h5>Recent Activity</h5>
    <a asp-action="Users" class="btn btn-sm btn-outline-primary">Manage Users</a>
</div>

@if (Model.RecentActivity.Any())
{
    <div class="table-responsive">
        <table class="table table-sm table-striped">
            <thead>
                <tr>
                    <th>Time</th>
                    <th>Action</th>
                    <th>User</th>
                    <th>Target</th>
                    <th>Success</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model.RecentActivity)
                {
                    <tr>
                        <td class="text-muted small">@log.OccurredAt.ToString("MM/dd HH:mm")</td>
                        <td>@log.Action</td>
                        <td>@(log.User?.UserName ?? log.UserId ?? "anonymous")</td>
                        <td class="text-muted small">@log.TargetType @log.TargetId</td>
                        <td>
                            @if (log.Success)
                            {
                                <span class="badge bg-success">OK</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Fail</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
else
{
    <p class="text-muted">No activity logged yet.</p>
}
