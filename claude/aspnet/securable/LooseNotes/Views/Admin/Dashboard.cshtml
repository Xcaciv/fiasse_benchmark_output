@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}
<h2>Admin Dashboard</h2>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">Total Users</h5>
                <p class="display-6">@Model.TotalUsers</p>
                <a asp-action="Users" class="btn btn-sm btn-outline-primary">Manage Users</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-center">
            <div class="card-body">
                <h5 class="card-title">Total Notes</h5>
                <p class="display-6">@Model.TotalNotes</p>
            </div>
        </div>
    </div>
</div>

<h4>Recent Activity</h4>
@if (!Model.RecentActivity.Any())
{
    <p class="text-muted">No activity recorded yet.</p>
}
else
{
    <table class="table table-sm table-striped">
        <thead>
            <tr>
                <th>Action</th>
                <th>User</th>
                <th>Resource</th>
                <th>Result</th>
                <th>Time</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.RecentActivity)
            {
                <tr>
                    <td>@item.Action</td>
                    <td>@(item.UserId ?? "anonymous")</td>
                    <td>@item.ResourceType/@item.ResourceId</td>
                    <td>
                        <span class="badge @(item.Succeeded ? "bg-success" : "bg-danger")">
                            @(item.Succeeded ? "OK" : "FAIL")
                        </span>
                    </td>
                    <td>@item.OccurredAt.ToString("MMM d HH:mm")</td>
                </tr>
            }
        </tbody>
    </table>
}
