@model RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="mb-4">Create Account</h2>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Username" class="form-label"></label>
                <input asp-for="Username" class="form-control" autocomplete="off" id="emailInput" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" id="emailField" />
                <datalist id="emailSuggestions"></datalist>
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" type="password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <input asp-for="ConfirmPassword" type="password" class="form-control" />
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>

            <hr />
            <h6 class="mb-3">Security Question (optional)</h6>

            <div class="mb-3">
                <label asp-for="SecurityQuestion" class="form-label"></label>
                <select asp-for="SecurityQuestion" class="form-select">
                    <option value="">-- Select a question --</option>
                    <option>What is the name of your first pet?</option>
                    <option>What city were you born in?</option>
                    <option>What is your mother's maiden name?</option>
                    <option>What was the name of your first school?</option>
                    <option>What is your favourite film?</option>
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="SecurityAnswer" class="form-label"></label>
                <input asp-for="SecurityAnswer" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary w-100">Register</button>
        </form>

        <div class="mt-3 text-center">
            <a asp-action="Login">Already have an account? Login</a>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // Email autocomplete (§15)
    document.getElementById('emailField').addEventListener('input', function () {
        var q = this.value;
        if (q.length < 2) return;
        fetch('/Account/EmailAutocomplete?q=' + encodeURIComponent(q))
            .then(r => r.json())
            .then(emails => {
                var dl = document.getElementById('emailSuggestions');
                dl.innerHTML = '';
                emails.forEach(e => {
                    var opt = document.createElement('option');
                    opt.value = e;
                    dl.appendChild(opt);
                });
            });
    });
    document.getElementById('emailField').setAttribute('list', 'emailSuggestions');
</script>
}
