@{
    ViewData["Title"] = "Password Recovery";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="mb-4">Password Recovery</h2>

        @if (ViewBag.RecoveredPassword != null)
        {
            <div class="alert alert-success">
                <h5>Your password has been retrieved.</h5>
                <p class="mb-1">Your current password is:</p>
                <strong class="fs-5">@ViewBag.RecoveredPassword</strong>
            </div>
        }

        <a asp-action="Login" class="btn btn-primary">Go to Login</a>
    </div>
</div>
