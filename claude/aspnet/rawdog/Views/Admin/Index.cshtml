@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2><i class="bi bi-shield-check"></i> Admin Dashboard</h2>

<div class="row mt-4 g-4">
    <div class="col-md-3">
        <div class="card text-center border-primary">
            <div class="card-body">
                <i class="bi bi-people display-4 text-primary"></i>
                <h3 class="mt-2">@Model.TotalUsers</h3>
                <p class="text-muted mb-0">Total Users</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-success">
            <div class="card-body">
                <i class="bi bi-journal-text display-4 text-success"></i>
                <h3 class="mt-2">@Model.TotalNotes</h3>
                <p class="text-muted mb-0">Total Notes</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-info">
            <div class="card-body">
                <i class="bi bi-globe display-4 text-info"></i>
                <h3 class="mt-2">@Model.TotalPublicNotes</h3>
                <p class="text-muted mb-0">Public Notes</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center border-warning">
            <div class="card-body">
                <i class="bi bi-star display-4 text-warning"></i>
                <h3 class="mt-2">@Model.TotalRatings</h3>
                <p class="text-muted mb-0">Total Ratings</p>
            </div>
        </div>
    </div>
</div>

<div class="mt-4 d-flex gap-2">
    <a asp-action="Users" class="btn btn-outline-primary">
        <i class="bi bi-people"></i> Manage Users
    </a>
</div>
