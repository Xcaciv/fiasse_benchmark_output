@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
}

<div class="row justify-content-center">
    <div class="col-md-4">
        <h2 class="mb-4">Security Question</h2>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form asp-action="ResetPassword" method="post">
            <input type="hidden" asp-for="Email" />

            @if (!string.IsNullOrEmpty(Model?.SecurityQuestion))
            {
                <div class="mb-3">
                    <label class="form-label fw-bold">Security Question</label>
                    <p class="text-muted">@Model.SecurityQuestion</p>
                </div>
            }

            <div class="mb-3">
                <label asp-for="Answer" class="form-label">Your Answer</label>
                <input asp-for="Answer" class="form-control" />
            </div>

            <button type="submit" class="btn btn-primary w-100">Verify</button>
        </form>
    </div>
</div>
