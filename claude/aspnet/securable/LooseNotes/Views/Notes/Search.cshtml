@model NoteSearchViewModel
@{
    ViewData["Title"] = "Search Notes";
}

<h2>Search Notes</h2>

<form asp-action="Search" method="get" class="mb-4">
    <div class="input-group">
        <input asp-for="Query" class="form-control form-control-lg"
               placeholder="Search by title or content…"
               maxlength="200" autocomplete="off" />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@if (!string.IsNullOrEmpty(Model.Query))
{
    <p class="text-muted">@Model.Results.Count result(s) for "<strong>@Model.Query</strong>"</p>

    @if (!Model.Results.Any())
    {
        <div class="alert alert-info">No notes found matching your search.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var note in Model.Results)
            {
                <a asp-action="Details" asp-route-id="@note.Id"
                   class="list-group-item list-group-item-action">
                    <div class="d-flex w-100 justify-content-between">
                        <h6 class="mb-1">@note.Title</h6>
                        <small class="text-muted">@note.CreatedAt.ToString("MMM d, yyyy")</small>
                    </div>
                    <p class="mb-1 text-muted small">@note.Excerpt</p>
                    <small class="text-muted">by @note.AuthorUserName</small>
                </a>
            }
        </div>
    }
}
