@model Note
@{
    ViewData["Title"] = Model.Title;
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h1 class="mb-0">@Model.Title</h1>
        @if (Model.RatingCount > 0)
        {
            <span class="badge bg-warning text-dark">
                @Model.AverageRating.ToString("F1")/5 (@Model.RatingCount)
            </span>
        }
    </div>
    <div class="card-body">
        <p class="card-text" style="white-space: pre-wrap;">@Model.Content</p>
    </div>
    <div class="card-footer text-muted">
        <small>By @Model.User?.UserName | @Model.CreatedAt.ToLocalTime().ToString("MMMM dd, yyyy")</small>
    </div>
</div>

@if (Model.Attachments.Any())
{
    <div class="card mt-4">
        <div class="card-header">
            <h5>Attachments</h5>
        </div>
        <ul class="list-group list-group-flush">
            @foreach (var attachment in Model.Attachments)
            {
                <li class="list-group-item">
                    <i class="bi bi-paperclip"></i>
                    @attachment.FileName
                    <small class="text-muted">(@(attachment.FileSize / 1024) KB)</small>
                </li>
            }
        </ul>
    </div>
}

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">Back to Home</a>
</div>
