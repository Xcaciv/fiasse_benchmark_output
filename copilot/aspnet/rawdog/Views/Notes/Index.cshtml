@model LooseNotes.ViewModels.Notes.NoteListViewModel
@{
    ViewData["Title"] = "My Notes";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>My Notes</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Note</a>
</div>

@if (!Model.Notes.Any())
{
    <div class="alert alert-info">You have no notes yet. <a asp-action="Create">Create your first note</a>.</div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Title</th>
                <th>Visibility</th>
                <th>Created</th>
                <th>Updated</th>
                <th>Rating</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var note in Model.Notes)
            {
                <tr>
                    <td><a asp-action="Details" asp-route-id="@note.Id">@note.Title</a></td>
                    <td>
                        @if (note.IsPublic)
                        {
                            <span class="badge bg-success">Public</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Private</span>
                        }
                    </td>
                    <td>@note.CreatedAt.ToString("MMM d, yyyy")</td>
                    <td>@note.UpdatedAt.ToString("MMM d, yyyy")</td>
                    <td>
                        @if (note.Ratings.Any())
                        {
                            <span>⭐ @note.Ratings.Average(r => r.Stars).ToString("F1")</span>
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@note.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Share" asp-route-id="@note.Id" class="btn btn-sm btn-outline-info">Share</a>
                        <a asp-action="Delete" asp-route-id="@note.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (Model.TotalPages > 1)
    {
        <nav>
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
