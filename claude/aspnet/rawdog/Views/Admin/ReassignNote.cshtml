@model ReassignNoteViewModel
@{
    ViewData["Title"] = "Reassign Note";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <i class="bi bi-arrow-left-right"></i> Reassign Note Ownership
            </div>
            <div class="card-body p-4">
                <p><strong>Note:</strong> @Model.NoteTitle</p>
                <p><strong>Current Owner:</strong> @Model.CurrentOwnerName</p>
                <hr />
                <form asp-action="ReassignNote" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="NoteId" />
                    <input type="hidden" asp-for="NoteTitle" />
                    <input type="hidden" asp-for="CurrentOwnerId" />
                    <input type="hidden" asp-for="CurrentOwnerName" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div class="mb-4">
                        <label asp-for="NewOwnerId" class="form-label fw-semibold">Assign to User</label>
                        <select asp-for="NewOwnerId" asp-items="Model.Users" class="form-select">
                            <option value="">— Select a user —</option>
                        </select>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning"
                                onclick="return confirm('Reassign this note?')">
                            <i class="bi bi-arrow-left-right"></i> Reassign
                        </button>
                        <a asp-action="Users" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScripts") }
