<%- include('partials/head', {title}) %>
<%- include('partials/nav') %>
<div class="container mt-4">
  <div class="row">
    <div class="col-lg-8">
      <div class="alert alert-info py-2 small mb-3">
        🔗 You are viewing this note via a shared link.
      </div>
      <span class="badge bg-<%= note.is_public ? 'success' : 'secondary' %> mb-2">
        <%= note.is_public ? 'Public' : 'Shared (Private)' %>
      </span>
      <% if (note.avg_rating > 0) { %>
        <span class="text-warning ms-2">★ <%= note.avg_rating %></span>
        <span class="text-muted small">(<%= note.rating_count %> rating<%= note.rating_count === 1 ? '' : 's' %>)</span>
      <% } %>
      <h1 class="h2 mt-1 mb-1"><%= note.title %></h1>
      <p class="text-muted small mb-4">
        By <strong><%= note.username %></strong> &middot;
        Created <%= new Date(note.created_at).toLocaleDateString() %>
      </p>

      <div class="note-content mb-4">
        <%- note.content.replace(/\n/g, '<br>') %>
      </div>

      <% if (attachments.length) { %>
        <h5>Attachments</h5>
        <ul class="list-group mb-4">
          <% attachments.forEach(att => { %>
            <li class="list-group-item d-flex justify-content-between align-items-center">
              <span>📎 <%= att.original_name %>
                <span class="text-muted small">(<%= (att.size / 1024).toFixed(1) %> KB)</span>
              </span>
              <a href="/share/<%= token %>/attachments/<%= att.id %>" class="btn btn-sm btn-outline-primary">
                Download
              </a>
            </li>
          <% }) %>
        </ul>
      <% } %>

      <% if (ratings.length) { %>
        <h5>Ratings</h5>
        <div class="list-group mb-4">
          <% ratings.forEach(r => { %>
            <div class="list-group-item">
              <div class="d-flex justify-content-between">
                <strong><%= r.username %></strong>
                <span class="text-warning"><%= '★'.repeat(r.stars) %><%= '☆'.repeat(5-r.stars) %></span>
              </div>
              <% if (r.comment) { %><p class="mb-0 mt-1 small"><%= r.comment %></p><% } %>
            </div>
          <% }) %>
        </div>
      <% } %>

      <div class="text-center mt-4">
        <a href="/auth/register" class="btn btn-outline-primary">Create an account to write your own notes</a>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
