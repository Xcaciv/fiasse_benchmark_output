@model NoteDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-start gap-3 mb-4">
    <div>
        <div class="d-flex flex-wrap gap-2 align-items-center mb-2">
            <h1 class="h2 mb-0">@Model.Title</h1>
            <span class="badge @(Model.IsPublic ? "bg-success-subtle text-success" : "bg-secondary-subtle text-secondary")">
                @(Model.IsPublic ? "Public" : "Private")
            </span>
            @if (Model.AccessedByShareLink)
            {
                <span class="badge bg-info-subtle text-info">Shared link</span>
            }
        </div>
        <p class="text-muted mb-1">By @Model.Author</p>
        <p class="text-muted mb-0">
            Created @Model.CreatedAtUtc.ToLocalTime().ToString("g")
            @if (Model.UpdatedAtUtc.HasValue)
            {
                <span>- Updated @Model.UpdatedAtUtc.Value.ToLocalTime().ToString("g")</span>
            }
        </p>
    </div>
    <div class="d-flex flex-wrap gap-2">
        @if (Model.CanEdit)
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Edit</a>
        }
        @if (Model.CanDelete)
        {
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">Delete</a>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <section class="card shadow-sm mb-4">
            <div class="card-body">
                <h2 class="h5 mb-3">Content</h2>
                <div class="note-content">@Model.Content</div>
            </div>
        </section>

        <section class="card shadow-sm mb-4">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0">Attachments</h2>
                    <span class="text-muted small">@Model.Attachments.Count file(s)</span>
                </div>

                @if (Model.Attachments.Count == 0)
                {
                    <p class="text-muted mb-0">No attachments uploaded.</p>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var attachment in Model.Attachments)
                        {
                            <a asp-action="DownloadAttachment"
                               asp-route-id="@attachment.Id"
                               asp-route-token="@Model.AttachmentToken"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center gap-3">
                                <div>
                                    <div class="fw-semibold">@attachment.OriginalFileName</div>
                                    <div class="text-muted small">@attachment.ContentType</div>
                                </div>
                                <span class="text-muted small">@(attachment.SizeBytes / 1024.0m).ToString("0.0") KB</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </section>

        <section class="card shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h5 mb-0">Ratings</h2>
                    <div class="text-end">
                        <div class="fw-semibold">@Model.AverageRating.ToString("0.0") / 5</div>
                        <div class="text-muted small">@Model.RatingCount rating(s)</div>
                    </div>
                </div>

                @if (Model.CanRate)
                {
                    <form asp-action="Rate" method="post" class="border rounded p-3 mb-4">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="noteId" value="@Model.Id" />
                        <div class="row g-3">
                            <div class="col-md-3">
                                <label asp-for="RatingInput.Score" class="form-label"></label>
                                <select asp-for="RatingInput.Score" class="form-select">
                                    @for (var score = 5; score >= 1; score--)
                                    {
                                        <option value="@score">@score star@(score == 1 ? "" : "s")</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-9">
                                <label asp-for="RatingInput.Comment" class="form-label">Comment</label>
                                <textarea asp-for="RatingInput.Comment" class="form-control" rows="3" placeholder="Optional feedback"></textarea>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary mt-3">Save rating</button>
                    </form>
                }

                @if (Model.Ratings.Count == 0)
                {
                    <p class="text-muted mb-0">No ratings yet.</p>
                }
                else
                {
                    <div class="vstack gap-3">
                        @foreach (var rating in Model.Ratings)
                        {
                            <article class="border rounded p-3">
                                <div class="d-flex justify-content-between align-items-start gap-3">
                                    <div>
                                        <div class="fw-semibold">@rating.UserName</div>
                                        <div class="text-warning mb-2">@(new string('★', rating.Score))<span class="text-muted">@(new string('☆', 5 - rating.Score))</span></div>
                                    </div>
                                    <div class="text-muted small">@rating.CreatedAtUtc.ToLocalTime().ToString("g")</div>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(rating.Comment))
                                {
                                    <p class="mb-0">@rating.Comment</p>
                                }
                            </article>
                        }
                    </div>
                }
            </div>
        </section>
    </div>

    <div class="col-lg-4">
        @if (Model.CanManageShareLinks)
        {
            <section class="card shadow-sm mb-4">
                <div class="card-body">
                    <h2 class="h5 mb-3">Share access</h2>

                    @if (string.IsNullOrWhiteSpace(Model.ActiveShareUrl))
                    {
                        <p class="text-muted">This note does not currently have an active share link.</p>
                    }
                    else
                    {
                        <label class="form-label">Active link</label>
                        <input class="form-control mb-3" value="@Model.ActiveShareUrl" readonly />
                    }

                    <div class="d-flex flex-wrap gap-2">
                        <form asp-action="GenerateShareLink" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="noteId" value="@Model.Id" />
                            <button type="submit" class="btn btn-primary">Generate / Regenerate</button>
                        </form>

                        <form asp-action="RevokeShareLinks" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="noteId" value="@Model.Id" />
                            <button type="submit" class="btn btn-outline-danger">Revoke</button>
                        </form>
                    </div>
                </div>
            </section>
        }

        <section class="card shadow-sm">
            <div class="card-body">
                <h2 class="h5 mb-3">At a glance</h2>
                <dl class="row mb-0">
                    <dt class="col-6">Visibility</dt>
                    <dd class="col-6 text-end">@(Model.IsPublic ? "Public" : "Private")</dd>

                    <dt class="col-6">Attachments</dt>
                    <dd class="col-6 text-end">@Model.Attachments.Count</dd>

                    <dt class="col-6">Average rating</dt>
                    <dd class="col-6 text-end">@Model.AverageRating.ToString("0.0")</dd>

                    <dt class="col-6">Ratings</dt>
                    <dd class="col-6 text-end">@Model.RatingCount</dd>
                </dl>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
