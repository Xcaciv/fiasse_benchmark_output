<section class="mb-4">
  <h1 class="h2 mb-2">Admin Dashboard</h1>
  <p class="text-muted mb-0">Manage users, review activity, and reassign note ownership.</p>
</section>

<section class="row g-3 mb-4">
  <div class="col-md-6 col-xl-3">
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="text-muted small">Total users</div>
        <div class="display-6"><%= totals.user_count %></div>
      </div>
    </div>
  </div>
  <div class="col-md-6 col-xl-3">
    <div class="card shadow-sm">
      <div class="card-body">
        <div class="text-muted small">Total notes</div>
        <div class="display-6"><%= totals.note_count %></div>
      </div>
    </div>
  </div>
</section>

<section class="card shadow-sm mb-4">
  <div class="card-body p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="h4 mb-0">Users</h2>
      <form class="d-flex" method="get" action="/admin">
        <input class="form-control form-control-sm me-2" type="search" name="q" value="<%= query %>" placeholder="Search by username or email" />
        <button class="btn btn-outline-secondary btn-sm" type="submit">Search</button>
      </form>
    </div>

    <div class="table-responsive">
      <table class="table table-striped align-middle">
        <thead>
          <tr>
            <th>Username</th>
            <th>Email</th>
            <th>Role</th>
            <th>Registered</th>
            <th>Notes</th>
          </tr>
        </thead>
        <tbody>
          <% users.forEach(function(user) { %>
            <tr>
              <td><%= user.username %></td>
              <td><%= user.email %></td>
              <td><span class="badge text-bg-<%= user.role === 'Admin' ? 'warning' : 'secondary' %>"><%= user.role %></span></td>
              <td><%= helpers.formatDate(user.created_at) %></td>
              <td><%= user.note_count %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="card shadow-sm mb-4">
  <div class="card-body p-4">
    <h2 class="h4 mb-3">Reassign note ownership</h2>
    <div class="table-responsive">
      <table class="table table-striped">
        <thead>
          <tr>
            <th>Note</th>
            <th>Current owner</th>
            <th>Visibility</th>
            <th>Created</th>
            <th>New owner</th>
          </tr>
        </thead>
        <tbody>
          <% notes.forEach(function(note) { %>
            <tr>
              <td><a href="/notes/<%= note.id %>"><%= note.title %></a></td>
              <td><%= note.owner_username %></td>
              <td><%= note.is_public ? 'Public' : 'Private' %></td>
              <td><%= helpers.formatDate(note.created_at) %></td>
              <td>
                <form method="post" action="/admin/notes/<%= note.id %>/reassign" class="d-flex gap-2">
                  <input type="hidden" name="csrfToken" value="<%= csrfToken %>" />
                  <select class="form-select form-select-sm" name="newOwnerId">
                    <% assignableUsers.forEach(function(user) { %>
                      <option value="<%= user.id %>" <%= user.id === note.owner_id ? 'selected' : '' %>>
                        <%= user.username %> (<%= user.email %>)
                      </option>
                    <% }) %>
                  </select>
                  <button class="btn btn-primary btn-sm" type="submit">Save</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</section>

<section class="card shadow-sm">
  <div class="card-body p-4">
    <h2 class="h4 mb-3">Recent activity</h2>
    <% if (recentLogs.length === 0) { %>
      <p class="text-muted mb-0">No activity has been logged yet.</p>
    <% } else { %>
      <div class="table-responsive">
        <table class="table table-striped">
          <thead>
            <tr>
              <th>When</th>
              <th>User</th>
              <th>Action</th>
              <th>Details</th>
            </tr>
          </thead>
          <tbody>
            <% recentLogs.forEach(function(log) { %>
              <tr>
                <td><%= helpers.formatDate(log.created_at) %></td>
                <td><%= log.username || 'System' %></td>
                <td><code><%= log.action_type %></code></td>
                <td><%= log.details %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</section>
