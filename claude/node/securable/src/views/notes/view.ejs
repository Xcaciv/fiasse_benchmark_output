<%- include('../partials/head', {title}) %>
<%- include('../partials/nav') %>
<div class="container mt-4">
  <%- include('../partials/flash') %>
  <div class="row">
    <div class="col-lg-8">
      <!-- Note header -->
      <div class="d-flex flex-wrap justify-content-between align-items-start mb-2">
        <div>
          <span class="badge <%= note.is_public ? 'bg-success' : 'bg-secondary' %> me-2">
            <%= note.is_public ? 'Public' : 'Private' %>
          </span>
          <% if (note.avg_rating > 0) { %>
            <span class="text-warning">★ <%= note.avg_rating %></span>
            <span class="text-muted small">(<%= note.rating_count %> rating<%= note.rating_count === 1 ? '' : 's' %>)</span>
          <% } %>
        </div>
        <% if (isOwner) { %>
          <div class="d-flex gap-2">
            <a href="/notes/<%= note.id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
            <a href="/notes/<%= note.id %>/share" class="btn btn-sm btn-outline-info">Share</a>
            <form method="POST" action="/notes/<%= note.id %>/delete"
                  onsubmit="return confirm('Delete this note permanently?')">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="btn btn-sm btn-outline-danger">Delete</button>
            </form>
          </div>
        <% } %>
      </div>
      <h1 class="h2 mb-1"><%= note.title %></h1>
      <p class="text-muted small mb-4">
        By <strong><%= note.username %></strong> &middot;
        Created <%= new Date(note.created_at).toLocaleDateString() %>
        <% if (note.updated_at !== note.created_at) { %>
          &middot; Updated <%= new Date(note.updated_at).toLocaleDateString() %>
        <% } %>
      </p>

      <!-- Content -->
      <div class="note-content mb-4">
        <%- note.content.replace(/\n/g, '<br>') %>
      </div>

      <!-- Attachments -->
      <% if (attachments.length) { %>
        <div class="mb-4">
          <h5>Attachments</h5>
          <ul class="list-group">
            <% attachments.forEach(att => { %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>📎 <%= att.original_name %>
                  <span class="text-muted small">(<%= (att.size / 1024).toFixed(1) %> KB)</span>
                </span>
                <a href="/notes/<%= note.id %>/attachments/<%= att.id %>" class="btn btn-sm btn-outline-primary">
                  Download
                </a>
              </li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <!-- Rating form (for non-owners who are logged in) -->
      <% if (currentUser && !isOwner) { %>
        <div class="card mb-4">
          <div class="card-body">
            <h5 class="card-title"><%= myRating ? 'Update Your Rating' : 'Rate This Note' %></h5>
            <form method="POST" action="/notes/<%= note.id %>/rate">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <div class="mb-2">
                <label class="form-label">Stars</label>
                <select name="stars" class="form-select form-select-sm w-auto" required>
                  <option value="">Select…</option>
                  <% [1,2,3,4,5].forEach(s => { %>
                    <option value="<%= s %>" <%= myRating && myRating.stars === s ? 'selected' : '' %>>
                      <%= '★'.repeat(s) + '☆'.repeat(5-s) %> (<%= s %>)
                    </option>
                  <% }) %>
                </select>
              </div>
              <div class="mb-2">
                <label class="form-label">Comment (optional)</label>
                <textarea name="comment" class="form-control form-control-sm" rows="2" maxlength="1000"><%= myRating ? myRating.comment || '' : '' %></textarea>
              </div>
              <button type="submit" class="btn btn-sm btn-primary"><%= myRating ? 'Update Rating' : 'Submit Rating' %></button>
            </form>
          </div>
        </div>
      <% } %>

      <!-- Ratings list -->
      <% if (ratings.length) { %>
        <h5>Ratings (<%= ratings.length %>)</h5>
        <div class="list-group mb-4">
          <% ratings.forEach(r => { %>
            <div class="list-group-item">
              <div class="d-flex justify-content-between">
                <strong><%= r.username %></strong>
                <span class="text-warning"><%= '★'.repeat(r.stars) %><%= '☆'.repeat(5-r.stars) %></span>
              </div>
              <% if (r.comment) { %>
                <p class="mb-0 mt-1 small"><%= r.comment %></p>
              <% } %>
              <small class="text-muted"><%= new Date(r.updated_at).toLocaleDateString() %></small>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <!-- Sidebar: share link info for owner -->
    <% if (isOwner && shareLink) { %>
      <div class="col-lg-4">
        <div class="card border-info">
          <div class="card-body">
            <h6 class="card-title text-info">Share Link Active</h6>
            <p class="small text-muted">Anyone with this link can view the note.</p>
            <a href="/notes/<%= note.id %>/share" class="btn btn-sm btn-outline-info">Manage Share Link</a>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</div>
<%- include('../partials/footer') %>
