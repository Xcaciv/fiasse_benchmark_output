<div class="mb-4">
  <h2>Search Notes</h2>
  <form action="/notes/search" method="GET" class="d-flex gap-2">
    <input type="text" name="q" class="form-control" placeholder="Search title or content..." value="<%= q %>">
    <button type="submit" class="btn btn-primary">Search</button>
  </form>
</div>

<% if (q && notes.length === 0) { %>
  <div class="alert alert-info">No notes found for "<%= q %>".</div>
<% } else if (notes.length > 0) { %>
  <p class="text-muted"><%= notes.length %> result(s) for "<%= q %>"</p>
  <div class="list-group">
    <% notes.forEach(note => { %>
      <a href="/notes/<%= note.id %>" class="list-group-item list-group-item-action">
        <div class="d-flex justify-content-between">
          <h6 class="mb-1"><%= note.title %></h6>
          <small class="text-muted"><%= note.User ? note.User.username : 'Unknown' %> &middot; <%= new Date(note.createdAt).toLocaleDateString() %></small>
        </div>
        <p class="mb-1 text-muted small"><%= note.content.substring(0, 200) %><%= note.content.length > 200 ? '…' : '' %></p>
        <span class="badge bg-<%= note.visibility === 'public' ? 'success' : 'secondary' %>"><%= note.visibility %></span>
      </a>
    <% }) %>
  </div>
<% } %>
