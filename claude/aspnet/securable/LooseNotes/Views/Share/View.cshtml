@model Note
@{
    ViewData["Title"] = Model.Title + " (Shared)";
    Layout = "_Layout";
}
<div class="alert alert-info small">
    You are viewing a shared note. <a asp-controller="Account" asp-action="Login">Sign in</a> to create your own.
</div>

<h2>@Model.Title</h2>
<div class="text-muted small mb-3">
    By <strong>@Model.Owner?.UserName</strong> &bull;
    @Model.CreatedAt.ToString("MMM d, yyyy")
</div>

<div class="card mb-4">
    <div class="card-body">
        <div style="white-space: pre-wrap">@Model.Content</div>
    </div>
</div>

@if (Model.Attachments.Any())
{
    <h5>Attachments</h5>
    <ul class="list-group">
        @foreach (var a in Model.Attachments)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>@a.OriginalFileName</span>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Attachments" asp-action="Download" asp-route-id="@a.Id"
                       class="btn btn-sm btn-outline-secondary">Download</a>
                }
                else
                {
                    <span class="text-muted small">Sign in to download</span>
                }
            </li>
        }
    </ul>
}
