@model ReassignNoteViewModel
@{
    ViewData["Title"] = "Reassign Note";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <h2>Reassign Note Ownership</h2>
        <div class="card mb-3">
            <div class="card-body">
                <strong>Note:</strong> @Model.NoteTitle<br />
                <strong>Current Owner:</strong> @Model.CurrentOwnerDisplayName
            </div>
        </div>
        <form asp-action="ReassignNote" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="NoteId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <div class="mb-3">
                <label asp-for="NewOwnerEmail" class="form-label"></label>
                <select asp-for="NewOwnerEmail" class="form-select">
                    <option value="">-- Select new owner --</option>
                    @foreach (var email in Model.AvailableUserEmails)
                    {
                        <option value="@email">@email</option>
                    }
                </select>
                <span asp-validation-for="NewOwnerEmail" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">Reassign</button>
                <a asp-action="Dashboard" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
