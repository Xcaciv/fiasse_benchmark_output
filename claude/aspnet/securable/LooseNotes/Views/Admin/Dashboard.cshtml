@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<h2>Admin Dashboard</h2>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-center bg-primary text-white">
            <div class="card-body">
                <h3>@Model.TotalUsers</h3>
                <p class="mb-0">Total Users</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center bg-success text-white">
            <div class="card-body">
                <h3>@Model.TotalNotes</h3>
                <p class="mb-0">Total Notes</p>
            </div>
        </div>
    </div>
</div>

<div class="d-flex gap-2 mb-4">
    <a asp-action="Users" class="btn btn-outline-primary">Manage Users</a>
</div>

<h5>Recent Activity</h5>
@if (!Model.RecentAuditEntries.Any())
{
    <p class="text-muted">No audit entries yet.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-sm table-hover">
            <thead>
                <tr>
                    <th>Time</th>
                    <th>Actor</th>
                    <th>Action</th>
                    <th>Resource</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var entry in Model.RecentAuditEntries)
                {
                    <tr>
                        <td><small class="text-muted">@entry.OccurredAt.ToString("yyyy-MM-dd HH:mm")</small></td>
                        <td>@(entry.ActorUserName ?? "—")</td>
                        <td><code>@entry.Action</code></td>
                        <td>@(entry.ResourceType)/@(entry.ResourceId)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
