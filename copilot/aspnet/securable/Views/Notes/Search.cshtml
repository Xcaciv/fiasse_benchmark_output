@model NoteSearchResultViewModel
@{
    ViewData["Title"] = "Search Notes";
}
<h2 class="mb-4">Search Notes</h2>

<form asp-action="Search" method="get" class="mb-4">
    <div class="input-group">
        <input type="search" name="q" value="@Model.Query" class="form-control"
               placeholder="Search by title or content…" maxlength="200" />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.Query))
{
    <p class="text-muted">Found @Model.TotalCount result(s) for "@Model.Query"</p>

    @if (Model.Results.Any())
    {
        <div class="row g-3">
            @foreach (var note in Model.Results)
            {
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">
                                <a asp-action="Details" asp-route-id="@note.Id" class="text-decoration-none">
                                    @note.Title
                                </a>
                            </h5>
                            <p class="card-text text-muted small">
                                @(note.Content.Length > 120 ? note.Content[..120] + "…" : note.Content)
                            </p>
                            <small class="text-muted">By @(note.User?.UserName ?? "Unknown")</small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p>No notes found matching your search.</p>
    }
}
