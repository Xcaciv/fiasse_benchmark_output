@model NoteDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2>@Model.Title</h2>
        <div class="text-muted small">
            By <strong>@Model.OwnerUserName</strong> &bull;
            @Model.CreatedAt.ToString("MMM d, yyyy")
            @if (Model.UpdatedAt > Model.CreatedAt)
            {
                <span>&bull; Updated @Model.UpdatedAt.ToString("MMM d, yyyy")</span>
            }
            &bull;
            <span class="badge @(Model.IsPublic ? "bg-success" : "bg-secondary")">
                @(Model.IsPublic ? "Public" : "Private")
            </span>
        </div>
    </div>
    @if (Model.IsOwner || Model.IsAdmin)
    {
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger">Delete</a>
            @if (Model.IsAdmin && !Model.IsOwner)
            {
                <a asp-controller="Admin" asp-action="ReassignNote" asp-route-noteId="@Model.Id"
                   class="btn btn-sm btn-outline-warning">Reassign</a>
            }
        </div>
    }
</div>

<div class="card mb-4">
    <div class="card-body">
        <div style="white-space: pre-wrap">@Model.Content</div>
    </div>
</div>

@* Attachments *@
@if (Model.Attachments.Any())
{
    <h5>Attachments</h5>
    <ul class="list-group mb-4">
        @foreach (var a in Model.Attachments)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>@a.OriginalFileName <small class="text-muted">(@((a.FileSizeBytes / 1024.0).ToString("F1")) KB)</small></span>
                <div class="d-flex gap-2">
                    <a asp-controller="Attachments" asp-action="Download" asp-route-id="@a.Id"
                       class="btn btn-sm btn-outline-secondary">Download</a>
                    @if (Model.IsOwner || Model.IsAdmin)
                    {
                        <form asp-controller="Attachments" asp-action="Delete" method="post">
                            <input type="hidden" name="id" value="@a.Id" />
                            <input type="hidden" name="noteId" value="@Model.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Delete this attachment?')">Remove</button>
                        </form>
                    }
                </div>
            </li>
        }
    </ul>
}

@* Share Links *@
@if (Model.IsOwner)
{
    <h5>Share Links</h5>
    @if (Model.ActiveShareLinks.Any())
    {
        <ul class="list-group mb-3">
            @foreach (var link in Model.ActiveShareLinks)
            {
                var shareUrl = Url.Action("View", "Share", new { token = link.Token }, Request.Scheme)!;
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <code class="small">@shareUrl</code>
                    <form asp-controller="Notes" asp-action="RevokeShareLink" method="post">
                        <input type="hidden" name="shareLinkId" value="@link.Id" />
                        <input type="hidden" name="noteId" value="@Model.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Revoke</button>
                    </form>
                </li>
            }
        </ul>
    }
    <form asp-controller="Notes" asp-action="CreateShareLink" method="post" class="mb-4">
        <input type="hidden" name="noteId" value="@Model.Id" />
        <button type="submit" class="btn btn-sm btn-outline-primary">Generate Share Link</button>
    </form>
}

@* Ratings *@
<h5>Ratings
    @if (Model.Ratings.Any())
    {
        <span class="text-muted fs-6">
            &#9733; @Model.AverageRating.ToString("F1") (@Model.Ratings.Count @(Model.Ratings.Count == 1 ? "rating" : "ratings"))
        </span>
    }
</h5>

@if (User.Identity?.IsAuthenticated == true && !Model.IsOwner)
{
    <div class="card mb-4">
        <div class="card-header">@(Model.CurrentUserRatingId.HasValue ? "Update Your Rating" : "Rate This Note")</div>
        <div class="card-body">
            <form asp-controller="Notes" asp-action="Rate" method="post">
                <input type="hidden" name="NoteId" value="@Model.Id" />
                <div class="mb-2">
                    <label class="form-label">Stars (1–5)</label>
                    <select name="Value" class="form-select" style="width:auto">
                        @for (int i = 1; i <= 5; i++)
                        {
                            if (Model.CurrentUserRatingValue == i)
                            {
                                <option value="@i" selected>@i &#9733;</option>
                            }
                            else
                            {
                                <option value="@i">@i &#9733;</option>
                            }
                        }
                    </select>
                </div>
                <div class="mb-2">
                    <label class="form-label">Comment (optional)</label>
                    <textarea name="Comment" class="form-control" rows="2" maxlength="1000"></textarea>
                </div>
                <button type="submit" class="btn btn-sm btn-primary">Submit Rating</button>
            </form>
        </div>
    </div>
}

@if (Model.Ratings.Any())
{
    <div class="list-group">
        @foreach (var r in Model.Ratings)
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between">
                    <strong>@r.Rater?.UserName</strong>
                    <span>@string.Concat(Enumerable.Repeat("&#9733;", r.Value))</span>
                </div>
                @if (!string.IsNullOrEmpty(r.Comment))
                {
                    <p class="mb-1 mt-1 small">@r.Comment</p>
                }
                <small class="text-muted">@r.CreatedAt.ToString("MMM d, yyyy")</small>
            </div>
        }
    </div>
}
else
{
    <p class="text-muted">No ratings yet.</p>
}
