@model IEnumerable<LooseNotes.Models.Note>
@{
    ViewData["Title"] = "Top Rated Notes";
}

<h1>@ViewData["Title"]</h1>
<p class="lead">The highest-rated public notes (minimum 3 ratings required)</p>

@if (Model.Any())
{
    <div class="row">
        @foreach (var note in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card">
                    <div class="card-body">
                        <h5 class="card-title">
                            <a asp-action="Details" asp-route-id="@note.Id">@note.Title</a>
                        </h5>
                        <p class="card-text text-muted">
                            by @note.User?.UserName | Created: @note.CreatedAt.ToString("MMM dd, yyyy")
                        </p>
                        <p class="card-text">
                            @(note.Content.Length > 150 ? note.Content.Substring(0, 150) + "..." : note.Content)
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="badge bg-warning text-dark">
                                    @note.Ratings.Average(r => r.Value).ToString("F1") / 5
                                </span>
                                <small class="text-muted">(@note.Ratings.Count ratings)</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="alert alert-info">
        No notes meet the minimum rating threshold yet. Be the first to rate some notes!
    </div>
}

<div class="mt-3">
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Back to Home</a>
</div>
