<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Loose Notes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    body { min-height: 100vh; display: flex; flex-direction: column; }
    main { flex: 1; }
  </style>
</head>
<body>
  <%- include partials/navbar %>
  <%- include partials/flash %>
  <main class="container py-4">
    <div class="py-5">
      <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Loose Notes</h1>
        <p class="lead text-muted">Your personal note-taking platform</p>
      </div>

      <div class="row g-4 justify-content-center">
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center py-4">
              <i class="bi bi-journal-plus display-4 text-primary mb-3"></i>
              <h3>Create Notes</h3>
              <p class="text-muted">Organize your thoughts with rich text notes. Keep them private or share with others.</p>
            </div>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center py-4">
              <i class="bi bi-share display-4 text-success mb-3"></i>
              <h3>Share & Collaborate</h3>
              <p class="text-muted">Generate secure share links to let others view your notes without logging in.</p>
            </div>
          </div>
        </div>
        <div class="col-md-6 col-lg-4">
          <div class="card h-100 border-0 shadow-sm">
            <div class="card-body text-center py-4">
              <i class="bi bi-star display-4 text-warning mb-3"></i>
              <h3>Rate & Discover</h3>
              <p class="text-muted">Rate notes from other users and discover top-rated content in the community.</p>
            </div>
          </div>
        </div>
      </div>

      <div class="text-center mt-5">
        <% if (!user) { %>
          <a href="/auth/register" class="btn btn-primary btn-lg px-5">Get Started</a>
          <a href="/auth/login" class="btn btn-outline-secondary btn-lg px-5 ms-2">Login</a>
        <% } else { %>
          <a href="/notes" class="btn btn-primary btn-lg px-5">Go to My Notes</a>
        <% } %>
      </div>
    </div>
  </main>
  <%- include partials/footer %>
</body>
</html>
