@model LooseNotes.Models.Note
@{
    ViewData["Title"] = "Delete Note";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">Confirm Delete</div>
            <div class="card-body">
                <h5>Are you sure you want to delete this note?</h5>
                <p><strong>@Model.Title</strong></p>
                <p class="text-muted small">Created @Model.CreatedAt.ToString("MMM d, yyyy") · This action cannot be undone.</p>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
