<%- include('../partials/header') %>

<div class="row">
  <div class="col-lg-8">
    <!-- Note Header -->
    <div class="d-flex justify-content-between align-items-start mb-3">
      <div>
        <h1 class="mb-1"><%= note.title %></h1>
        <div class="text-muted small">
          <i class="bi bi-person me-1"></i><%= note.author ? note.author.username : 'Unknown' %>
          &bull;
          <i class="bi bi-calendar me-1"></i><%= new Date(note.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
          &bull;
          <% if (note.isPublic) { %>
          <span class="badge bg-success"><i class="bi bi-globe me-1"></i>Public</span>
          <% } else { %>
          <span class="badge bg-secondary"><i class="bi bi-lock me-1"></i>Private</span>
          <% } %>
        </div>
      </div>
      <div class="d-flex gap-2 flex-shrink-0 ms-3">
        <% if (isOwner || (user && user.isAdmin)) { %>
        <a href="/notes/<%= note.id %>/edit" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a href="/notes/<%= note.id %>/delete" class="btn btn-outline-danger btn-sm">
          <i class="bi bi-trash me-1"></i>Delete
        </a>
        <% } %>
        <a href="/notes" class="btn btn-outline-secondary btn-sm">
          <i class="bi bi-arrow-left me-1"></i>Back
        </a>
      </div>
    </div>

    <!-- Note Content -->
    <div class="card shadow-sm mb-4">
      <div class="card-body p-4">
        <div class="note-content" style="white-space: pre-wrap; line-height: 1.7;"><%= note.content %></div>
      </div>
    </div>

    <!-- Attachments -->
    <% if (note.Attachments && note.Attachments.length > 0) { %>
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-transparent">
        <h5 class="mb-0"><i class="bi bi-paperclip me-2"></i>Attachments (<%= note.Attachments.length %>)</h5>
      </div>
      <div class="list-group list-group-flush">
        <% note.Attachments.forEach(function(att) { %>
        <div class="list-group-item d-flex justify-content-between align-items-center">
          <div>
            <i class="bi bi-file-earmark me-2 text-muted"></i>
            <a href="/uploads/<%= att.storedName %>" download="<%= att.originalName %>" class="text-decoration-none">
              <%= att.originalName %>
            </a>
            <small class="text-muted ms-2">(<%= (att.size / 1024).toFixed(1) %> KB)</small>
          </div>
          <a href="/uploads/<%= att.storedName %>" download="<%= att.originalName %>" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-download me-1"></i>Download
          </a>
        </div>
        <% }); %>
      </div>
    </div>
    <% } %>

    <!-- Ratings Section -->
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-star me-2"></i>Ratings</h5>
        <% if (avgRating) { %>
        <div class="text-warning fw-bold">
          <i class="bi bi-star-fill me-1"></i><%= avgRating %> / 5.0
          <span class="text-muted fw-normal small">(<%= ratings.length %> rating<%= ratings.length !== 1 ? 's' : '' %>)</span>
        </div>
        <% } else { %>
        <span class="text-muted small">No ratings yet</span>
        <% } %>
      </div>
      <div class="card-body">
        <!-- Rate this note (if not owner) -->
        <% if (user && !isOwner) { %>
        <div class="mb-4 p-3 bg-light rounded">
          <h6 class="mb-3">
            <% if (userRating) { %><i class="bi bi-pencil me-2"></i>Update Your Rating<% } else { %><i class="bi bi-star me-2"></i>Rate This Note<% } %>
          </h6>
          <form action="/notes/<%= note.id %>/rate" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <div class="mb-2">
              <div class="d-flex gap-2 align-items-center mb-2 flex-wrap">
                <% for (var i = 1; i <= 5; i++) { %>
                <div class="form-check form-check-inline">
                  <input class="form-check-input" type="radio" name="stars" id="star<%= i %>" value="<%= i %>"
                    <%= userRating && userRating.stars === i ? 'checked' : '' %> required>
                  <label class="form-check-label" for="star<%= i %>">
                    <i class="bi bi-star-fill text-warning"></i> <%= i %>
                  </label>
                </div>
                <% } %>
              </div>
            </div>
            <div class="mb-2">
              <textarea name="comment" class="form-control form-control-sm" rows="2" placeholder="Optional comment..."><%= userRating ? (userRating.comment || '') : '' %></textarea>
            </div>
            <button type="submit" class="btn btn-sm btn-warning">
              <i class="bi bi-star-fill me-1"></i><%= userRating ? 'Update Rating' : 'Submit Rating' %>
            </button>
          </form>
        </div>
        <% } else if (user && isOwner) { %>
        <p class="text-muted small mb-3"><i class="bi bi-info-circle me-1"></i>You cannot rate your own note.</p>
        <% } else { %>
        <p class="text-muted small mb-3">
          <a href="/auth/login">Login</a> to rate this note.
        </p>
        <% } %>

        <!-- Existing Ratings -->
        <% if (ratings && ratings.length > 0) { %>
        <div class="ratings-list">
          <% ratings.forEach(function(rating) { %>
          <div class="d-flex align-items-start mb-3 pb-3 border-bottom">
            <div class="me-3">
              <i class="bi bi-person-circle text-muted fs-4"></i>
            </div>
            <div class="flex-grow-1">
              <div class="d-flex justify-content-between align-items-center">
                <strong><%= rating.rater ? rating.rater.username : 'Unknown' %></strong>
                <div class="text-warning">
                  <% for (var j = 1; j <= 5; j++) { %>
                  <i class="bi bi-star<%= j <= rating.stars ? '-fill' : '' %>"></i>
                  <% } %>
                  <span class="text-muted small ms-1">(<%= rating.stars %>/5)</span>
                </div>
              </div>
              <% if (rating.comment) { %>
              <p class="mb-0 mt-1 text-muted small"><%= rating.comment %></p>
              <% } %>
              <small class="text-muted"><%= new Date(rating.createdAt).toLocaleDateString() %></small>
            </div>
          </div>
          <% }); %>
        </div>
        <% } else { %>
        <p class="text-muted text-center py-2">No ratings yet. Be the first to rate!</p>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="col-lg-4">
    <!-- Share Link Management (owner only) -->
    <% if (isOwner) { %>
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-transparent">
        <h5 class="mb-0"><i class="bi bi-share me-2"></i>Share Link</h5>
      </div>
      <div class="card-body">
        <% if (note.ShareLink && note.ShareLink.isActive) { %>
        <div class="mb-3">
          <label class="form-label small fw-semibold text-muted">Share URL</label>
          <div class="input-group input-group-sm">
            <input type="text" class="form-control" id="shareLinkFull"
              value="<%= (process.env.BASE_URL || 'http://localhost:' + (process.env.PORT || 3000)) + '/share/' + note.ShareLink.token %>" readonly>
            <button class="btn btn-outline-secondary" type="button" onclick="copyShareLink()">
              <i class="bi bi-clipboard"></i>
            </button>
          </div>
        </div>
        <form action="/notes/<%= note.id %>/revoke-share" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn btn-sm btn-danger w-100">
            <i class="bi bi-x-circle me-2"></i>Revoke Share Link
          </button>
        </form>
        <% } else { %>
        <p class="text-muted small mb-3">No active share link. Create one to share this note with others.</p>
        <form action="/notes/<%= note.id %>/share" method="POST">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="btn btn-sm btn-success w-100">
            <i class="bi bi-link-45deg me-2"></i>Create Share Link
          </button>
        </form>
        <% } %>
      </div>
    </div>
    <% } %>

    <!-- Note Info Card -->
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-transparent">
        <h5 class="mb-0"><i class="bi bi-info-circle me-2"></i>Note Info</h5>
      </div>
      <ul class="list-group list-group-flush">
        <li class="list-group-item d-flex justify-content-between">
          <span class="text-muted">Author</span>
          <strong><%= note.author ? note.author.username : 'Unknown' %></strong>
        </li>
        <li class="list-group-item d-flex justify-content-between">
          <span class="text-muted">Visibility</span>
          <% if (note.isPublic) { %>
          <span class="badge bg-success"><i class="bi bi-globe me-1"></i>Public</span>
          <% } else { %>
          <span class="badge bg-secondary"><i class="bi bi-lock me-1"></i>Private</span>
          <% } %>
        </li>
        <li class="list-group-item d-flex justify-content-between">
          <span class="text-muted">Created</span>
          <span><%= new Date(note.createdAt).toLocaleDateString() %></span>
        </li>
        <li class="list-group-item d-flex justify-content-between">
          <span class="text-muted">Updated</span>
          <span><%= new Date(note.updatedAt).toLocaleDateString() %></span>
        </li>
        <li class="list-group-item d-flex justify-content-between">
          <span class="text-muted">Attachments</span>
          <span><%= (note.Attachments || []).length %></span>
        </li>
        <li class="list-group-item d-flex justify-content-between">
          <span class="text-muted">Avg Rating</span>
          <span>
            <% if (avgRating) { %>
            <i class="bi bi-star-fill text-warning me-1"></i><%= avgRating %>/5
            <% } else { %>
            <span class="text-muted">None</span>
            <% } %>
          </span>
        </li>
      </ul>
    </div>
  </div>
</div>

<script>
function copyShareLink() {
  var el = document.getElementById('shareLinkFull');
  if (!el) return;
  var url = el.value;
  if (navigator.clipboard && navigator.clipboard.writeText) {
    navigator.clipboard.writeText(url).then(function() {
      alert('Share link copied to clipboard!');
    }).catch(function() {
      el.select();
      document.execCommand('copy');
      alert('Share link copied!');
    });
  } else {
    el.select();
    document.execCommand('copy');
    alert('Share link copied!');
  }
}
</script>

<%- include('../partials/footer') %>
