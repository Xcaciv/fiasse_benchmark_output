@model CreateNoteViewModel
@{
    ViewData["Title"] = "New Note";
}

<div class="row">
    <div class="col-lg-8">
        <h2><i class="bi bi-plus-circle"></i> New Note</h2>
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-semibold"></label>
                <input asp-for="Title" class="form-control form-control-lg" placeholder="Note title…" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Content" class="form-label fw-semibold"></label>
                <textarea asp-for="Content" class="form-control" rows="12" placeholder="Write your note here…"></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Files" class="form-label fw-semibold"></label>
                <input asp-for="Files" class="form-control" type="file" multiple
                       accept=".pdf,.doc,.docx,.txt,.png,.jpg,.jpeg" />
                <div class="form-text">Allowed: PDF, DOC, DOCX, TXT, PNG, JPG, JPEG. Max 10 MB each.</div>
                <span asp-validation-for="Files" class="text-danger small"></span>
            </div>
            <div class="mb-4 form-check">
                <input asp-for="IsPublic" class="form-check-input" type="checkbox" />
                <label asp-for="IsPublic" class="form-check-label">Make this note public</label>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Create Note
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScripts") }
