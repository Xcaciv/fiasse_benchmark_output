<div class="d-flex justify-content-between align-items-center mb-3">
  <h2>My Notes</h2>
  <a href="/notes/create" class="btn btn-success">+ New Note</a>
</div>
<% if (!notes || notes.length === 0) { %>
  <p class="text-muted">No notes yet. <a href="/notes/create">Create your first note.</a></p>
<% } else { %>
  <table class="table table-striped">
    <thead><tr><th>Title</th><th>Visibility</th><th>Created</th><th>Actions</th></tr></thead>
    <tbody>
      <% notes.forEach(note => { %>
        <tr>
          <td><a href="/notes/<%= note.id %>"><%= note.title %></a></td>
          <td>
            <span class="badge <%= note.isPublic ? 'bg-success' : 'bg-secondary' %>">
              <%= note.isPublic ? 'Public' : 'Private' %>
            </span>
          </td>
          <td><%= new Date(note.createdAt).toLocaleDateString() %></td>
          <td>
            <a href="/notes/<%= note.id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
            <form method="POST" action="/notes/<%= note.id %>/delete" class="d-inline" onsubmit="return confirm('Delete this note?')">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>
