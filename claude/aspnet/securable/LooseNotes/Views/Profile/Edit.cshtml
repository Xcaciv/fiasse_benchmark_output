@model EditProfileViewModel
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2>Edit Profile</h2>

        <form asp-action="Edit" method="post">
            <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="UserName" class="form-label fw-bold"></label>
                <input asp-for="UserName" class="form-control" autocomplete="username" />
                <span asp-validation-for="UserName" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-bold"></label>
                <input asp-for="Email" class="form-control" autocomplete="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <hr />
            <h6 class="text-muted">Change Password (optional)</h6>

            <div class="mb-3">
                <label asp-for="NewPassword" class="form-label"></label>
                <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="NewPassword" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ConfirmNewPassword" class="form-label"></label>
                <input asp-for="ConfirmNewPassword" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
            </div>

            <hr />
            <div class="mb-3">
                <label asp-for="CurrentPassword" class="form-label fw-bold"></label>
                <input asp-for="CurrentPassword" class="form-control" autocomplete="current-password" />
                <div class="form-text">Required to save any changes.</div>
                <span asp-validation-for="CurrentPassword" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Save Changes</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
