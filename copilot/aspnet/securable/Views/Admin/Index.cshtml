@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Admin Dashboard</h2>
    <a asp-action="Users" class="btn btn-outline-primary">Manage Users</a>
</div>

<div class="row g-3 mb-5">
    <div class="col-md-3">
        <div class="card text-bg-primary">
            <div class="card-body text-center">
                <h3 class="card-title">@Model.TotalUsers</h3>
                <p class="card-text">Users</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-bg-success">
            <div class="card-body text-center">
                <h3 class="card-title">@Model.TotalNotes</h3>
                <p class="card-text">Notes</p>
            </div>
        </div>
    </div>
</div>

<h4>Recent Activity</h4>
<div class="table-responsive">
    <table class="table table-sm table-hover">
        <thead>
            <tr>
                <th>Timestamp</th>
                <th>Action</th>
                <th>User ID</th>
                <th>Detail</th>
                <th>IP</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model.RecentActivity)
            {
                <tr>
                    <td><small>@log.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")</small></td>
                    <td><code>@log.Action</code></td>
                    <td><small class="text-muted">@(log.UserId ?? "—")</small></td>
                    <td><small>@(log.Detail ?? "—")</small></td>
                    <td><small class="text-muted">@(log.IpAddress ?? "—")</small></td>
                </tr>
            }
        </tbody>
    </table>
</div>
