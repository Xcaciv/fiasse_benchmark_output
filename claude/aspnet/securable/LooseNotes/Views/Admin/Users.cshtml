@model UserListViewModel
@{
    ViewData["Title"] = "User Management";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Users</h2>
    <a asp-action="Dashboard" class="btn btn-sm btn-outline-secondary">&larr; Dashboard</a>
</div>

<form asp-action="Users" method="get" class="mb-3">
    <div class="input-group">
        <input asp-for="SearchQuery" class="form-control" placeholder="Search by username or email..." maxlength="200" />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@if (!Model.Users.Any())
{
    <p class="text-muted">No users found.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Display Name</th>
                <th>Email</th>
                <th>Roles</th>
                <th>Notes</th>
                <th>Registered</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.DisplayName</td>
                    <td>@user.Email</td>
                    <td>@string.Join(", ", user.Roles)</td>
                    <td>@user.NoteCount</td>
                    <td>@user.CreatedAt.ToString("MMM d, yyyy")</td>
                </tr>
            }
        </tbody>
    </table>
}
