<div class="text-center py-5">
  <h1 class="display-4">Welcome to Loose Notes</h1>
  <p class="lead">A secure multi-user note-taking platform.</p>
  <% if (currentUser) { %>
    <a href="/notes" class="btn btn-primary btn-lg me-2">My Notes</a>
    <a href="/notes/create" class="btn btn-success btn-lg">Create Note</a>
  <% } else { %>
    <a href="/auth/login" class="btn btn-primary btn-lg me-2">Login</a>
    <a href="/auth/register" class="btn btn-outline-primary btn-lg">Register</a>
  <% } %>
</div>
