<div class="d-flex justify-content-between align-items-start mb-3">
  <div>
    <h2><%= note.title %></h2>
    <small class="text-muted">
      By <%= note.User ? note.User.username : 'Unknown' %> &bull;
      <%= new Date(note.createdAt).toLocaleString() %>
      <span class="badge <%= note.isPublic ? 'bg-success' : 'bg-secondary' %> ms-1">
        <%= note.isPublic ? 'Public' : 'Private' %>
      </span>
    </small>
  </div>
  <% if (currentUser && note.userId === currentUser.id) { %>
    <div>
      <a href="/notes/<%= note.id %>/edit" class="btn btn-outline-primary btn-sm">Edit</a>
      <form method="POST" action="/notes/<%= note.id %>/delete" class="d-inline" onsubmit="return confirm('Delete this note?')">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <button class="btn btn-outline-danger btn-sm">Delete</button>
      </form>
    </div>
  <% } %>
</div>

<div class="card mb-4"><div class="card-body"><pre class="mb-0" style="white-space:pre-wrap"><%= note.content %></pre></div></div>

<% if (attachments && attachments.length > 0) { %>
  <h4>Attachments</h4>
  <ul class="list-group mb-4">
    <% attachments.forEach(att => { %>
      <li class="list-group-item"><a href="/attachments/<%= att.id %>/download"><%= att.originalFilename %></a> (<%= (att.fileSizeBytes/1024).toFixed(1) %> KB)</li>
    <% }) %>
  </ul>
<% } %>

<% if (!isSharedView && currentUser && note.userId === currentUser.id) { %>
  <h4>Share Link</h4>
  <% if (shareLinks && shareLinks.length > 0) { %>
    <div class="input-group mb-2">
      <input type="text" class="form-control" value="<%= process.env.BASE_URL || '' %>/share/<%= shareLinks[0].token %>" readonly>
    </div>
    <form method="POST" action="/notes/<%= note.id %>/share/revoke" class="d-inline">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="btn btn-sm btn-outline-danger">Revoke</button>
    </form>
    <form method="POST" action="/notes/<%= note.id %>/share" class="d-inline">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="btn btn-sm btn-outline-secondary">Regenerate</button>
    </form>
  <% } else { %>
    <form method="POST" action="/notes/<%= note.id %>/share">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <button class="btn btn-sm btn-outline-primary">Generate Share Link</button>
    </form>
  <% } %>
  <hr>
<% } %>

<h4>Ratings <% if (avgRating) { %><small class="text-muted">(Avg: <%= avgRating %> &#9733;)</small><% } %></h4>
<% if (currentUser && !isSharedView) { %>
  <form method="POST" action="/notes/<%= note.id %>/ratings" class="mb-3">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="row g-2">
      <div class="col-auto">
        <select name="stars" class="form-select" required>
          <option value="">Stars</option>
          <% [1,2,3,4,5].forEach(n => { %><option value="<%= n %>"><%= n %> &#9733;</option><% }) %>
        </select>
      </div>
      <div class="col">
        <input type="text" name="comment" class="form-control" placeholder="Optional comment" maxlength="500">
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-primary">Rate</button>
      </div>
    </div>
  </form>
<% } %>
<% if (ratings && ratings.length > 0) { %>
  <% ratings.forEach(r => { %>
    <div class="card mb-2"><div class="card-body">
      <strong><%= r.User ? r.User.username : 'User' %></strong>
      <span class="ms-2"><%= '&#9733;'.repeat(r.stars) %></span>
      <% if (r.comment) { %><p class="mb-0 text-muted mt-1"><%= r.comment %></p><% } %>
      <small class="text-muted"><%= new Date(r.createdAt).toLocaleDateString() %></small>
    </div></div>
  <% }) %>
<% } else { %>
  <p class="text-muted">No ratings yet.</p>
<% } %>
