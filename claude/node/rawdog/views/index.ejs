<%- include('partials/header', { title: title }) %>

<div class="row justify-content-center">
  <div class="col-lg-8 text-center py-5">
    <i class="bi bi-journal-text display-1 text-primary mb-4"></i>
    <h1 class="display-4 fw-bold">Loose Notes</h1>
    <p class="lead text-muted mb-4">
      A multi-user note-taking platform. Create, share, and discover notes. Rate and comment on public content.
    </p>
    <div class="d-flex gap-3 justify-content-center">
      <a href="/auth/register" class="btn btn-primary btn-lg px-5">
        <i class="bi bi-person-plus me-2"></i>Get Started
      </a>
      <a href="/notes/top-rated" class="btn btn-outline-secondary btn-lg px-5">
        <i class="bi bi-star me-2"></i>Top Rated Notes
      </a>
    </div>
  </div>
</div>

<div class="row mt-4 g-4">
  <div class="col-md-4">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body text-center p-4">
        <i class="bi bi-pencil-square display-5 text-primary mb-3"></i>
        <h5 class="card-title">Create & Manage</h5>
        <p class="card-text text-muted">Create notes with rich content, attach files, and control visibility with public or private settings.</p>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body text-center p-4">
        <i class="bi bi-share display-5 text-success mb-3"></i>
        <h5 class="card-title">Share Easily</h5>
        <p class="card-text text-muted">Generate unique share links so anyone can view your notes without needing an account.</p>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card h-100 border-0 shadow-sm">
      <div class="card-body text-center p-4">
        <i class="bi bi-star display-5 text-warning mb-3"></i>
        <h5 class="card-title">Rate & Discover</h5>
        <p class="card-text text-muted">Rate public notes, leave comments, and discover top-rated content from the community.</p>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
