<section class="row g-4 mb-4">
  <div class="col-lg-8">
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <h1 class="h2 mb-3">Search notes</h1>
        <p class="text-muted">
          Search by title or content. You will see your own notes and public notes shared by others.
        </p>
        <form class="row g-2" method="get" action="/">
          <div class="col-md-9">
            <input
              class="form-control form-control-lg"
              type="search"
              name="q"
              value="<%= query %>"
              placeholder="Enter keywords"
            />
          </div>
          <div class="col-md-3">
            <button class="btn btn-primary btn-lg w-100" type="submit">Search</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card shadow-sm h-100">
      <div class="card-body p-4">
        <h2 class="h4">What you can do</h2>
        <ul class="mb-0">
          <li>Create private or public notes.</li>
          <li>Upload attachments and share notes by link.</li>
          <li>Rate notes and browse top-rated content.</li>
          <li>Manage your profile and password reset flow.</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<% if (query) { %>
  <section class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="h3 mb-0">Search results for "<%= query %>"</h2>
      <span class="text-muted"><%= searchResults.length %> result(s)</span>
    </div>

    <% if (searchResults.length === 0) { %>
      <div class="alert alert-secondary mb-0">No notes matched your search.</div>
    <% } else { %>
      <div class="row g-3">
        <% searchResults.forEach(function(note) { %>
          <div class="col-md-6">
            <div class="card shadow-sm h-100">
              <div class="card-body">
                <div class="d-flex justify-content-between gap-2 mb-2">
                  <h3 class="h5 mb-0"><a href="/notes/<%= note.id %>" class="text-decoration-none"><%= note.title %></a></h3>
                  <span class="badge text-bg-<%= note.is_public ? 'success' : 'secondary' %>">
                    <%= note.is_public ? 'Public' : 'Private' %>
                  </span>
                </div>
                <p class="text-muted small mb-2">
                  By <%= note.author_username %> · <%= helpers.formatDate(note.created_at) %>
                </p>
                <p class="card-note-preview mb-3"><%= helpers.excerpt(note.content, 200) %></p>
                <div class="small text-muted">
                  Rating: <%= note.average_rating || 'N/A' %> · <%= note.rating_count %> review(s)
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>
<% } %>

<% if (currentUser) { %>
  <section class="mb-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <h2 class="h3 mb-0">Your recent notes</h2>
      <a class="btn btn-primary btn-sm" href="/notes/new">Create a note</a>
    </div>

    <% if (recentOwnNotes.length === 0) { %>
      <div class="alert alert-secondary mb-0">You do not have any notes yet.</div>
    <% } else { %>
      <div class="row g-3">
        <% recentOwnNotes.forEach(function(note) { %>
          <div class="col-md-6 col-xl-4">
            <div class="card shadow-sm h-100">
              <div class="card-body">
                <div class="d-flex justify-content-between gap-2 mb-2">
                  <h3 class="h5 mb-0"><a href="/notes/<%= note.id %>" class="text-decoration-none"><%= note.title %></a></h3>
                  <span class="badge text-bg-<%= note.is_public ? 'success' : 'secondary' %>">
                    <%= note.is_public ? 'Public' : 'Private' %>
                  </span>
                </div>
                <p class="text-muted small mb-2">
                  Updated <%= helpers.formatDate(note.updated_at) %>
                </p>
                <p class="card-note-preview mb-3"><%= helpers.excerpt(note.content, 160) %></p>
                <div class="small text-muted">
                  Rating: <%= note.average_rating || 'N/A' %> · <%= note.rating_count %> review(s)
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>
<% } %>

<section>
  <h2 class="h3 mb-3">Recent public notes</h2>

  <% if (recentPublicNotes.length === 0) { %>
    <div class="alert alert-secondary mb-0">No public notes have been published yet.</div>
  <% } else { %>
    <div class="row g-3">
      <% recentPublicNotes.forEach(function(note) { %>
        <div class="col-md-6 col-xl-4">
          <div class="card shadow-sm h-100">
            <div class="card-body">
              <h3 class="h5 mb-2"><a href="/notes/<%= note.id %>" class="text-decoration-none"><%= note.title %></a></h3>
              <p class="text-muted small mb-2">
                By <%= note.author_username %> · <%= helpers.formatDate(note.created_at) %>
              </p>
              <p class="card-note-preview mb-3"><%= helpers.excerpt(note.content, 160) %></p>
              <div class="small text-muted">
                Rating: <%= note.average_rating || 'N/A' %> · <%= note.rating_count %> review(s)
              </div>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>
