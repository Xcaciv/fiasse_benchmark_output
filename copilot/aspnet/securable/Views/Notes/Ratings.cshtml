@model RatingListViewModel
@{
    ViewData["Title"] = "Ratings";
}

<div class="d-flex flex-column flex-md-row justify-content-between gap-3 mb-4">
    <div>
        <h1 class="mb-1">Ratings for @Model.NoteTitle</h1>
        <p class="text-muted mb-0">Average: @Model.AverageRating.ToString("0.0") / 5 · Total ratings: @Model.RatingCount</p>
    </div>
    <a asp-action="Details" asp-route-id="@Model.NoteId" class="btn btn-outline-secondary align-self-start">Back to note</a>
</div>

@if (Model.Ratings.Count == 0)
{
    <div class="card shadow-sm">
        <div class="card-body p-4 text-center text-muted">This note has not been rated yet.</div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Rating</th>
                        <th>Comment</th>
                        <th>Updated</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rating in Model.Ratings)
                    {
                        <tr>
                            <td>@rating.UserName</td>
                            <td>@rating.Value / 5</td>
                            <td>@rating.Comment</td>
                            <td>@rating.CreatedAtUtc.ToLocalTime().ToString("g")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
