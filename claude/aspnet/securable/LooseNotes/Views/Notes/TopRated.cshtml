@model TopRatedViewModel
@{
    ViewData["Title"] = "Top Rated Notes";
}
<h2>Top Rated Notes</h2>
<p class="text-muted">Public notes with at least 3 ratings, sorted by average score.</p>

@if (!Model.Notes.Any())
{
    <p class="alert alert-info">No notes have enough ratings yet. Be the first to rate some!</p>
}
else
{
    <div class="list-group">
        @foreach (var note in Model.Notes)
        {
            <a asp-controller="Notes" asp-action="Details" asp-route-id="@note.Id"
               class="list-group-item list-group-item-action">
                <div class="d-flex justify-content-between">
                    <h6 class="mb-1">@note.Title</h6>
                    <span class="text-warning">&#9733; @note.AverageRating.ToString("F1") (@note.RatingCount)</span>
                </div>
                <p class="mb-1 text-muted small">@note.Excerpt</p>
                <small class="text-muted">by @note.OwnerUserName</small>
            </a>
        }
    </div>
}
