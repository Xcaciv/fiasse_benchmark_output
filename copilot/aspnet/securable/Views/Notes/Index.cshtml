@model NoteListViewModel
@{
    ViewData["Title"] = "My Notes";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My Notes</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Note</a>
</div>

@if (!Model.Notes.Any())
{
    <div class="text-center text-muted py-5">
        <p>You haven't created any notes yet.</p>
        <a asp-action="Create" class="btn btn-outline-primary">Create Your First Note</a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var note in Model.Notes)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <a asp-action="Details" asp-route-id="@note.Id" class="text-decoration-none">
                                @note.Title
                            </a>
                        </h5>
                        <p class="card-text text-muted small">
                            @(note.Content.Length > 100 ? note.Content[..100] + "…" : note.Content)
                        </p>
                    </div>
                    <div class="card-footer d-flex justify-content-between align-items-center">
                        <small class="text-muted">@note.UpdatedAt.ToString("MMM d, yyyy")</small>
                        <span class="badge @(note.IsPublic ? "bg-success" : "bg-secondary")">
                            @(note.IsPublic ? "Public" : "Private")
                        </span>
                    </div>
                </div>
            </div>
        }
    </div>
}
