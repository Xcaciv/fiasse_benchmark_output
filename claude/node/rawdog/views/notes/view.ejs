<%- include('../partials/header', { title: title }) %>

<div class="row">
  <div class="col-lg-8">
    <!-- Note header -->
    <div class="d-flex justify-content-between align-items-start mb-3">
      <div>
        <h1 class="h2 mb-1"><%= note.title %></h1>
        <p class="text-muted small mb-0">
          By <strong><%= note.username %></strong> &bull;
          Created <%= new Date(note.created_at).toLocaleDateString() %>
          <% if (note.updated_at !== note.created_at) { %>
            &bull; Updated <%= new Date(note.updated_at).toLocaleDateString() %>
          <% } %>
          &bull;
          <span class="badge visibility-badge-<%= note.visibility %>"><%= note.visibility %></span>
        </p>
      </div>
      <% if (isOwner || isAdmin) { %>
        <div class="d-flex gap-2 flex-shrink-0 ms-3">
          <a href="/notes/<%= note.id %>/edit" class="btn btn-sm btn-outline-secondary">
            <i class="bi bi-pencil me-1"></i>Edit
          </a>
          <button class="btn btn-sm btn-outline-danger"
            onclick="document.getElementById('deleteModal').style.display='flex'" >
            <i class="bi bi-trash"></i>
          </button>
        </div>
      <% } %>
    </div>

    <!-- Note content -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body p-4">
        <pre class="mb-0" style="font-family: inherit;"><%= note.content %></pre>
      </div>
    </div>

    <!-- Attachments -->
    <% if (attachments.length > 0) { %>
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white fw-semibold">
          <i class="bi bi-paperclip me-2"></i>Attachments (<%= attachments.length %>)
        </div>
        <ul class="list-group list-group-flush">
          <% attachments.forEach(att => { %>
            <li class="list-group-item d-flex justify-content-between align-items-center">
              <a href="/uploads/<%= att.stored_filename %>" target="_blank">
                <i class="bi bi-file-earmark me-2"></i><%= att.original_filename %>
              </a>
              <span class="text-muted small"><%= (att.file_size / 1024).toFixed(1) %> KB</span>
            </li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <!-- Ratings section -->
    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white fw-semibold d-flex justify-content-between">
        <span><i class="bi bi-star me-2"></i>Ratings (<%= ratings.length %>)</span>
        <% if (avgRating) { %>
          <span class="star-rating">
            <i class="bi bi-star-fill"></i> <%= avgRating %> / 5
          </span>
        <% } %>
      </div>
      <div class="card-body">
        <% if (user && user.id !== note.user_id) { %>
          <form action="/notes/<%= note.id %>/rate" method="POST" class="mb-4">
            <h6 class="mb-2"><%= userRating ? 'Update Your Rating' : 'Rate This Note' %></h6>
            <div class="mb-2">
              <% for (let i = 1; i <= 5; i++) { %>
                <div class="form-check form-check-inline">
                  <input class="form-check-input" type="radio" name="rating" id="r<%= i %>" value="<%= i %>"
                    <%= userRating && userRating.rating === i ? 'checked' : '' %> required>
                  <label class="form-check-label" for="r<%= i %>"><%= i %> <i class="bi bi-star-fill text-warning" style="font-size:.8rem"></i></label>
                </div>
              <% } %>
            </div>
            <div class="mb-2">
              <textarea class="form-control form-control-sm" name="comment" rows="2"
                placeholder="Optional comment..."><%= userRating ? userRating.comment || '' : '' %></textarea>
            </div>
            <button type="submit" class="btn btn-sm btn-primary">
              <%= userRating ? 'Update Rating' : 'Submit Rating' %>
            </button>
          </form>
        <% } else if (!user) { %>
          <p class="text-muted small mb-3">
            <a href="/auth/login">Log in</a> to rate this note.
          </p>
        <% } %>

        <% if (ratings.length === 0) { %>
          <p class="text-muted small mb-0">No ratings yet. Be the first to rate!</p>
        <% } else { %>
          <% ratings.forEach(r => { %>
            <div class="mb-3 pb-3 border-bottom">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <strong class="small"><%= r.username %></strong>
                <div>
                  <span class="star-rating small">
                    <% for (let i = 1; i <= 5; i++) { %>
                      <i class="bi bi-star<%= i <= r.rating ? '-fill' : '' %>"></i>
                    <% } %>
                  </span>
                  <span class="text-muted small ms-2"><%= new Date(r.updated_at).toLocaleDateString() %></span>
                </div>
              </div>
              <% if (r.comment) { %>
                <p class="small mb-0 text-muted"><%= r.comment %></p>
              <% } %>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="col-lg-4">
    <% if (isOwner) { %>
      <!-- Share link panel -->
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-white fw-semibold">
          <i class="bi bi-share me-2"></i>Share Link
        </div>
        <div class="card-body">
          <% if (shareLink) { %>
            <div class="input-group mb-2">
              <input type="text" class="form-control form-control-sm"
                value="<%= typeof req !== 'undefined' ? '' : '' %>/share/<%= shareLink.token %>"
                id="shareLinkInput" readonly>
              <button class="btn btn-sm btn-outline-secondary" onclick="copyShareLink()">
                <i class="bi bi-clipboard"></i>
              </button>
            </div>
            <p class="text-muted small mb-2" id="shareLinkFull" style="word-break:break-all; display:none;"></p>
            <form action="/notes/<%= note.id %>/share/revoke" method="POST" class="d-inline">
              <button type="submit" class="btn btn-sm btn-outline-danger me-1">Revoke</button>
            </form>
            <form action="/notes/<%= note.id %>/share/generate" method="POST" class="d-inline">
              <button type="submit" class="btn btn-sm btn-outline-secondary">Regenerate</button>
            </form>
          <% } else { %>
            <p class="text-muted small mb-2">No share link active.</p>
            <form action="/notes/<%= note.id %>/share/generate" method="POST">
              <button type="submit" class="btn btn-sm btn-primary">
                <i class="bi bi-link-45deg me-1"></i>Generate Link
              </button>
            </form>
          <% } %>
        </div>
      </div>
    <% } %>

    <!-- Note info -->
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white fw-semibold">
        <i class="bi bi-info-circle me-2"></i>Note Info
      </div>
      <ul class="list-group list-group-flush">
        <li class="list-group-item d-flex justify-content-between small">
          <span class="text-muted">Author</span>
          <span><%= note.username %></span>
        </li>
        <li class="list-group-item d-flex justify-content-between small">
          <span class="text-muted">Created</span>
          <span><%= new Date(note.created_at).toLocaleDateString() %></span>
        </li>
        <li class="list-group-item d-flex justify-content-between small">
          <span class="text-muted">Visibility</span>
          <span class="badge visibility-badge-<%= note.visibility %>"><%= note.visibility %></span>
        </li>
        <li class="list-group-item d-flex justify-content-between small">
          <span class="text-muted">Attachments</span>
          <span><%= attachments.length %></span>
        </li>
        <li class="list-group-item d-flex justify-content-between small">
          <span class="text-muted">Avg Rating</span>
          <span>
            <% if (avgRating) { %>
              <span class="star-rating"><i class="bi bi-star-fill"></i></span> <%= avgRating %> (<%= ratings.length %>)
            <% } else { %>
              No ratings
            <% } %>
          </span>
        </li>
      </ul>
    </div>

    <% if (isOwner) { %>
      <div class="mt-3">
        <form action="/notes/<%= note.id %>/delete" method="POST" id="deleteFormMain">
          <button type="button" class="btn btn-danger w-100"
            onclick="if(confirm('Delete this note? This cannot be undone.')) document.getElementById('deleteFormMain').submit()">
            <i class="bi bi-trash me-1"></i>Delete Note
          </button>
        </form>
      </div>
    <% } %>
  </div>
</div>

<script>
function copyShareLink() {
  const token = '<%= shareLink ? shareLink.token : "" %>';
  const url = window.location.origin + '/share/' + token;
  navigator.clipboard.writeText(url).then(() => {
    document.querySelector('#shareLinkInput').value = url;
    alert('Link copied to clipboard!');
  });
}
// Set share link full URL on page load
window.addEventListener('DOMContentLoaded', function() {
  const input = document.getElementById('shareLinkInput');
  if (input) {
    const token = '<%= shareLink ? shareLink.token : "" %>';
    if (token) input.value = window.location.origin + '/share/' + token;
  }
});
</script>

<%- include('../partials/footer') %>
