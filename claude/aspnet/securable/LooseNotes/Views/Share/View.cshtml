@model Note
@{
    ViewData["Title"] = Model.Title;
    Layout = "_Layout";
}
<div class="alert alert-info d-flex align-items-center mb-4" role="alert">
    <span>You are viewing a shared note.</span>
    @if (User.Identity?.IsAuthenticated != true)
    {
        <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-outline-primary ms-auto">Log In</a>
    }
</div>

<div class="card mb-4">
    <div class="card-header">
        <h3 class="mb-0">@Model.Title</h3>
    </div>
    <div class="card-body">
        <p class="text-muted small">By @Model.Owner?.DisplayName &nbsp;|&nbsp;
           @Model.CreatedAt.ToString("MMM d, yyyy")</p>
        <div style="white-space: pre-wrap;">@Model.Content</div>
    </div>
</div>

@if (Model.Attachments.Any())
{
    <div class="card">
        <div class="card-header"><h5 class="mb-0">Attachments</h5></div>
        <ul class="list-group list-group-flush">
            @foreach (var att in Model.Attachments)
            {
                <li class="list-group-item">
                    <a asp-controller="Attachments" asp-action="Download" asp-route-id="@att.Id">
                        @att.OriginalFileName
                    </a>
                </li>
            }
        </ul>
    </div>
}
