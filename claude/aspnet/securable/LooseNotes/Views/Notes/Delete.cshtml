@model Note
@{
    ViewData["Title"] = "Delete Note";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="alert alert-danger">
            <h4 class="alert-heading">Delete Note</h4>
            <p>Are you sure you want to permanently delete <strong>@Model.Title</strong>?</p>
            <p class="mb-0">This will also remove all attachments, ratings, and share links.</p>
        </div>
        <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
            @Html.AntiForgeryToken()
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Delete Permanently</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
