@model IList<Note>
@{
    ViewData["Title"] = "LooseNotes";
}

<h2>Public Notes</h2>

@if (!Model.Any())
{
    <p class="text-muted">No public notes yet. <a asp-controller="Account" asp-action="Register">Register</a> to share your first note.</p>
}
else
{
    <div class="row">
        @foreach (var note in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card">
                    <div class="card-body">
                        @* All values HTML-encoded by Razor @ operator *@
                        <h5 class="card-title">@note.Title</h5>
                        <p class="card-text text-muted small">@note.CreatedAt.ToString("yyyy-MM-dd")</p>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <a asp-controller="Notes" asp-action="Details"
                               asp-route-id="@note.Id" class="btn btn-sm btn-outline-primary">Read</a>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
