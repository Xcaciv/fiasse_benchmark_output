@model LooseNotes.Models.Note
@{
    ViewData["Title"] = Model.Title;
    Layout = "_Layout";
}

<div class="alert alert-info">
    This note was shared with you via a direct link.
</div>

<h2>@Model.Title</h2>
<p class="text-muted">By <strong>@Model.User?.UserName</strong> &middot; @Model.CreatedAt.ToString("MMM d, yyyy")</p>

<div class="card mb-4">
    <div class="card-body">
        <pre style="white-space: pre-wrap; font-family: inherit;">@Model.Content</pre>
    </div>
</div>

@if (Model.Attachments.Any())
{
    <h5>Attachments</h5>
    <ul class="list-group mb-4">
        @foreach (var att in Model.Attachments)
        {
            <li class="list-group-item">
                <a asp-controller="Notes" asp-action="DownloadAttachment" asp-route-id="@att.Id">@att.OriginalFileName</a>
                <span class="text-muted small ms-2">(@(att.FileSize / 1024) KB)</span>
            </li>
        }
    </ul>
}

@if (Model.Ratings.Any())
{
    <h5>Ratings (@Model.Ratings.Count)</h5>
    <p>
        Average:
        <span class="star-rating">
            @for (int i = 1; i <= 5; i++)
            {
                <span>@(i <= Math.Round(Model.AverageRating) ? "★" : "☆")</span>
            }
        </span>
        @Model.AverageRating.ToString("0.0")
    </p>

    @foreach (var rating in Model.Ratings.OrderByDescending(r => r.UpdatedAt))
    {
        <div class="card mb-2">
            <div class="card-body py-2">
                <div class="d-flex justify-content-between">
                    <strong>@rating.User?.UserName</strong>
                    <span class="star-rating">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span>@(i <= rating.Value ? "★" : "☆")</span>
                        }
                    </span>
                </div>
                @if (!string.IsNullOrEmpty(rating.Comment))
                {
                    <p class="mb-0 mt-1">@rating.Comment</p>
                }
            </div>
        </div>
    }
}
