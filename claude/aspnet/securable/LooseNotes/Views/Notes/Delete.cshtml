@model NoteListItemViewModel
@{
    ViewData["Title"] = "Delete Note";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">Confirm Deletion</div>
            <div class="card-body">
                <h5 class="card-title">Delete "@Model.Title"?</h5>
                <p class="card-text text-muted">
                    This will permanently remove the note, all attachments, ratings, and share links.
                    This action cannot be undone.
                </p>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-danger me-2">Yes, Delete</button>
                    <a asp-action="Details" asp-route-id="@Model.Id"
                       class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
