@model UserListViewModel
@{
    ViewData["Title"] = "Manage Users";
}

<h2>Manage Users</h2>

<form asp-action="Users" method="get" class="mb-4">
    <div class="input-group">
        <input asp-for="SearchQuery" class="form-control" placeholder="Search by username or email…"
               maxlength="100" />
        <button type="submit" class="btn btn-outline-primary">Search</button>
        @if (!string.IsNullOrEmpty(Model.SearchQuery))
        {
            <a asp-action="Users" class="btn btn-outline-secondary">Clear</a>
        }
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Role</th>
                <th>Joined</th>
                <th>Notes</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.UserName</td>
                    <td>@user.Email</td>
                    <td>
                        @if (user.IsAdmin)
                        {
                            <span class="badge bg-warning text-dark">Admin</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">User</span>
                        }
                    </td>
                    <td><small>@user.CreatedAt.ToString("yyyy-MM-dd")</small></td>
                    <td>@user.NoteCount</td>
                    <td></td>
                </tr>
            }
        </tbody>
    </table>
</div>
