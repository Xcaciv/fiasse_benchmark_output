@model IReadOnlyList<NoteListItemViewModel>
@{
    ViewData["Title"] = "Top Rated Notes";
}
<h2>Top Rated Notes</h2>
<p class="text-muted">Public notes with at least 3 ratings, sorted by average score.</p>

@if (!Model.Any())
{
    <div class="alert alert-info">No top-rated notes yet. Be the first to rate some notes!</div>
}
else
{
    <div class="list-group">
        @foreach (var note in Model)
        {
            <a asp-action="Details" asp-route-id="@note.Id" class="list-group-item list-group-item-action">
                <div class="d-flex w-100 justify-content-between">
                    <h6 class="mb-1">@note.Title</h6>
                    <span class="text-warning fw-bold">
                        ★ @note.AverageRating!.Value.ToString("F1")
                        <small class="text-muted fw-normal">(@note.RatingCount)</small>
                    </span>
                </div>
                <p class="mb-1 small text-muted">@note.Excerpt</p>
                <small>By @note.OwnerDisplayName</small>
            </a>
        }
    </div>
}
