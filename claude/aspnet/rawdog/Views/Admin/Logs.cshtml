@{
    ViewData["Title"] = "Activity Logs";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Activity Logs</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&larr; Dashboard</a>
</div>

<p class="text-muted">Log file: <code>@ViewBag.LogPath</code></p>

@if (!string.IsNullOrEmpty(ViewBag.LogContent as string))
{
    <div class="card bg-dark text-light">
        <div class="card-body">
            <pre style="white-space:pre-wrap;max-height:500px;overflow-y:auto">@ViewBag.LogContent</pre>
        </div>
    </div>
}
else
{
    <p class="text-muted">No log entries yet.</p>
}
