@model UserListViewModel
@{
    ViewData["Title"] = "Users";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Users</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">← Dashboard</a>
</div>

<form asp-action="Users" method="get" class="mb-4">
    <div class="input-group" style="max-width:400px;">
        <input type="search" name="q" value="@Model.SearchQuery" class="form-control"
               placeholder="Search by username or email…" maxlength="100" />
        <button type="submit" class="btn btn-outline-secondary">Search</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>ID</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td>@user.UserName</td>
                    <td>@user.Email</td>
                    <td><small class="text-muted">@user.Id</small></td>
                </tr>
            }
        </tbody>
    </table>
</div>
