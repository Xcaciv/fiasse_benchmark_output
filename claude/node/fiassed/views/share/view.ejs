<div class="shared-note">
  <div class="shared-note-header">
    <h1><%= note.title %></h1>
    <p class="shared-badge">Shared Note</p>
    <small>Last updated: <%= new Date(note.updatedAt).toLocaleDateString() %></small>
  </div>

  <div class="note-content">
    <pre><%= note.content %></pre>
  </div>

  <div class="shared-note-footer">
    <p><a href="/">Visit Loose Notes</a> to create and share your own notes.</p>
  </div>
</div>
