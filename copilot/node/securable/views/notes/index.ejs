<%- include('../partials/header') %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>My Notes</h2>
  <a href="/notes/new" class="btn btn-primary">+ New Note</a>
</div>
<% if (notes.length === 0) { %>
  <div class="alert alert-info">You have no notes yet. <a href="/notes/new">Create your first note.</a></div>
<% } else { %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead class="table-light">
        <tr>
          <th>Title</th>
          <th>Visibility</th>
          <th>Last Updated</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% notes.forEach(function(note) { %>
          <tr>
            <td><a href="/notes/<%= note.id %>"><%= note.title %></a></td>
            <td>
              <% if (note.visibility === 'public') { %>
                <span class="badge bg-success">Public</span>
              <% } else { %>
                <span class="badge bg-secondary">Private</span>
              <% } %>
            </td>
            <td><%= note.updatedAt.toLocaleDateString() %></td>
            <td>
              <a href="/notes/<%= note.id %>/edit" class="btn btn-sm btn-outline-secondary">Edit</a>
              <form action="/notes/<%= note.id %>?_method=DELETE" method="POST" class="d-inline confirm-delete">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="_method" value="DELETE">
                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% if (totalPages > 1) { %>
    <nav>
      <ul class="pagination">
        <% for (let p = 1; p <= totalPages; p++) { %>
          <li class="page-item <%= p === page ? 'active' : '' %>">
            <a class="page-link" href="/notes?page=<%= p %>"><%= p %></a>
          </li>
        <% } %>
      </ul>
    </nav>
  <% } %>
<% } %>
<%- include('../partials/footer') %>
