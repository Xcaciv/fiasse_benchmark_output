@model NoteSearchViewModel
@{
    ViewData["Title"] = "Search Notes";
}
<h2>Search Notes</h2>
<form asp-action="Search" method="get" class="mb-4">
    <div class="input-group">
        <input asp-for="Query" class="form-control" placeholder="Search titles and content..."
               maxlength="200" autocomplete="off" />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
    <span asp-validation-for="Query" class="text-danger small"></span>
</form>

@if (Model.HasSearched)
{
    @if (!Model.Results.Any())
    {
        <p class="text-muted">No notes found matching <em>@Model.Query</em>.</p>
    }
    else
    {
        <p class="text-muted">Found @Model.Results.Count result(s) for <em>@Model.Query</em>.</p>
        <div class="list-group">
            @foreach (var note in Model.Results)
            {
                <a asp-action="Details" asp-route-id="@note.Id" class="list-group-item list-group-item-action">
                    <div class="d-flex w-100 justify-content-between">
                        <h6 class="mb-1">@note.Title</h6>
                        <small class="text-muted">@note.CreatedAt.ToString("MMM d, yyyy")</small>
                    </div>
                    <p class="mb-1 small text-muted">@note.Excerpt</p>
                    <small>By @note.OwnerDisplayName</small>
                </a>
            }
        </div>
    }
}
