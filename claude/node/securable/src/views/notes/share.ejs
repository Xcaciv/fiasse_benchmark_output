<%- include('../partials/head', {title}) %>
<%- include('../partials/nav') %>
<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-7">
      <div class="d-flex align-items-center gap-2 mb-4">
        <a href="/notes/<%= note.id %>" class="btn btn-sm btn-outline-secondary">← Back</a>
        <h1 class="h3 mb-0">Share Note</h1>
      </div>
      <p class="text-muted">Note: <strong><%= note.title %></strong></p>

      <% if (shareLink) { %>
        <div class="alert alert-info">
          <strong>Share link is active.</strong><br>
          Anyone with this URL can view the note without signing in:
        </div>
        <div class="input-group mb-3">
          <input type="text" class="form-control" id="shareUrl" readonly
                 value="<%= baseUrl %>/share/<%= shareLink.token %>">
          <button class="btn btn-outline-secondary" type="button"
                  onclick="navigator.clipboard.writeText(document.getElementById('shareUrl').value)">
            Copy
          </button>
        </div>
        <div class="d-flex gap-2">
          <form method="POST" action="/notes/<%= note.id %>/share/generate">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn btn-warning" type="submit">Regenerate Link</button>
          </form>
          <form method="POST" action="/notes/<%= note.id %>/share/revoke"
                onsubmit="return confirm('Revoke this share link? Anyone with the old link will lose access.')">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn btn-danger" type="submit">Revoke Link</button>
          </form>
        </div>
      <% } else { %>
        <div class="alert alert-secondary">No share link exists for this note.</div>
        <form method="POST" action="/notes/<%= note.id %>/share/generate">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="btn btn-primary" type="submit">Generate Share Link</button>
        </form>
      <% } %>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
