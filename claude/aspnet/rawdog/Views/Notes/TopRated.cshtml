@model TopRatedViewModel
@{
    ViewData["Title"] = "Top Rated Notes";
}

<h2><i class="bi bi-star-fill text-warning"></i> Top Rated Notes</h2>
<p class="text-muted mb-4">Public notes with at least 3 ratings, sorted by average rating.</p>

@if (!Model.Notes.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-star display-3"></i>
        <p class="mt-3">No notes have enough ratings yet. Be the first to rate some notes!</p>
        <a asp-action="Search" class="btn btn-outline-primary">Browse Notes</a>
    </div>
}
else
{
    <div class="list-group">
        @for (int i = 0; i < Model.Notes.Count; i++)
        {
            var note = Model.Notes[i];
            <a asp-action="Details" asp-route-id="@note.Id"
               class="list-group-item list-group-item-action">
                <div class="d-flex justify-content-between align-items-start">
                    <div class="d-flex align-items-center me-3">
                        <span class="display-6 text-muted me-3 fw-bold">@(i + 1)</span>
                        <div>
                            <h6 class="mb-1">@note.Title</h6>
                            <p class="mb-1 text-muted small">@note.Excerpt</p>
                            <small class="text-muted">
                                By <strong>@note.AuthorName</strong> &bull;
                                @note.CreatedAt.ToString("MMM d, yyyy")
                            </small>
                        </div>
                    </div>
                    <div class="text-end text-nowrap">
                        <div class="star-rating fs-5">
                            <i class="bi bi-star-fill"></i> @note.AverageRating.ToString("F1")
                        </div>
                        <small class="text-muted">@note.RatingCount ratings</small>
                    </div>
                </div>
            </a>
        }
    </div>
}
