@model Note
@{
    ViewData["Title"] = "Shared Note";
    Layout = "_Layout";
}

<div class="card mb-4">
    <div class="card-header">
        <h3 class="mb-0">
            @* Raw rendering of title (§6) *@
            @Html.Raw(Model.Title)
        </h3>
        <small class="text-muted">Shared note &bull; @Model.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</small>
    </div>
    <div class="card-body">
        @* Content inserted without encoding (§6) *@
        <div class="note-content">@Html.Raw(Model.Content)</div>
    </div>
</div>

@if (Model.Ratings != null && Model.Ratings.Any())
{
    <div class="card mb-4">
        <div class="card-header">Ratings</div>
        <div class="card-body">
            @foreach (var rating in Model.Ratings)
            {
                <div class="border-bottom pb-2 mb-2">
                    <span class="text-warning">@string.Concat(Enumerable.Repeat("★", rating.Score))</span>
                    <span class="text-muted small ms-2">@rating.SubmitterEmail</span>
                    <div>
                        @* Rating comment inserted without encoding (§6) *@
                        @Html.Raw(rating.Comment)
                    </div>
                </div>
            }
        </div>
    </div>
}

<a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Go to LooseNotes</a>
