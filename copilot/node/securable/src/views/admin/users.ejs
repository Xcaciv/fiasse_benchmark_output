<h2>User Management</h2>
<form method="GET" action="/admin/users/search" class="mb-4">
  <div class="input-group">
    <input type="text" name="q" class="form-control" value="<%= query %>" placeholder="Search users...">
    <button type="submit" class="btn btn-primary">Search</button>
    <a href="/admin/users" class="btn btn-outline-secondary">Clear</a>
  </div>
</form>
<table class="table table-striped">
  <thead><tr><th>Username</th><th>Email</th><th>Notes</th><th>Admin</th><th>Registered</th><th>Actions</th></tr></thead>
  <tbody>
    <% users.forEach(u => { %>
      <tr>
        <td><%= u.username %></td>
        <td><%= u.email %></td>
        <td><%= u.Notes ? u.Notes.length : 0 %></td>
        <td><%= u.isAdmin ? '&#10003;' : '' %></td>
        <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
        <td>
          <% if (u.Notes && u.Notes.length > 0) { %>
            <form method="POST" action="/admin/notes/<%= u.Notes[0].id %>/reassign" class="d-flex gap-1">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input type="text" name="newOwnerId" class="form-control form-control-sm" placeholder="New Owner ID" style="width:200px">
              <button type="submit" class="btn btn-sm btn-outline-warning">Reassign</button>
            </form>
          <% } %>
        </td>
      </tr>
    <% }) %>
  </tbody>
</table>
