<div class="note-detail">
  <div class="note-detail-header">
    <div>
      <h1><%= note.title %></h1>
      <div class="note-meta">
        By <strong><%= note.owner.username %></strong> &nbsp;|&nbsp;
        <%= new Date(note.createdAt).toLocaleDateString() %>
        <% if (note.updatedAt && note.updatedAt !== note.createdAt) { %>
          (updated <%= new Date(note.updatedAt).toLocaleDateString() %>)
        <% } %>
        &nbsp;|&nbsp;
        <span class="badge <%= note.isPublic ? 'badge-public' : 'badge-private' %>">
          <%= note.isPublic ? 'Public' : 'Private' %>
        </span>
      </div>
    </div>
    <% if (isOwner) { %>
      <div class="note-owner-actions">
        <a href="/notes/<%= note.id %>/edit" class="btn btn-sm btn-secondary">Edit</a>
        <form method="POST" action="/notes/<%= note.id %>/delete" style="display:inline"
              onsubmit="return confirm('Delete this note and all its attachments?')">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="submit" class="btn btn-sm btn-danger">Delete</button>
        </form>
      </div>
    <% } %>
  </div>

  <div class="note-content"><%- note.content.replace(/\n/g, '<br>') %></div>

  <% if (isOwner && shareLink) { %>
    <div class="share-section card">
      <h3>Share Link</h3>
      <p class="share-url">
        <code><%= `${typeof window !== 'undefined' ? window.location.origin : ''}/share?token=${shareLink.token}` %></code>
      </p>
      <p><small>Anyone with this link can view this note (even if private).</small></p>
      <form method="POST" action="/notes/<%= note.id %>/share/regenerate" style="display:inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" class="btn btn-sm btn-secondary">Regenerate Link</button>
      </form>
      <form method="POST" action="/notes/<%= note.id %>/share/revoke" style="display:inline">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <button type="submit" class="btn btn-sm btn-danger"
                onclick="return confirm('Revoke share link?')">Revoke Link</button>
      </form>
    </div>
  <% } %>

  <% if (note.attachments && note.attachments.length > 0) { %>
    <div class="attachments-section">
      <h3>Attachments (<%= note.attachments.length %>)</h3>
      <ul class="attachment-list">
        <% note.attachments.forEach(att => { %>
          <li class="attachment-item">
            <a href="/attachments/<%= att.id %>/download"><%= att.originalFilename %></a>
            <span class="attachment-size"><%= (att.sizeBytes / 1024).toFixed(1) %> KB</span>
            <% if (isOwner) { %>
              <form method="POST" action="/attachments/<%= att.id %>/delete" style="display:inline">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
                <button type="submit" class="btn btn-xs btn-danger"
                        onclick="return confirm('Delete this attachment?')">×</button>
              </form>
            <% } %>
          </li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <% if (isOwner) { %>
    <div class="upload-section card">
      <h3>Upload Attachment</h3>
      <form method="POST" action="/attachments/upload/<%= note.id %>" enctype="multipart/form-data">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="form-group">
          <input type="file" name="file" accept=".pdf,.doc,.docx,.txt,.png,.jpg,.jpeg" required />
          <small>Allowed: PDF, DOC, DOCX, TXT, PNG, JPG, JPEG. Max 5 MB.</small>
        </div>
        <button type="submit" class="btn btn-secondary">Upload</button>
      </form>
    </div>
  <% } %>

  <div class="ratings-section">
    <h3>Ratings</h3>

    <% if (user) { %>
      <form method="POST" action="/notes/<%= note.id %>/rate" class="rating-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
        <div class="form-group">
          <label for="value">Your Rating</label>
          <select id="value" name="value" required>
            <option value="">Select...</option>
            <% for (let i = 1; i <= 5; i++) { %>
              <option value="<%= i %>"><%= '★'.repeat(i) %> (<%= i %>)</option>
            <% } %>
          </select>
        </div>
        <div class="form-group">
          <label for="comment">Comment (optional)</label>
          <textarea id="comment" name="comment" rows="2" maxlength="1000"></textarea>
        </div>
        <button type="submit" class="btn btn-primary btn-sm">Submit Rating</button>
      </form>
    <% } %>

    <% if (note.ratings && note.ratings.length > 0) { %>
      <% const avg = (note.ratings.reduce((s,r) => s+r.value,0) / note.ratings.length).toFixed(1); %>
      <p class="rating-summary">Average: <strong><%= avg %> ★</strong> (<%= note.ratings.length %> ratings)</p>
      <ul class="ratings-list">
        <% note.ratings.forEach(rating => { %>
          <li class="rating-item">
            <div class="rating-header">
              <strong><%= rating.rater.username %></strong>
              <span class="stars"><%= '★'.repeat(rating.value) %><%= '☆'.repeat(5 - rating.value) %></span>
              <span class="rating-date"><%= new Date(rating.createdAt).toLocaleDateString() %></span>
            </div>
            <% if (rating.comment) { %><p class="rating-comment"><%= rating.comment %></p><% } %>
          </li>
        <% }) %>
      </ul>
    <% } else { %>
      <p class="empty-state">No ratings yet.</p>
    <% } %>
  </div>
</div>
