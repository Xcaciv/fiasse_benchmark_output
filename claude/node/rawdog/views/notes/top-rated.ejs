<%- include('../partials/header') %>

<div class="mb-4">
  <div class="text-center mb-5">
    <i class="bi bi-trophy display-3 text-warning mb-3"></i>
    <h1 class="mb-2">Top Rated Notes</h1>
    <p class="text-muted">Public notes with at least 3 ratings, sorted by average rating.</p>
  </div>

  <% if (notes && notes.length > 0) { %>
  <div class="row g-4">
    <% notes.forEach(function(note, index) { %>
    <div class="col-md-6 col-lg-4">
      <div class="card h-100 shadow-sm position-relative">
        <% if (index === 0) { %>
        <div class="position-absolute top-0 start-50 translate-middle">
          <span class="badge bg-warning text-dark px-3 py-2 rounded-pill shadow">
            <i class="bi bi-trophy-fill me-1"></i>#1
          </span>
        </div>
        <% } else if (index === 1) { %>
        <div class="position-absolute top-0 start-50 translate-middle">
          <span class="badge bg-secondary px-3 py-2 rounded-pill shadow">#2</span>
        </div>
        <% } else if (index === 2) { %>
        <div class="position-absolute top-0 start-50 translate-middle">
          <span class="badge px-3 py-2 rounded-pill shadow" style="background-color: #cd7f32; color: white;">#3</span>
        </div>
        <% } %>

        <div class="card-body pt-4">
          <div class="text-center mb-3">
            <div class="display-6 fw-bold text-warning"><%= note.avgRating %></div>
            <div class="text-warning">
              <% var avgStars = Math.round(parseFloat(note.avgRating)); %>
              <% for (var i = 1; i <= 5; i++) { %>
              <i class="bi bi-star<%= i <= avgStars ? '-fill' : '' %>"></i>
              <% } %>
            </div>
            <small class="text-muted"><%= note.ratingCount %> rating<%= note.ratingCount !== 1 ? 's' : '' %></small>
          </div>

          <h5 class="card-title text-center">
            <a href="/notes/<%= note.id %>" class="text-decoration-none text-dark">
              <%= note.title %>
            </a>
          </h5>

          <p class="card-text text-muted small text-center">
            <%= note.content.substring(0, 100) %><%= note.content.length > 100 ? '...' : '' %>
          </p>
        </div>

        <div class="card-footer bg-transparent text-center">
          <small class="text-muted">
            <i class="bi bi-person me-1"></i><%= note.author ? note.author.username : 'Unknown' %>
            &bull;
            <i class="bi bi-calendar me-1"></i><%= new Date(note.createdAt).toLocaleDateString() %>
          </small>
          <div class="mt-2">
            <a href="/notes/<%= note.id %>" class="btn btn-sm btn-outline-primary">
              <i class="bi bi-eye me-1"></i>Read Note
            </a>
          </div>
        </div>
      </div>
    </div>
    <% }); %>
  </div>
  <% } else { %>
  <div class="text-center py-5">
    <i class="bi bi-star display-3 text-muted mb-3"></i>
    <h4 class="text-muted">No top-rated notes yet</h4>
    <p class="text-muted">
      Notes need at least 3 ratings to appear here.
      <% if (user) { %>
      <a href="/notes">Browse notes</a> and rate some!
      <% } else { %>
      <a href="/auth/register">Register</a> to start rating notes!
      <% } %>
    </p>
  </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
