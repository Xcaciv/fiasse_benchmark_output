@{
    ViewData["Title"] = "Welcome";
}
<div class="row justify-content-center">
    <div class="col-md-8 text-center mt-5">
        <h1 class="display-4">Welcome to LooseNotes</h1>
        <p class="lead text-muted">Your private, shareable note-taking app.</p>
        <div class="mt-4">
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg me-2">Get Started</a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-lg">Sign In</a>
        </div>
        <hr class="my-5" />
        <div class="row g-4">
            <div class="col-md-4">
                <h5>📝 Take Notes</h5>
                <p class="text-muted">Create and manage notes with file attachments.</p>
            </div>
            <div class="col-md-4">
                <h5>🔗 Share Links</h5>
                <p class="text-muted">Share notes via unique, revocable links.</p>
            </div>
            <div class="col-md-4">
                <h5>⭐ Rate Notes</h5>
                <p class="text-muted">Rate and discover top public notes.</p>
            </div>
        </div>
    </div>
</div>
