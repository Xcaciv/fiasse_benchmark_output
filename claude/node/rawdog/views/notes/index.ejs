<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="mb-0"><i class="bi bi-journal-richtext text-primary me-2"></i>My Notes</h1>
  <a href="/notes/create" class="btn btn-primary">
    <i class="bi bi-plus-circle me-2"></i>New Note
  </a>
</div>

<% if (notes && notes.length > 0) { %>
<div class="row g-3">
  <% notes.forEach(function(note) { %>
  <div class="col-md-6 col-lg-4">
    <div class="card h-100 shadow-sm">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-2">
          <h5 class="card-title mb-0">
            <a href="/notes/<%= note.id %>" class="text-decoration-none text-dark">
              <%= note.title %>
            </a>
          </h5>
          <% if (note.isPublic) { %>
          <span class="badge bg-success ms-2 flex-shrink-0"><i class="bi bi-globe me-1"></i>Public</span>
          <% } else { %>
          <span class="badge bg-secondary ms-2 flex-shrink-0"><i class="bi bi-lock me-1"></i>Private</span>
          <% } %>
        </div>

        <p class="card-text text-muted small">
          <%= note.content.substring(0, 120) %><%= note.content.length > 120 ? '...' : '' %>
        </p>
      </div>

      <div class="card-footer bg-transparent d-flex justify-content-between align-items-center">
        <div class="text-muted small">
          <% if (note.ratingCount > 0) { %>
          <i class="bi bi-star-fill text-warning me-1"></i><%= note.avgRating %> (<%= note.ratingCount %>)
          <% } else { %>
          <i class="bi bi-star text-muted me-1"></i>No ratings
          <% } %>
          <% if (note.attachmentCount > 0) { %>
          <span class="ms-2"><i class="bi bi-paperclip me-1"></i><%= note.attachmentCount %></span>
          <% } %>
        </div>
        <div class="btn-group btn-group-sm">
          <a href="/notes/<%= note.id %>" class="btn btn-outline-primary" title="View">
            <i class="bi bi-eye"></i>
          </a>
          <a href="/notes/<%= note.id %>/edit" class="btn btn-outline-secondary" title="Edit">
            <i class="bi bi-pencil"></i>
          </a>
          <a href="/notes/<%= note.id %>/delete" class="btn btn-outline-danger" title="Delete">
            <i class="bi bi-trash"></i>
          </a>
        </div>
      </div>
    </div>
  </div>
  <% }); %>
</div>
<% } else { %>
<div class="text-center py-5">
  <i class="bi bi-journal-x display-3 text-muted mb-3"></i>
  <h4 class="text-muted">No notes yet</h4>
  <p class="text-muted">Create your first note to get started.</p>
  <a href="/notes/create" class="btn btn-primary mt-2">
    <i class="bi bi-plus-circle me-2"></i>Create First Note
  </a>
</div>
<% } %>

<%- include('../partials/footer') %>
