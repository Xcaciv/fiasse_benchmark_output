<%- include('../partials/header', { title: title }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0"><i class="bi bi-shield-check me-2 text-primary"></i>Admin Dashboard</h1>
  <a href="/admin/users" class="btn btn-outline-primary btn-sm">
    <i class="bi bi-people me-1"></i>Manage Users
  </a>
</div>

<!-- Stats cards -->
<div class="row g-3 mb-4">
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="bg-primary bg-opacity-10 rounded-3 p-3">
          <i class="bi bi-people display-6 text-primary"></i>
        </div>
        <div>
          <div class="fs-2 fw-bold"><%= userCount %></div>
          <div class="text-muted">Total Users</div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card border-0 shadow-sm">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="bg-success bg-opacity-10 rounded-3 p-3">
          <i class="bi bi-journals display-6 text-success"></i>
        </div>
        <div>
          <div class="fs-2 fw-bold"><%= noteCount %></div>
          <div class="text-muted">Total Notes</div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Activity log -->
<div class="card border-0 shadow-sm">
  <div class="card-header bg-white fw-semibold">
    <i class="bi bi-clock-history me-2"></i>Recent Activity
  </div>
  <% if (recentActivity.length === 0) { %>
    <div class="card-body text-muted">No activity recorded yet.</div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Action</th>
            <th>User</th>
            <th>Details</th>
            <th>Time</th>
          </tr>
        </thead>
        <tbody>
          <% recentActivity.forEach(log => { %>
            <tr>
              <td><code class="small"><%= log.action %></code></td>
              <td class="small"><%= log.username || '<em>deleted</em>' %></td>
              <td class="small text-muted"><%= log.details || '' %></td>
              <td class="small text-muted text-nowrap"><%= new Date(log.created_at).toLocaleString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
