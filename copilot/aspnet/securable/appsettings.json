{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=App_Data\\loosenotes.db"
  },
  "FileStorage": {
    "StorageRootPath": "App_Data\\attachments",
    "MaxBytes": 10485760,
    "AllowedExtensions": [
      ".pdf",
      ".doc",
      ".docx",
      ".txt",
      ".png",
      ".jpg",
      ".jpeg"
    ]
  },
  "Email": {
    "OutboxPath": "App_Data\\outbox"
  },
  "BootstrapAdmin": {
    "UserName": "",
    "Email": "",
    "Password": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "AllowedHosts": "*"
}
