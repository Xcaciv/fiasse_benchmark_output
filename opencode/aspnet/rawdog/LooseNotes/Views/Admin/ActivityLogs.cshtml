@model IEnumerable<LooseNotes.Models.ActivityLog>
@{
    ViewData["Title"] = "Activity Logs";
}

<h1>@ViewData["Title"]</h1>

@if (Model.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Time</th>
                <th>Action</th>
                <th>User ID</th>
                <th>Target</th>
                <th>Details</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td>@log.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>@log.Action</td>
                    <td>
                        @if (!string.IsNullOrEmpty(log.UserId))
                        {
                            <a asp-controller="Admin" asp-action="Users" asp-route-search="@log.UserId">@log.UserId</a>
                        }
                        else
                        {
                            <span class="text-muted">System</span>
                        }
                    </td>
                    <td>
                        @if (!string.IsNullOrEmpty(log.TargetType))
                        {
                            <span>@log.TargetType</span>
                            @if (log.TargetId.HasValue)
                            {
                                <span>#@log.TargetId</span>
                            }
                        }
                    </td>
                    <td>@log.Details</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        No activity logs available.
    </div>
}

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">Back to Dashboard</a>
</div>
