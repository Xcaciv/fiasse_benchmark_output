@model ImportViewModel
@{
    ViewData["Title"] = "Import Notes";
}

<div class="row">
    <div class="col-md-6">
        <h2 class="mb-4">Import Notes</h2>
        <p class="text-muted">Upload a ZIP archive previously exported from LooseNotes.</p>

        <form asp-action="Import" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="ZipFile" class="form-label">ZIP Archive</label>
                <input asp-for="ZipFile" type="file" class="form-control" accept=".zip" />
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Import</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
