<h2>Edit Note</h2>
<%- include('../partials/errors', { errors }) %>
<form method="POST" action="/notes/<%= note.id %>/edit">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <div class="mb-3">
    <label class="form-label">Title</label>
    <input type="text" name="title" class="form-control" value="<%= note.title %>" maxlength="255" required>
  </div>
  <div class="mb-3">
    <label class="form-label">Content</label>
    <textarea name="content" class="form-control" rows="10" required><%= note.content %></textarea>
  </div>
  <div class="mb-3 form-check">
    <input type="checkbox" name="isPublic" class="form-check-input" id="isPublic" <%= note.isPublic ? 'checked' : '' %>>
    <label class="form-check-label" for="isPublic">Make Public</label>
  </div>
  <button type="submit" class="btn btn-primary">Save Changes</button>
  <a href="/notes/<%= note.id %>" class="btn btn-secondary ms-2">Cancel</a>
</form>

<hr>
<h4>Attachments</h4>
<% if (attachments && attachments.length > 0) { %>
  <ul class="list-group mb-3">
    <% attachments.forEach(att => { %>
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <%= att.originalFilename %> (<%= (att.fileSizeBytes / 1024).toFixed(1) %> KB)
        <div>
          <a href="/attachments/<%= att.id %>/download" class="btn btn-sm btn-outline-secondary">Download</a>
          <form method="POST" action="/attachments/<%= att.id %>/delete" class="d-inline">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
          </form>
        </div>
      </li>
    <% }) %>
  </ul>
<% } else { %>
  <p class="text-muted">No attachments.</p>
<% } %>

<h5>Upload Attachment</h5>
<form method="POST" action="/notes/<%= note.id %>/attachments" enctype="multipart/form-data">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <div class="mb-3">
    <input type="file" name="attachment" class="form-control" accept=".pdf,.doc,.docx,.txt,.png,.jpg,.jpeg">
  </div>
  <button type="submit" class="btn btn-outline-primary">Upload</button>
</form>
