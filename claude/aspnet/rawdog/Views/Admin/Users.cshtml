@model AdminUsersViewModel
@{
    ViewData["Title"] = "Users";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Users</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Dashboard</a>
</div>

<form asp-action="Users" method="get" class="mb-3">
    <div class="input-group" style="max-width: 400px;">
        <input type="text" name="q" value="@Model.SearchQuery" class="form-control" placeholder="Search by username or email..." />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Username</th>
            <th>Email</th>
            <th>Registered</th>
            <th>Notes</th>
            <th>Role</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td>@user.Username</td>
                <td>@user.Email</td>
                <td>@user.CreatedAt.ToString("MMM d, yyyy")</td>
                <td>@user.NoteCount</td>
                <td>@(user.IsAdmin ? "Admin" : "User")</td>
                <td>
                    <!-- No note reassign link here; notes are per-note -->
                </td>
            </tr>
        }
    </tbody>
</table>
