@{
    ViewData["Title"] = "Check Your Email";
}
<div class="row justify-content-center">
    <div class="col-md-6 text-center py-5">
        <h2>Check Your Email</h2>
        <!-- Generic confirmation — does not reveal whether the email exists (Confidentiality) -->
        <p>If an account exists for that email address, a password reset link has been sent. Please check your inbox.</p>
        <a asp-action="Login" class="btn btn-primary">Return to Login</a>
    </div>
</div>
