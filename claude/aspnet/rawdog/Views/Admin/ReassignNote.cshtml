@model ReassignNoteViewModel
@{
    ViewData["Title"] = "Reassign Note";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Reassign Note Ownership</h2>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">&larr; Dashboard</a>
</div>

@if (ViewBag.Success != null)
{
    <div class="alert alert-success">@ViewBag.Success</div>
}

<div class="row">
    <div class="col-md-6">
        <form asp-action="ReassignNote" method="post">
            <div class="mb-3">
                <label class="form-label">Note ID</label>
                <input type="number" name="noteId" value="@Model.NoteId" class="form-control" placeholder="Enter note ID" />
            </div>

            @if (Model.Note != null)
            {
                <div class="alert alert-info">
                    <strong>Note:</strong> @Html.Raw(Model.Note.Title)
                </div>
            }

            <div class="mb-3">
                <label class="form-label">Transfer Ownership To</label>
                <select name="targetUserId" class="form-select">
                    <option value="">-- Select user --</option>
                    @foreach (var user in Model.Users)
                    {
                        if (user.Id == Model.TargetUserId)
                        {
                            <option value="@user.Id" selected>@user.Username (@user.Email)</option>
                        }
                        else
                        {
                            <option value="@user.Id">@user.Username (@user.Email)</option>
                        }
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-warning">Reassign Ownership</button>
        </form>
    </div>
</div>
