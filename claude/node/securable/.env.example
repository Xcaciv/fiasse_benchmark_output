# Application
NODE_ENV=development
PORT=3000

# Session — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace-with-64-byte-random-hex-string

# Database (SQLite path or PostgreSQL/MySQL connection string)
DB_PATH=./data/loosenotes.sqlite

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Email (logging stub used when SMTP not configured)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@loosenotes.local

# Password Reset Token TTL (seconds)
RESET_TOKEN_TTL_SECONDS=3600

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10
