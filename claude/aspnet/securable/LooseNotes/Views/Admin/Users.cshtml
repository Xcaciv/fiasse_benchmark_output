@model LooseNotes.ViewModels.Admin.UserListViewModel
@{
    ViewData["Title"] = "Manage Users";
}

<h2>Users</h2>

<form asp-action="Users" method="get" class="mb-4">
    <div class="input-group" style="max-width:400px">
        <input type="search" name="q" value="@Model.SearchQuery"
               class="form-control" placeholder="Search by username or email…" />
        <button type="submit" class="btn btn-outline-secondary">Search</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Role</th>
                <th>Notes</th>
                <th>Registered</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model.Users)
            {
                <tr>
                    <td>@u.UserName</td>
                    <td>@u.Email</td>
                    <td>@(u.IsAdmin ? "Admin" : "User")</td>
                    <td>@u.NoteCount</td>
                    <td>@u.CreatedAt.ToString("d")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
