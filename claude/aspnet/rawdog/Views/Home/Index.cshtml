@{
    ViewData["Title"] = "Home";
}

<div class="text-center py-5">
    <h1 class="display-4 fw-bold">LooseNotes</h1>
    <p class="lead text-muted">Create, share, and discover notes with the community.</p>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <div class="mt-4">
            <a asp-controller="Notes" asp-action="Create" class="btn btn-primary btn-lg me-2">New Note</a>
            <a asp-controller="Notes" asp-action="Index" class="btn btn-outline-secondary btn-lg me-2">My Notes</a>
            <a asp-controller="Notes" asp-action="TopRated" class="btn btn-outline-secondary btn-lg">Top Rated</a>
        </div>
    }
    else
    {
        <div class="mt-4">
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg me-2">Get Started</a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-lg">Login</a>
        </div>
    }
</div>

<div class="row mt-4 g-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <h5 class="card-title">Create Notes</h5>
                <p class="card-text text-muted">Write and organise rich-text notes with file attachments.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <h5 class="card-title">Share & Collaborate</h5>
                <p class="card-text text-muted">Generate share links and allow anyone to view your notes.</p>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body text-center">
                <h5 class="card-title">Rate & Discover</h5>
                <p class="card-text text-muted">Rate community notes and explore top-rated content.</p>
            </div>
        </div>
    </div>
</div>
