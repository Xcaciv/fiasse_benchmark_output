@model NoteSearchViewModel
@{
    ViewData["Title"] = "Search Notes";
}

<h2 class="mb-4">Search Notes</h2>

<form asp-action="Search" method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="keyword" value="@Model.Keyword" class="form-control" placeholder="Search notes..." />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@if (!string.IsNullOrEmpty(Model.Keyword))
{
    <p class="text-muted">Results for: <strong>@Model.Keyword</strong></p>

    @if (!Model.Results.Any())
    {
        <p>No results found.</p>
    }
    else
    {
        <div class="row g-3">
            @foreach (var note in Model.Results)
            {
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-body">
                            @* Raw rendering (§6) *@
                            <h5 class="card-title">@Html.Raw(note.Title)</h5>
                            <p class="card-text text-muted">
                                @Html.Raw(note.Content.Length > 150 ? note.Content[..150] + "..." : note.Content)
                            </p>
                            <a asp-action="Details" asp-route-id="@note.Id" class="btn btn-sm btn-outline-primary">View</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
