<%- include('../partials/header') %>
<h2 class="mb-4">Admin Dashboard</h2>
<div class="row mb-4">
  <div class="col-md-3">
    <div class="card text-white bg-primary">
      <div class="card-body text-center">
        <h3><%= userCount %></h3>
        <p class="mb-0">Total Users</p>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card text-white bg-success">
      <div class="card-body text-center">
        <h3><%= noteCount %></h3>
        <p class="mb-0">Total Notes</p>
      </div>
    </div>
  </div>
</div>
<div class="d-flex justify-content-between mb-2">
  <h4>Recent Activity</h4>
  <a href="/admin/users" class="btn btn-sm btn-outline-primary">Manage Users</a>
</div>
<div class="table-responsive">
  <table class="table table-sm table-hover">
    <thead class="table-light">
      <tr><th>Time</th><th>User</th><th>Action</th><th>Target</th></tr>
    </thead>
    <tbody>
      <% recentLogs.forEach(function(log) { %>
        <tr>
          <td><small><%= log.createdAt.toLocaleString() %></small></td>
          <td><small><%= log.actor ? log.actor.username : '(system)' %></small></td>
          <td><code><%= log.action %></code></td>
          <td><small><%= log.targetType ? log.targetType + ':' + log.targetId : '—' %></small></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
<%- include('../partials/footer') %>
