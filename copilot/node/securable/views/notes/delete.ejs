<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="card border-danger shadow-sm">
      <div class="card-body p-4">
        <h1 class="h3 text-danger mb-3">Delete note</h1>
        <p>You are about to permanently delete <strong><%= note.title %></strong>.</p>
        <p class="text-body-secondary">This removes the note, its attachments, all ratings, and any generated share links.</p>

        <form method="post" action="/notes/<%= note.id %>/delete" class="d-flex gap-2">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button class="btn btn-danger" type="submit">Delete permanently</button>
          <a class="btn btn-outline-secondary" href="/notes/<%= note.id %>">Cancel</a>
        </form>
      </div>
    </div>
  </div>
</div>
