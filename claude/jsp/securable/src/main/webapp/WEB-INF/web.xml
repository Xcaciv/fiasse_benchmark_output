<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

  <display-name>Loose Notes</display-name>

  <!-- ─────────────────────────────────────────────
       CONTEXT PARAMETERS
       ───────────────────────────────────────────── -->
  <context-param>
    <param-name>uploadMaxSizeMB</param-name>
    <param-value>10</param-value>
  </context-param>

  <!-- ─────────────────────────────────────────────
       FILTERS  (order matters: headers → CSRF → auth)
       ───────────────────────────────────────────── -->
  <filter>
    <filter-name>SecurityHeadersFilter</filter-name>
    <filter-class>com.loosenotes.filter.SecurityHeadersFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>SecurityHeadersFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <filter>
    <filter-name>CsrfFilter</filter-name>
    <filter-class>com.loosenotes.filter.CsrfFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>CsrfFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <filter>
    <filter-name>AuthenticationFilter</filter-name>
    <filter-class>com.loosenotes.filter.AuthenticationFilter</filter-class>
  </filter>
  <filter-mapping>
    <filter-name>AuthenticationFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <!-- ─────────────────────────────────────────────
       SERVLETS
       ───────────────────────────────────────────── -->
  <servlet>
    <servlet-name>HomeServlet</servlet-name>
    <servlet-class>com.loosenotes.servlet.HomeServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>HomeServlet</servlet-name>
    <url-pattern>/home</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>RegisterServlet</servlet-name>
    <servlet-class>com.loosenotes.servlet.RegisterServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>RegisterServlet</servlet-name>
    <url-pattern>/register</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>com.loosenotes.servlet.LoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>com.loosenotes.servlet.LogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>PasswordResetServlet</servlet-name>
    <servlet-class>com.loosenotes.servlet.PasswordResetServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>PasswordResetServlet</servlet-name>
    <url-pattern>/password-reset</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>NoteCreateServlet</servlet-name>
    <servlet-class>com.loosenotes.servlet.NoteCreateServlet</servlet-class>
    <multipart-config>
      <max-file-size>10485760</max-file-size>
      <max-request-size>20971520</max-request-size>
      <file-size-threshold>1048576</file-size-threshold>
    </multipart-config>
  </servlet>
  <servlet-mapping>
    <servlet-name>NoteCreateServlet</servlet-name>
    <url-pattern>/notes/create</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>NoteViewServlet</servlet-name>
    <servlet-class>com.loosenotes.servlet.NoteViewServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>NoteViewServlet</servlet-name>
    <url-pattern>/notes/view</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>NoteEditServlet</servlet-name>
    <servlet-class>com.loosenotes.servlet.NoteEditServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>NoteEditServlet</servlet-name>
    <url-pattern>/notes/edit</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>NoteDeleteServlet</servlet-name>
    <servlet-class>com.loosenotes.servlet.NoteDeleteServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>NoteDeleteServlet</servlet-name>
    <url-pattern>/notes/delete</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AttachmentServlet</servlet-name>
    <servlet-class>com.loosenotes.servlet.AttachmentServlet</servlet-class>
    <multipart-config>
      <max-file-size>10485760</max-file-size>
      <max-request-size>20971520</max-request-size>
      <file-size-threshold>1048576</file-size-threshold>
    </multipart-config>
  </servlet>
  <servlet-mapping>
    <servlet-name>AttachmentServlet</servlet-name>
    <url-pattern>/attachments/*</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ShareServlet</servlet-name>
    <servlet-class>com.loosenotes.servlet.ShareServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ShareServlet</servlet-name>
    <url-pattern>/share/*</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>RatingServlet</servlet-name>
    <servlet-class>com.loosenotes.servlet.RatingServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>RatingServlet</servlet-name>
    <url-pattern>/ratings/*</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>SearchServlet</servlet-name>
    <servlet-class>com.loosenotes.servlet.SearchServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>SearchServlet</servlet-name>
    <url-pattern>/search</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>TopRatedServlet</servlet-name>
    <servlet-class>com.loosenotes.servlet.TopRatedServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>TopRatedServlet</servlet-name>
    <url-pattern>/top-rated</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>ProfileServlet</servlet-name>
    <servlet-class>com.loosenotes.servlet.ProfileServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>ProfileServlet</servlet-name>
    <url-pattern>/profile</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AdminServlet</servlet-name>
    <servlet-class>com.loosenotes.servlet.AdminServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AdminServlet</servlet-name>
    <url-pattern>/admin/*</url-pattern>
  </servlet-mapping>

  <!-- ─────────────────────────────────────────────
       SESSION CONFIGURATION
       ───────────────────────────────────────────── -->
  <session-config>
    <session-timeout>30</session-timeout>
    <cookie-config>
      <http-only>true</http-only>
      <secure>false</secure><!-- set to true behind HTTPS -->
    </cookie-config>
    <tracking-mode>COOKIE</tracking-mode>
  </session-config>

  <!-- ─────────────────────────────────────────────
       ERROR PAGES (no stack traces to client)
       ───────────────────────────────────────────── -->
  <error-page>
    <error-code>400</error-code>
    <location>/error.jsp</location>
  </error-page>
  <error-page>
    <error-code>403</error-code>
    <location>/error.jsp</location>
  </error-page>
  <error-page>
    <error-code>404</error-code>
    <location>/error.jsp</location>
  </error-page>
  <error-page>
    <error-code>500</error-code>
    <location>/error.jsp</location>
  </error-page>
  <error-page>
    <exception-type>java.lang.Exception</exception-type>
    <location>/error.jsp</location>
  </error-page>

  <!-- ─────────────────────────────────────────────
       WELCOME FILES
       ───────────────────────────────────────────── -->
  <welcome-file-list>
    <welcome-file>index.jsp</welcome-file>
  </welcome-file-list>
</web-app>
