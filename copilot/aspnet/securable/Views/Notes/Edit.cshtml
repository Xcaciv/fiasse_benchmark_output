@model NoteEditViewModel
@{
    ViewData["Title"] = "Edit Note";
}
<div class="row justify-content-center">
    <div class="col-md-8">
        <h2 class="mb-4">Edit Note</h2>
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" maxlength="200" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Content" class="form-label"></label>
                <textarea asp-for="Content" class="form-control" rows="10" maxlength="10000"></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsPublic" class="form-check-input" />
                <label asp-for="IsPublic" class="form-check-label">Make Public</label>
            </div>
            <div class="mb-3">
                <label asp-for="NewAttachments" class="form-label">
                    Add Attachments <small class="text-muted">(PDF, DOC, DOCX, TXT, PNG, JPG, JPEG — max 10 MB)</small>
                </label>
                <input asp-for="NewAttachments" class="form-control" type="file" multiple
                       accept=".pdf,.doc,.docx,.txt,.png,.jpg,.jpeg" />
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScripts"); } }
