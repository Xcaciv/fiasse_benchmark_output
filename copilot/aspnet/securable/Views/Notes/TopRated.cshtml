@model NoteListViewModel
@{
    ViewData["Title"] = "Top Rated Notes";
}
<h2 class="mb-4">Top Rated Notes</h2>
<p class="text-muted">Public notes with at least 3 ratings, sorted by average rating.</p>

@if (!Model.Notes.Any())
{
    <p class="text-center text-muted py-4">No top-rated notes yet. Be the first to rate some!</p>
}
else
{
    <div class="row g-3">
        @foreach (var note in Model.Notes)
        {
            var avg = note.Ratings.Any() ? note.Ratings.Average(r => r.Stars) : 0;
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <a asp-action="Details" asp-route-id="@note.Id" class="text-decoration-none">
                                @note.Title
                            </a>
                        </h5>
                        <p class="card-text text-muted small">
                            @(note.Content.Length > 100 ? note.Content[..100] + "…" : note.Content)
                        </p>
                        <small class="text-muted">By @(note.User?.UserName ?? "Unknown")</small>
                    </div>
                    <div class="card-footer d-flex justify-content-between">
                        <span>⭐ @Math.Round(avg, 1) / 5</span>
                        <small class="text-muted">@note.Ratings.Count rating(s)</small>
                    </div>
                </div>
            </div>
        }
    </div>
}
