<%
function renderStars(avg) {
  if (!avg) return '<span class="text-muted">No ratings</span>';
  let stars = '';
  for (let i = 1; i <= 5; i++) {
    stars += i <= Math.round(avg) ? '<span class="star">★</span>' : '<span class="star-empty">★</span>';
  }
  return stars + ` <small class="text-muted">(${avg})</small>`;
}
%>
<div class="row">
  <div class="col-md-8">
    <div class="card shadow-sm mb-4">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start mb-3">
          <div>
            <h2 class="mb-1"><%= note.title %></h2>
            <small class="text-muted">
              By <%= note.User ? note.User.username : 'Unknown' %> &middot;
              <%= new Date(note.createdAt).toLocaleString() %> &middot;
              <span class="badge bg-<%= note.visibility === 'public' ? 'success' : 'secondary' %>"><%= note.visibility %></span>
            </small>
          </div>
          <% if (isOwner) { %>
            <div class="d-flex gap-2 flex-shrink-0 ms-3">
              <a href="/notes/<%= note.id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
              <form action="/notes/<%= note.id %>/delete" method="POST" onsubmit="return confirm('Delete this note?')">
                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
              </form>
            </div>
          <% } %>
        </div>

        <hr>
        <div style="white-space: pre-wrap;"><%= note.content %></div>
      </div>
    </div>

    <!-- Attachments -->
    <div class="card shadow-sm mb-4">
      <div class="card-header"><strong>Attachments</strong></div>
      <ul class="list-group list-group-flush">
        <% if (note.Attachments && note.Attachments.length > 0) { %>
          <% note.Attachments.forEach(att => { %>
            <li class="list-group-item d-flex justify-content-between align-items-center">
              <a href="/notes/<%= note.id %>/attachments/<%= att.id %>/download" class="text-decoration-none">
                📎 <%= att.originalName %>
                <small class="text-muted">(<%= (att.size / 1024).toFixed(1) %> KB)</small>
              </a>
              <% if (isOwner) { %>
                <form action="/notes/<%= note.id %>/attachments/<%= att.id %>/delete" method="POST"
                      onsubmit="return confirm('Delete attachment?')" class="ms-2">
                  <button type="submit" class="btn btn-sm btn-outline-danger">✕</button>
                </form>
              <% } %>
            </li>
          <% }) %>
        <% } else { %>
          <li class="list-group-item text-muted">No attachments.</li>
        <% } %>
      </ul>
      <% if (isOwner) { %>
        <div class="card-footer">
          <form action="/notes/<%= note.id %>/attachments" method="POST" enctype="multipart/form-data" class="d-flex gap-2">
            <input type="file" name="file" class="form-control form-control-sm" accept=".pdf,.doc,.docx,.txt,.png,.jpg,.jpeg">
            <button type="submit" class="btn btn-sm btn-primary">Upload</button>
          </form>
          <small class="text-muted">Allowed: PDF, DOC, DOCX, TXT, PNG, JPG. Max 10MB.</small>
        </div>
      <% } %>
    </div>

    <!-- Ratings -->
    <div class="card shadow-sm mb-4">
      <div class="card-header d-flex justify-content-between">
        <strong>Ratings</strong>
        <span><%- renderStars(avgRating) %> &middot; <%= note.Ratings ? note.Ratings.length : 0 %> review(s)</span>
      </div>
      <% if (note.Ratings && note.Ratings.length > 0) { %>
        <ul class="list-group list-group-flush">
          <% note.Ratings.forEach(r => { %>
            <li class="list-group-item">
              <div class="d-flex justify-content-between">
                <strong><%= r.User ? r.User.username : 'User' %></strong>
                <span>
                  <% for(let i=1;i<=5;i++) { %><span class="<%= i<=r.value?'star':'star-empty' %>">★</span><% } %>
                </span>
              </div>
              <% if (r.comment) { %><p class="mb-0 text-muted small"><%= r.comment %></p><% } %>
            </li>
          <% }) %>
        </ul>
      <% } else { %>
        <div class="card-body text-muted">No ratings yet.</div>
      <% } %>
      <% if (locals.currentUser && locals.currentUser.id !== note.userId) { %>
        <div class="card-footer">
          <form action="/notes/<%= note.id %>/ratings" method="POST">
            <div class="row g-2 align-items-end">
              <div class="col-auto">
                <label class="form-label">Your Rating</label>
                <select name="value" class="form-select form-select-sm" required>
                  <option value="">—</option>
                  <% for(let i=1;i<=5;i++) { %><option value="<%= i %>" <%= userRating && userRating.value===i ? 'selected' : '' %>><%= i %> ★</option><% } %>
                </select>
              </div>
              <div class="col">
                <label class="form-label">Comment (optional)</label>
                <input type="text" name="comment" class="form-control form-control-sm" value="<%= userRating ? userRating.comment || '' : '' %>">
              </div>
              <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary"><%= userRating ? 'Update' : 'Submit' %></button>
              </div>
            </div>
          </form>
        </div>
      <% } %>
    </div>
  </div>

  <!-- Sidebar -->
  <div class="col-md-4">
    <% if (isOwner) { %>
      <div class="card shadow-sm mb-3">
        <div class="card-header"><strong>Share Link</strong></div>
        <div class="card-body">
          <% if (note.ShareLink) { %>
            <div class="mb-2">
              <input type="text" class="form-control form-control-sm"
                     value="<%= (process.env.BASE_URL || 'http://localhost:3000') + '/share/' + note.ShareLink.token %>"
                     readonly onclick="this.select()">
            </div>
            <div class="d-flex gap-2">
              <form action="/notes/<%= note.id %>/share" method="POST">
                <button type="submit" class="btn btn-sm btn-outline-secondary">Regenerate</button>
              </form>
              <form action="/notes/<%= note.id %>/share/revoke" method="POST">
                <button type="submit" class="btn btn-sm btn-outline-danger">Revoke</button>
              </form>
            </div>
          <% } else { %>
            <form action="/notes/<%= note.id %>/share" method="POST">
              <button type="submit" class="btn btn-sm btn-primary w-100">Generate Share Link</button>
            </form>
          <% } %>
        </div>
      </div>
    <% } %>
  </div>
</div>
