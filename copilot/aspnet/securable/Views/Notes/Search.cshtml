@model List<NoteListItemViewModel>
@{
    ViewData["Title"] = "Search Notes";
    var query = ViewBag.Query as string;
}
<h2>Search Notes</h2>
<form asp-action="Search" method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="q" value="@query" class="form-control" placeholder="Search by title or content..." maxlength="200" />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>
@if (query != null)
{
    if (!Model.Any())
    {
        <p class="text-muted">No notes found for "@query".</p>
    }
    else
    {
        <p class="text-muted">@Model.Count result(s) for "@query"</p>
        @foreach (var note in Model)
        {
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">
                        <a asp-controller="Notes" asp-action="Detail" asp-route-id="@note.Id">@note.Title</a>
                    </h5>
                    <p class="card-text text-muted small">@note.Excerpt</p>
                    <span class="text-muted small">By @note.AuthorName &middot; @note.CreatedAt.ToString("MMM dd, yyyy")</span>
                </div>
            </div>
        }
    }
}
