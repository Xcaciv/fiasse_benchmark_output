@model Note
@{
    ViewData["Title"] = "Delete Note";
}

<h2 class="text-danger">Delete Note</h2>
<p>Are you sure you want to delete <strong>@Model.Title</strong>? This action cannot be undone.</p>
<p class="text-muted">All attachments, ratings, and share links will be permanently removed.</p>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary ms-2">Cancel</a>
</form>
