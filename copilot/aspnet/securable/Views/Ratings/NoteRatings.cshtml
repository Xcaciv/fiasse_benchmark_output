@model IEnumerable<LooseNotes.Models.Rating>
@{
    ViewData["Title"] = "Note Ratings";
    var noteTitle = ViewBag.NoteTitle as string;
    var noteId = (int)ViewBag.NoteId;
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Ratings for "@noteTitle"</h2>
    <a asp-controller="Notes" asp-action="Details" asp-route-id="@noteId"
       class="btn btn-outline-secondary">← Back to Note</a>
</div>

@if (!Model.Any())
{
    <p class="text-muted">No ratings yet.</p>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Stars</th>
                    <th>Comment</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>@(r.User?.UserName ?? "Unknown")</td>
                        <td>@r.Stars ⭐</td>
                        <td>@(r.Comment ?? "—")</td>
                        <td>@r.CreatedAt.ToString("MMM d, yyyy")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
