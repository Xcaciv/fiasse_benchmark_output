<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card shadow-sm border-danger">
      <div class="card-header bg-danger text-white">
        <h4 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Deletion</h4>
      </div>
      <div class="card-body p-4">
        <p class="mb-3">
          Are you sure you want to permanently delete the following note? This action <strong>cannot be undone</strong>.
        </p>

        <div class="alert alert-warning">
          <h5 class="alert-heading mb-1"><i class="bi bi-journal-text me-2"></i><%= note.title %></h5>
          <p class="mb-2 small text-muted">
            <%= note.content.substring(0, 150) %><%= note.content.length > 150 ? '...' : '' %>
          </p>
          <hr>
          <p class="mb-0 small">
            <strong>This will also permanently delete:</strong>
            all attachments, ratings, and share links associated with this note.
          </p>
        </div>

        <div class="d-flex gap-2 justify-content-end">
          <a href="/notes/<%= note.id %>" class="btn btn-outline-secondary">
            <i class="bi bi-x-circle me-2"></i>Cancel
          </a>
          <form action="/notes/<%= note.id %>/delete" method="POST">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button type="submit" class="btn btn-danger">
              <i class="bi bi-trash me-2"></i>Yes, Delete Permanently
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
