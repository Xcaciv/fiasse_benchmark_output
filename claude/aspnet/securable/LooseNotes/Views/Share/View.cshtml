@model LooseNotes.Models.Note
@{
    ViewData["Title"] = Model.Title + " (Shared)";
    Layout = "_Layout";
}

<div class="alert alert-info d-flex align-items-center mb-4" role="alert">
    <span>🔗 This note is being viewed via a share link.</span>
    <a asp-controller="Account" asp-action="Register" class="btn btn-sm btn-outline-primary ms-auto">
        Create Your Own Notes
    </a>
</div>

<h2>@Model.Title</h2>
<small class="text-muted">
    By <strong>@Model.User?.UserName</strong> ·
    @Model.CreatedAt.ToString("MMM d, yyyy")
</small>

<div class="card mt-3 mb-4">
    <div class="card-body">
        <pre class="mb-0" style="white-space: pre-wrap; font-family: inherit;">@Model.Content</pre>
    </div>
</div>

@if (Model.Attachments.Any())
{
    <h5>Attachments</h5>
    <ul class="list-group mb-4">
        @foreach (var att in Model.Attachments)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>📎 @att.OriginalFileName</span>
                <a asp-controller="Attachments" asp-action="Download" asp-route-id="@att.Id"
                   class="btn btn-sm btn-outline-secondary">Download</a>
            </li>
        }
    </ul>
}
