<div class="row justify-content-center">
  <div class="col-md-6">
    <h2 class="mb-4">Delete Note</h2>
    <div class="alert alert-danger">
      <strong>Warning:</strong> This will permanently delete the note "<em>{{note.title}}</em>",
      all its attachments, ratings, and share links. This cannot be undone.
    </div>
    <form action="/notes/{{note.id}}/delete" method="POST">
      <input type="hidden" name="_csrf" value="{{csrfToken}}">
      <button type="submit" class="btn btn-danger">Delete Note</button>
      <a href="/notes/{{note.id}}" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
  </div>
</div>
