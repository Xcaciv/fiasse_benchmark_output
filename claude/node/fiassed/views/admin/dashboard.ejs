<div class="page-header">
  <h1>Admin Dashboard</h1>
</div>

<div class="stats-grid">
  <div class="stat-card">
    <h3>Total Users</h3>
    <p class="stat-value"><%= stats.userCount %></p>
    <a href="/admin/users" class="btn btn-sm btn-secondary">Manage Users</a>
  </div>
  <div class="stat-card">
    <h3>Total Notes</h3>
    <p class="stat-value"><%= stats.noteCount %></p>
  </div>
</div>

<div class="audit-log-section">
  <h2>Recent Activity</h2>
  <% if (stats.recentAudit && stats.recentAudit.length > 0) { %>
    <div class="audit-table-wrapper">
      <table class="audit-table">
        <thead>
          <tr>
            <th>Time</th>
            <th>Event</th>
            <th>Actor</th>
            <th>Target</th>
            <th>Outcome</th>
            <th>IP</th>
          </tr>
        </thead>
        <tbody>
          <% stats.recentAudit.forEach(function(entry) { %>
            <tr class="outcome-<%= entry.outcome %>">
              <td><%= new Date(entry.createdAt).toISOString().replace('T', ' ').slice(0, 19) %></td>
              <td><code><%= entry.event %></code></td>
              <td><small><%= entry.actorId ? entry.actorId.slice(0, 8) + '...' : 'anon' %></small></td>
              <td><small><%= entry.targetId ? entry.targetId.slice(0, 8) + '...' : '-' %></small></td>
              <td><span class="badge badge-<%= entry.outcome %>"><%= entry.outcome %></span></td>
              <td><small><%= entry.ip || '-' %></small></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } else { %>
    <p>No audit log entries yet.</p>
  <% } %>
</div>
