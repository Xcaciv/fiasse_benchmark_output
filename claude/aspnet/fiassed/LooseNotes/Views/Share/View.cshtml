@model LooseNotes.ShareController.SharedNoteViewModel
@{
    ViewData["Title"] = Html.Encode(Model.Title);
    Layout = "_Layout";
}
<div class="shared-note">
    <div class="shared-note-header">
        <!-- No user email, user ID, or session data exposed (Confidentiality, ASVS V8.2.2) -->
        <h2>@Html.Encode(Model.Title)</h2>
        <p class="shared-badge">Shared Note</p>
    </div>
    <div class="note-meta">
        <span>Created @Model.CreatedAt.ToString("MMM d, yyyy")</span>
        <span>Updated @Model.UpdatedAt.ToString("MMM d, yyyy")</span>
    </div>
    <!-- Content encoded by Razor default encoding (GSR-07) -->
    <div class="note-content">@Model.Content</div>

    @if (Model.Attachments.Any())
    {
        <section class="attachments">
            <h3>Attachments</h3>
            <ul>
                @foreach (var a in Model.Attachments)
                {
                    <li>
                        <a asp-controller="Share" asp-action="DownloadAttachment"
                           asp-route-attachmentId="@a.Id"
                           asp-route-token="@Model.ShareToken">
                            @Html.Encode(a.OriginalFileName)
                        </a>
                        <span class="file-size">(@(a.FileSizeBytes / 1024) KB)</span>
                    </li>
                }
            </ul>
        </section>
    }
</div>
