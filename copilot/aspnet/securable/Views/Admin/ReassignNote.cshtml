@model ReassignNoteViewModel
@{
    ViewData["Title"] = "Reassign Note";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <h2 class="mb-4">Reassign Note</h2>

        <dl class="row mb-4">
            <dt class="col-sm-4">Note Title</dt>
            <dd class="col-sm-8">@Model.NoteTitle</dd>
            <dt class="col-sm-4">Current Owner</dt>
            <dd class="col-sm-8">@Model.CurrentOwnerName</dd>
        </dl>

        <form asp-action="ReassignNote" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="NoteId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="NewOwnerId" class="form-label">New Owner</label>
                <select asp-for="NewOwnerId" class="form-select"
                        asp-items="@(new SelectList(Model.AvailableUsers, "Id", "UserName"))">
                    <option value="">— Select new owner —</option>
                </select>
                <span asp-validation-for="NewOwnerId" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning"
                        onclick="return confirm('Reassign this note?')">Reassign</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScripts"); } }
