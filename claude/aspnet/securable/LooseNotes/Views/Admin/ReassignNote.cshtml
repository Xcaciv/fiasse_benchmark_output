@model ReassignNoteViewModel
@{
    ViewData["Title"] = "Reassign Note";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <h2>Reassign Note</h2>
        <dl class="mb-4">
            <dt>Note</dt>
            <dd>@Model.NoteTitle</dd>
            <dt>Current Owner</dt>
            <dd>@Model.CurrentOwnerUserName</dd>
        </dl>
        <form asp-action="ReassignNote" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <input asp-for="NoteId" type="hidden" />
            <div class="mb-3">
                <label asp-for="NewOwnerId" class="form-label">New Owner</label>
                <select asp-for="NewOwnerId" class="form-select"
                        asp-items="@(new SelectList(Model.AllUsers, "Id", "UserName"))">
                    <option value="">-- Select User --</option>
                </select>
                <span asp-validation-for="NewOwnerId" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning">Reassign</button>
                <a asp-action="Dashboard" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { @await Html.PartialAsync("_ValidationScriptsPartial") }
