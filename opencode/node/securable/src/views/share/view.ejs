<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= note.title %> - Loose Notes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    .note-content { white-space: pre-wrap; word-wrap: break-word; }
    .rating-stars { color: #ffc107; }
  </style>
</head>
<body>
  <%- include ../partials/navbar %>
  <%- include ../partials/flash %>
  <main class="container py-4">
    <div class="row">
      <div class="col-lg-8">
        <div class="card mb-4">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <h1 class="h3 mb-0"><%= note.title %></h1>
              <span class="badge bg-success">Shared</span>
            </div>
            
            <div class="text-muted mb-3">
              By <strong><%= note.author_username %></strong>
              <% if (note.avg_rating) { %>
                <span class="ms-3">
                  <span class="rating-stars">
                    <%= '★'.repeat(Math.round(note.avg_rating)) %><%= '☆'.repeat(5 - Math.round(note.avg_rating)) %>
                  </span>
                  <small class="text-muted">(<%= note.rating_count %> rating<%= note.rating_count > 1 ? 's' : '' %>)</small>
                </span>
              <% } %>
            </div>
            
            <hr>
            
            <div class="note-content"><%= note.content %></div>
            
            <% if (attachments && attachments.length > 0) { %>
              <hr>
              <h5>Attachments</h5>
              <div class="list-group">
                <% attachments.forEach(function(att) { %>
                  <div class="list-group-item d-flex justify-content-between align-items-center">
                    <span>
                      <i class="bi bi-paperclip"></i> <%= att.original_filename %>
                      <small class="text-muted">(<%= (att.size / 1024).toFixed(1) %> KB)</small>
                    </span>
                    <a href="/notes/download/<%= att.id %>" class="btn btn-sm btn-outline-primary">Download</a>
                  </div>
                <% }); %>
              </div>
            <% } %>
          </div>
        </div>
        
        <% if (ratings && ratings.length > 0) { %>
          <div class="card">
            <div class="card-body">
              <h5>Ratings (<%= ratings.length %>)</h5>
              <% ratings.forEach(function(r) { %>
                <div class="border-bottom py-2">
                  <div class="d-flex justify-content-between">
                    <strong><%= r.username %></strong>
                    <span class="rating-stars"><%= '★'.repeat(r.value) %><%= '☆'.repeat(5 - r.value) %></span>
                  </div>
                  <% if (r.comment) { %><p class="mb-0 small"><%= r.comment %></p><% } %>
                  <small class="text-muted"><%= new Date(r.created_at).toLocaleDateString() %></small>
                </div>
              <% }); %>
            </div>
          </div>
        <% } %>
      </div>
      
      <div class="col-lg-4">
        <div class="card">
          <div class="card-body">
            <p class="mb-1"><small class="text-muted">Created</small></p>
            <p class="mb-2"><%= new Date(note.created_at).toLocaleString() %></p>
            
            <% if (note.updated_at !== note.created_at) { %>
              <p class="mb-1"><small class="text-muted">Updated</small></p>
              <p class="mb-0"><%= new Date(note.updated_at).toLocaleString() %></p>
            <% } %>
          </div>
        </div>
        
        <div class="card mt-3">
          <div class="card-body">
            <p class="mb-2"><small class="text-muted">Share this note</small></p>
            <code class="d-block small">/share/<%= shareToken %></code>
            <button class="btn btn-sm btn-outline-secondary mt-2" onclick="navigator.clipboard.writeText(window.location.href)">
              Copy Link
            </button>
          </div>
        </div>
      </div>
    </div>
  </main>
  <%- include ../partials/footer %>
</body>
</html>
