@model IEnumerable<LooseNotes.Models.Note>
@{
    ViewData["Title"] = "Search";
    var query = ViewBag.Query as string;
}
<h2>Search Notes</h2>
<form asp-action="Search" method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="q" value="@query" class="form-control" placeholder="Search notes..." />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@if (!string.IsNullOrEmpty(query))
{
    <p>Results for: <strong>@query</strong> (@Model.Count() found)</p>
    @if (!Model.Any())
    {
        <div class="alert alert-info">No notes found matching your search.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var note in Model)
            {
                <a asp-controller="Notes" asp-action="Details" asp-route-id="@note.Id" class="list-group-item list-group-item-action">
                    <div class="d-flex justify-content-between">
                        <h6 class="mb-1">@note.Title</h6>
                        <small class="text-muted">@note.CreatedAt.ToString("MMM d, yyyy")</small>
                    </div>
                    <p class="mb-1 small">@(note.Content.Length > 150 ? note.Content.Substring(0, 150) + "..." : note.Content)</p>
                    <small>by @note.User?.UserName · @(note.IsPublic ? "Public" : "Private")</small>
                </a>
            }
        </div>
    }
}
