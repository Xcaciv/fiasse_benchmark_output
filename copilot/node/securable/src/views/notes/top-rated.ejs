<h2>Top Rated Notes</h2>
<% if (!notes || notes.length === 0) { %>
  <p class="text-muted">No top-rated notes yet (requires at least 3 ratings).</p>
<% } else { %>
  <div class="list-group">
    <% notes.forEach(note => { %>
      <a href="/notes/<%= note.id %>" class="list-group-item list-group-item-action">
        <div class="d-flex justify-content-between">
          <h5 class="mb-1"><%= note.title %></h5>
          <span class="badge bg-warning text-dark"><%= parseFloat(note.dataValues.avgRating).toFixed(1) %> &#9733; (<%= note.dataValues.ratingCount %> ratings)</span>
        </div>
        <small class="text-muted">By <%= note.User ? note.User.username : 'Unknown' %></small>
      </a>
    <% }) %>
  </div>
<% } %>
