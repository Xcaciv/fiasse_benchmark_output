@model IEnumerable<Note>
@{
    ViewData["Title"] = "Export Notes";
}

<h2 class="mb-4">Export Notes</h2>

@if (!Model.Any())
{
    <p class="text-muted">No notes available to export.</p>
}
else
{
    <form asp-action="ExportPost" method="post">
        <div class="mb-3">
            <p class="text-muted">Select notes to include in the export archive:</p>
            @foreach (var note in Model)
            {
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="noteIds" value="@note.Id" id="note_@note.Id" />
                    <label class="form-check-label" for="note_@note.Id">
                        @Html.Raw(note.Title)
                        <small class="text-muted">(@note.Attachments.Count attachment(s))</small>
                    </label>
                </div>
            }
        </div>
        <button type="submit" class="btn btn-primary">Download ZIP</button>
        <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
    </form>
}
