{
  "ConnectionStrings": {
    // Replace with production connection string via environment variable or secrets manager
    "DefaultConnection": "Data Source=loosenotes.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "FileStorage": {
    // Absolute path or relative to content root; override via env var FileStorage__UploadPath
    "UploadPath": "uploads",
    "MaxFileSizeBytes": 10485760,
    "AllowedExtensions": [ ".pdf", ".doc", ".docx", ".txt", ".png", ".jpg", ".jpeg" ]
  },
  "Security": {
    // Token lifetime for password reset links (minutes)
    "PasswordResetTokenLifetimeMinutes": 60,
    // Share link tokens: cryptographically random, server-generated (Derived Integrity)
    "ShareTokenSizeBytes": 32
  },
  "RateLimiting": {
    "LoginWindowSeconds": 60,
    "LoginMaxAttempts": 10,
    "RegisterWindowSeconds": 60,
    "RegisterMaxAttempts": 5
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/loosenotes-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
