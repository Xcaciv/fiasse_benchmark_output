@model ReassignNoteViewModel
@{
    ViewData["Title"] = "Reassign Note";
}

<h2>Reassign Note</h2>
<dl class="row">
    <dt class="col-sm-3">Note</dt>
    <dd class="col-sm-9">@Model.NoteTitle</dd>
    <dt class="col-sm-3">Current Owner</dt>
    <dd class="col-sm-9">@Model.CurrentOwner</dd>
</dl>

<form asp-action="ReassignNote" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="NoteId" />
    <div asp-validation-summary="All" class="text-danger mb-3"></div>
    <div class="mb-3">
        <label asp-for="NewOwnerId" class="form-label">New Owner</label>
        <select asp-for="NewOwnerId" class="form-select">
            <option value="">-- Select User --</option>
            @foreach (var user in Model.Users)
            {
                <option value="@user.Id">@user.Username (@user.Email)</option>
            }
        </select>
        <span asp-validation-for="NewOwnerId" class="text-danger"></span>
    </div>
    <button type="submit" class="btn btn-primary">Reassign</button>
    <a asp-action="Index" class="btn btn-secondary ms-2">Cancel</a>
</form>
