<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>User Details - Loose Notes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include ../partials/navbar %>
  <%- include ../partials/flash %>
  <main class="container py-4">
    <div class="mb-3">
      <a href="/admin/users" class="text-decoration-none">&larr; Back to Users</a>
    </div>

    <h1 class="mb-4">User Details</h1>

    <div class="row">
      <div class="col-md-6 mb-4">
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0">User Information</h5>
          </div>
          <div class="card-body">
            <p><strong>ID:</strong> <%= targetUser.id %></p>
            <p><strong>Username:</strong> <%= targetUser.username %></p>
            <p><strong>Email:</strong> <%= targetUser.email %></p>
            <p><strong>Role:</strong> <span class="badge bg-<%= targetUser.role === 'admin' ? 'danger' : 'secondary' %>"><%= targetUser.role %></span></p>
            <p><strong>Joined:</strong> <%= new Date(targetUser.created_at).toLocaleString() %></p>
          </div>
        </div>
      </div>
      
      <div class="col-md-6 mb-4">
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0">Activity</h5>
          </div>
          <div class="card-body">
            <% if (activity && activity.length > 0) { %>
              <div class="list-group list-group-flush">
                <% activity.slice(0, 10).forEach(function(act) { %>
                  <div class="list-group-item px-0">
                    <small class="text-muted"><%= new Date(act.created_at).toLocaleString() %></small>
                    <br>
                    <strong><%= act.action %></strong>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <p class="text-muted">No activity recorded</p>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-header">
        <h5 class="mb-0">Notes (<%= notes ? notes.length : 0 %>)</h5>
      </div>
      <div class="card-body">
        <% if (notes && notes.length > 0) { %>
          <div class="list-group">
            <% notes.forEach(function(note) { %>
              <div class="list-group-item d-flex justify-content-between align-items-center">
                <div>
                  <strong><%= note.title %></strong>
                  <span class="badge bg-<%= note.is_public ? 'success' : 'secondary' %> ms-2">
                    <%= note.is_public ? 'Public' : 'Private' %>
                  </span>
                </div>
                <div>
                  <span class="text-muted me-3"><%= new Date(note.created_at).toLocaleDateString() %></span>
                  <a href="/notes/<%= note.id %>" class="btn btn-sm btn-outline-primary">View</a>
                </div>
              </div>
            <% }); %>
          </div>
        <% } else { %>
          <p class="text-muted mb-0">No notes created</p>
        <% } %>
      </div>
    </div>
  </main>
  <%- include ../partials/footer %>
</body>
</html>
