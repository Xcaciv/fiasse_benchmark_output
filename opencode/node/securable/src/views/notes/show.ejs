<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= note.title %> - Loose Notes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  <style>
    .note-content { white-space: pre-wrap; word-wrap: break-word; }
    .rating-stars { color: #ffc107; }
  </style>
</head>
<body>
  <%- include ../partials/navbar %>
  <%- include ../partials/flash %>
  <main class="container py-4">
    <div class="mb-3">
      <a href="/notes" class="text-decoration-none">&larr; Back to My Notes</a>
    </div>

    <div class="row">
      <div class="col-lg-8">
        <div class="card mb-4">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <h1 class="h3 mb-0"><%= note.title %></h1>
              <span class="badge bg-<%= note.is_public ? 'success' : 'secondary' %>">
                <%= note.is_public ? 'Public' : 'Private' %>
              </span>
            </div>
            
            <div class="text-muted mb-3">
              By <strong><%= note.author_username %></strong>
              <% if (note.avg_rating) { %>
                <span class="ms-3">
                  <span class="rating-stars">
                    <%= '★'.repeat(Math.round(note.avg_rating)) %><%= '☆'.repeat(5 - Math.round(note.avg_rating)) %>
                  </span>
                  <small class="text-muted">(<%= note.rating_count %> rating<%= note.rating_count > 1 ? 's' : '' %>)</small>
                </span>
              <% } %>
            </div>
            
            <hr>
            
            <div class="note-content"><%= note.content %></div>
            
            <% if (attachments && attachments.length > 0) { %>
              <hr>
              <h5>Attachments</h5>
              <div class="list-group">
                <% attachments.forEach(function(att) { %>
                  <div class="list-group-item d-flex justify-content-between align-items-center">
                    <span>
                      <i class="bi bi-paperclip"></i> <%= att.original_filename %>
                      <small class="text-muted">(<%= (att.size / 1024).toFixed(1) %> KB)</small>
                    </span>
                    <div>
                      <a href="/notes/download/<%= att.id %>" class="btn btn-sm btn-outline-primary">Download</a>
                      <% if (isOwner) { %>
                        <form action="/notes/<%= note.id %>/attachments/<%= att.id %>?_method=DELETE" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                        </form>
                      <% } %>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } %>
            
            <% if (isOwner) { %>
              <hr>
              <div class="d-flex gap-2">
                <a href="/notes/<%= note.id %>/edit" class="btn btn-outline-primary">
                  <i class="bi bi-pencil"></i> Edit
                </a>
                <a href="/notes/<%= note.id %>/share" class="btn btn-outline-success">
                  <i class="bi bi-share"></i> Share
                </a>
                <button type="button" class="btn btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
                  <i class="bi bi-trash"></i> Delete
                </button>
              </div>
            <% } %>
          </div>
        </div>
        
        <% if (user) { %>
          <div class="card mb-4">
            <div class="card-body">
              <h5>Rate this Note</h5>
              <form action="/notes/<%= note.id %>/rate" method="POST">
                <div class="mb-3">
                  <label class="form-label">Rating</label>
                  <div class="d-flex gap-2">
                    <% [1,2,3,4,5].forEach(function(v) { %>
                      <button type="submit" name="value" value="<%= v %>" class="btn btn-sm <%= userRating && userRating.value >= v ? 'btn-warning' : 'btn-outline-warning' %>">
                        <%= v %> ★
                      </button>
                    <% }); %>
                  </div>
                </div>
                <div class="mb-3">
                  <label for="comment" class="form-label">Comment (optional)</label>
                  <textarea class="form-control" id="comment" name="comment" rows="2"></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Submit Rating</button>
              </form>
            </div>
          </div>
        <% } %>
        
        <% if (ratings && ratings.length > 0) { %>
          <div class="card">
            <div class="card-body">
              <h5>Ratings (<%= ratings.length %>)</h5>
              <% ratings.forEach(function(r) { %>
                <div class="border-bottom py-2">
                  <div class="d-flex justify-content-between">
                    <strong><%= r.username %></strong>
                    <span class="rating-stars"><%= '★'.repeat(r.value) %><%= '☆'.repeat(5 - r.value) %></span>
                  </div>
                  <% if (r.comment) { %><p class="mb-0 small"><%= r.comment %></p><% } %>
                  <small class="text-muted"><%= new Date(r.created_at).toLocaleDateString() %></small>
                </div>
              <% }); %>
            </div>
          </div>
        <% } %>
      </div>
      
      <div class="col-lg-4">
        <div class="card">
          <div class="card-body">
            <small class="text-muted">Created</small>
            <p class="mb-2"><%= new Date(note.created_at).toLocaleString() %></p>
            
            <% if (note.updated_at !== note.created_at) { %>
              <small class="text-muted">Updated</small>
              <p class="mb-0"><%= new Date(note.updated_at).toLocaleString() %></p>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <% if (isOwner) { %>
      <div class="modal fade" id="deleteModal" tabindex="-1">
        <div class="modal-dialog">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title">Delete Note</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <p>Are you sure you want to delete this note? This action cannot be undone.</p>
              <p class="mb-0"><strong>All attachments, ratings, and share links will also be deleted.</strong></p>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <form action="/notes/<%= note.id %>?_method=DELETE" method="POST">
                <button type="submit" class="btn btn-danger">Delete Note</button>
              </form>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  </main>
  <%- include ../partials/footer %>
</body>
</html>
