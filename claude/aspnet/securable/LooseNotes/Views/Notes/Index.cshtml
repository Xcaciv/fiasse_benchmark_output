@model IReadOnlyList<NoteListItemViewModel>
@{
    ViewData["Title"] = "My Notes";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>My Notes</h2>
    <a asp-action="Create" class="btn btn-success">+ New Note</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">
        You have no notes yet. <a asp-action="Create">Create your first note.</a>
    </div>
}
else
{
    <div class="list-group">
        @foreach (var note in Model)
        {
            <div class="list-group-item list-group-item-action">
                <div class="d-flex w-100 justify-content-between">
                    <h5 class="mb-1">
                        <a asp-action="Details" asp-route-id="@note.Id" class="text-decoration-none">
                            @note.Title
                        </a>
                    </h5>
                    <small class="text-muted">@note.CreatedAt.ToString("MMM d, yyyy")</small>
                </div>
                <p class="mb-1 text-muted">@note.Excerpt</p>
                <div class="d-flex gap-2 align-items-center mt-1">
                    <span class="badge @(note.IsPublic ? "bg-success" : "bg-secondary")">
                        @(note.IsPublic ? "Public" : "Private")
                    </span>
                    @if (note.AverageRating.HasValue)
                    {
                        <small class="text-muted">★ @note.AverageRating.Value.ToString("F1") (@note.RatingCount)</small>
                    }
                    <a asp-action="Edit" asp-route-id="@note.Id" class="btn btn-sm btn-outline-secondary ms-auto">Edit</a>
                    <a asp-action="Delete" asp-route-id="@note.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </div>
            </div>
        }
    </div>
}
