@model IEnumerable<Note>
@{
    ViewData["Title"] = "My Notes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>My Notes</h1>
    <a asp-action="Create" class="btn btn-primary">Create New Note</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (Model.Any())
{
    <div class="row">
        @foreach (var note in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title">
                                <a asp-action="Details" asp-route-id="@note.Id">@note.Title</a>
                            </h5>
                            @if (note.IsPublic)
                            {
                                <span class="badge bg-success">Public</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Private</span>
                            }
                        </div>
                        <p class="card-text text-muted">
                            @if (note.Content.Length > 100)
                            {
                                @note.Content.Substring(0, 100)
                                <text>...</text>
                            }
                            else
                            {
                                @note.Content
                            }
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted">
                                Created: @note.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")
                            </small>
                            @if (note.RatingCount > 0)
                            {
                                <small class="text-muted">
                                    Rating: @note.AverageRating.ToString("F1")/5 (@note.RatingCount)
                                </small>
                            }
                        </div>
                        <div class="mt-2">
                            <a asp-action="Details" asp-route-id="@note.Id" class="btn btn-sm btn-outline-primary">View</a>
                            <a asp-action="Edit" asp-route-id="@note.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@note.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <h3>No notes yet</h3>
        <p>Create your first note to get started!</p>
        <a asp-action="Create" class="btn btn-primary">Create Note</a>
    </div>
}
