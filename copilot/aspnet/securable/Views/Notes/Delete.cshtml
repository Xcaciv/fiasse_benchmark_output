@model NoteDetailsViewModel
@{
    ViewData["Title"] = "Delete note";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm border-danger-subtle">
            <div class="card-body p-4">
                <h1 class="h3 text-danger mb-3">Delete note</h1>
                <p>Are you sure you want to permanently delete <strong>@Model.Title</strong>? This will remove the note, all attachments, ratings, and share links.</p>
                <form asp-action="Delete" method="post" class="d-flex flex-wrap gap-2">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger">Delete permanently</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
