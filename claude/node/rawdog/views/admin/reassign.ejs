<%- include('../partials/header', { title: title }) %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <h1 class="h3 mb-0">
    <i class="bi bi-arrow-left-right me-2"></i>
    Reassign Notes for <span class="text-primary"><%= targetUser.username %></span>
  </h1>
  <a href="/admin/users" class="btn btn-outline-secondary btn-sm">
    <i class="bi bi-arrow-left me-1"></i>Back to Users
  </a>
</div>

<% if (notes.length === 0) { %>
  <div class="text-center py-5">
    <i class="bi bi-journals display-4 text-muted mb-3"></i>
    <p class="text-muted">This user has no notes.</p>
  </div>
<% } else { %>
  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white">
      <span class="fw-semibold">Notes by <%= targetUser.username %></span>
      <span class="text-muted small ms-2">(<%= notes.length %> total)</span>
    </div>
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>Note Title</th>
            <th>Visibility</th>
            <th>Created</th>
            <th>Reassign To</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% notes.forEach(note => { %>
            <tr>
              <td>
                <a href="/notes/<%= note.id %>" target="_blank" class="text-decoration-none">
                  <%= note.title %>
                </a>
              </td>
              <td>
                <span class="badge visibility-badge-<%= note.visibility %>"><%= note.visibility %></span>
              </td>
              <td class="text-muted small"><%= new Date(note.created_at).toLocaleDateString() %></td>
              <td colspan="2">
                <form action="/admin/users/<%= targetUser.id %>/reassign" method="POST" class="d-flex gap-2 align-items-center">
                  <input type="hidden" name="note_id" value="<%= note.id %>">
                  <select name="new_user_id" class="form-select form-select-sm" style="max-width:200px;" required>
                    <option value="">Select user...</option>
                    <% allUsers.forEach(u => { %>
                      <option value="<%= u.id %>"><%= u.username %></option>
                    <% }) %>
                  </select>
                  <button type="submit" class="btn btn-sm btn-primary"
                    onclick="return confirm('Reassign this note?')">
                    Reassign
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<%- include('../partials/footer') %>
