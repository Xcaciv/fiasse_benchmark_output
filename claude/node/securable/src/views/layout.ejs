<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <title><%= title %> — Loose Notes</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <nav class="navbar">
    <a class="nav-brand" href="/">Loose Notes</a>
    <div class="nav-links">
      <% if (user) { %>
        <a href="/notes">My Notes</a>
        <a href="/notes/search?q=">Search</a>
        <a href="/notes/top-rated">Top Rated</a>
        <% if (user.role === 'admin') { %>
          <a href="/admin">Admin</a>
        <% } %>
        <a href="/profile">Profile</a>
        <form method="POST" action="/auth/logout" style="display:inline">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <button type="submit" class="btn-link">Logout</button>
        </form>
      <% } else { %>
        <a href="/auth/login">Login</a>
        <a href="/auth/register">Register</a>
      <% } %>
    </div>
  </nav>

  <main class="container">
    <% if (flash.success && flash.success.length) { %>
      <% flash.success.forEach(msg => { %>
        <div class="alert alert-success"><%= msg %></div>
      <% }) %>
    <% } %>
    <% if (flash.error && flash.error.length) { %>
      <% flash.error.forEach(msg => { %>
        <div class="alert alert-error"><%= msg %></div>
      <% }) %>
    <% } %>

    <%- body %>
  </main>

  <footer class="footer">
    <p>&copy; <%= new Date().getFullYear() %> Loose Notes</p>
  </footer>
</body>
</html>
