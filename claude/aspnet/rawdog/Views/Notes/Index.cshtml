@model IEnumerable<Note>
@{
    ViewData["Title"] = "My Notes";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My Notes</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Note</a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <p>You have no notes yet.</p>
        <a asp-action="Create" class="btn btn-outline-primary">Create your first note</a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var note in Model)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h5 class="card-title">
                                @* Raw rendering of title (§6) *@
                                @Html.Raw(note.Title)
                            </h5>
                            <span class="badge @(note.IsPublic ? "bg-success" : "bg-secondary")">
                                @(note.IsPublic ? "Public" : "Private")
                            </span>
                        </div>
                        <p class="card-text text-muted small">
                            @* Raw rendering of content (§6) *@
                            @Html.Raw(note.Content.Length > 120 ? note.Content[..120] + "..." : note.Content)
                        </p>
                        @if (note.Ratings.Any())
                        {
                            <p class="text-warning small mb-1">
                                ★ @note.Ratings.Average(r => r.Score).ToString("0.0") (@note.Ratings.Count ratings)
                            </p>
                        }
                        <p class="text-muted small">@note.CreatedAt.ToLocalTime().ToString("MMM dd, yyyy")</p>
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@note.Id" class="btn btn-sm btn-outline-primary">View</a>
                        <a asp-action="Edit" asp-route-id="@note.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@note.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<div class="mt-4 d-flex gap-2">
    <a asp-action="Import" class="btn btn-outline-secondary btn-sm">Import ZIP</a>
    <a asp-action="Export" class="btn btn-outline-secondary btn-sm">Export ZIP</a>
</div>
