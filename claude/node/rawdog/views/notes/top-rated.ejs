<%- include('../partials/header', { title: title }) %>

<div class="mb-4">
  <h1 class="h3 mb-1"><i class="bi bi-trophy me-2 text-warning"></i>Top Rated Notes</h1>
  <p class="text-muted">Public notes with at least 3 ratings, sorted by average rating.</p>
</div>

<% if (notes.length === 0) { %>
  <div class="text-center py-5">
    <i class="bi bi-star display-4 text-muted mb-3"></i>
    <p class="text-muted">No notes have enough ratings yet. Notes need at least 3 ratings to appear here.</p>
    <% if (user) { %>
      <a href="/notes/search" class="btn btn-outline-primary">Discover Notes</a>
    <% } %>
  </div>
<% } else { %>
  <div class="row g-3">
    <% notes.forEach((note, index) => { %>
      <div class="col-12">
        <div class="card note-card border-0 shadow-sm">
          <div class="card-body d-flex align-items-center gap-3">
            <div class="text-muted fw-bold fs-4 text-center" style="min-width:2rem;">#<%= index + 1 %></div>
            <div class="flex-grow-1">
              <h5 class="mb-1">
                <a href="/notes/<%= note.id %>" class="text-decoration-none text-dark"><%= note.title %></a>
              </h5>
              <p class="note-excerpt mb-1">
                <%= note.content.substring(0, 200) %><%= note.content.length > 200 ? '...' : '' %>
              </p>
              <span class="text-muted small">By <strong><%= note.username %></strong> &bull;
                <%= new Date(note.created_at).toLocaleDateString() %>
              </span>
            </div>
            <div class="text-center flex-shrink-0" style="min-width:80px;">
              <div class="star-rating fs-4">
                <i class="bi bi-star-fill"></i>
              </div>
              <div class="fw-bold fs-5"><%= note.avg_rating %></div>
              <div class="text-muted small"><%= note.rating_count %> ratings</div>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>

<%- include('../partials/footer') %>
