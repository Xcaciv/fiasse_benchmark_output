@model LooseNotes.ViewModels.Notes.CreateNoteViewModel
@{
    ViewData["Title"] = "New Note";
}

<div class="row justify-content-center">
    <div class="col-md-9">
        <h2>New Note</h2>
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" placeholder="Note title" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Content" class="form-label"></label>
                <textarea asp-for="Content" class="form-control" rows="12"
                          placeholder="Write your note here…"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsPublic" class="form-check-input" />
                <label asp-for="IsPublic" class="form-check-label">Make this note public</label>
            </div>

            <button type="submit" class="btn btn-primary">Create Note</button>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScripts") }
