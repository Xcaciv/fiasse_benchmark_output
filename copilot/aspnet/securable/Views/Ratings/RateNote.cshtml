@model LooseNotes.ViewModels.Notes.RateNoteViewModel
@{
    ViewData["Title"] = Model.ExistingRatingId.HasValue ? "Edit Rating" : "Rate Note";
}
<div class="row justify-content-center">
    <div class="col-md-5">
        <h2 class="mb-2">@(Model.ExistingRatingId.HasValue ? "Edit Your Rating" : "Rate Note")</h2>
        <p class="text-muted mb-4">@Model.NoteTitle</p>

        <form asp-action="RateNote" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="NoteId" />
            <input type="hidden" asp-for="NoteTitle" />
            <input type="hidden" asp-for="ExistingRatingId" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Stars" class="form-label">Stars (1–5)</label>
                <select asp-for="Stars" class="form-select">
                    <option value="">Select…</option>
                    @for (int i = 1; i <= 5; i++)
                    {
                        <option value="@i">@i ⭐</option>
                    }
                </select>
                <span asp-validation-for="Stars" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Comment" class="form-label"></label>
                <textarea asp-for="Comment" class="form-control" rows="3" maxlength="500"></textarea>
                <span asp-validation-for="Comment" class="text-danger small"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    @(Model.ExistingRatingId.HasValue ? "Update Rating" : "Submit Rating")
                </button>
                <a asp-controller="Notes" asp-action="Details" asp-route-id="@Model.NoteId"
                   class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScripts"); } }
