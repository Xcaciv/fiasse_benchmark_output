<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="h3 mb-1">Your notes</h1>
    <p class="text-body-secondary mb-0">Manage private and public notes, share links, and attachments.</p>
  </div>
  <a href="/notes/new" class="btn btn-primary">Create note</a>
</div>

<% if (!notes.length) { %>
  <div class="alert alert-light border">You have not created any notes yet.</div>
<% } else { %>
  <div class="table-responsive bg-white border rounded-3 shadow-sm">
    <table class="table table-hover align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Title</th>
          <th>Visibility</th>
          <th>Attachments</th>
          <th>Ratings</th>
          <th>Updated</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% for (const note of notes) { %>
          <tr>
            <td>
              <a class="fw-semibold text-decoration-none" href="/notes/<%= note.id %>"><%= note.title %></a>
            </td>
            <td><span class="badge text-bg-<%= note.visibility === 'public' ? 'success' : 'secondary' %>"><%= helpers.formatVisibility(note.visibility) %></span></td>
            <td><%= note.attachment_count %></td>
            <td><%= note.rating_count %></td>
            <td><%= helpers.formatDateTime(note.updated_at) %></td>
            <td class="text-end">
              <a href="/notes/<%= note.id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
              <a href="/notes/<%= note.id %>/delete" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
<% } %>
