@model LooseNotes.ViewModels.Account.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
}
<div class="form-container">
    <h2>Sign In</h2>
    <form asp-action="Login" method="post">
        <input type="hidden" asp-for="ReturnUrl" />
        <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>
        <div class="form-group">
            <label asp-for="Username">Username</label>
            <input asp-for="Username" class="form-control" autocomplete="username" />
            <span asp-validation-for="Username" class="field-error"></span>
        </div>
        <div class="form-group">
            <label asp-for="Password">Password</label>
            <input asp-for="Password" class="form-control" autocomplete="current-password" />
            <span asp-validation-for="Password" class="field-error"></span>
        </div>
        <button type="submit" class="btn btn-primary">Sign In</button>
    </form>
    <div class="form-links">
        <a asp-action="ForgotPassword">Forgot your password?</a>
        <a asp-action="Register">Don't have an account? Register</a>
    </div>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
