@{
    ViewData["Title"] = "Welcome";
}
<div class="hero">
    <h1>Loose Notes</h1>
    <p>A secure note-taking application. Create, share, and organize your notes.</p>
    <div class="hero-actions">
        <a asp-controller="Account" asp-action="Register" class="btn btn-primary">Get Started</a>
        <a asp-controller="Account" asp-action="Login" class="btn btn-secondary">Sign In</a>
    </div>
    <div class="hero-features">
        <a asp-controller="Notes" asp-action="TopRated">View Top Rated Public Notes</a>
    </div>
</div>
