# Application
NODE_ENV=development
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-secret-value

# Database (SQLite file path)
DB_PATH=./data/loose-notes.db

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10

# Email (for password reset)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=your-ethereal-user
SMTP_PASS=your-ethereal-pass
EMAIL_FROM=noreply@loosenotes.local
APP_BASE_URL=http://localhost:3000
