<% if (total > pageSize) { %>
  <% const totalPages = Math.ceil(total / pageSize); %>
  <nav aria-label="Page navigation" class="mt-3">
    <ul class="pagination justify-content-center">
      <li class="page-item <%= page <= 1 ? 'disabled' : '' %>">
        <a class="page-link" href="?<%= query ? 'q=' + encodeURIComponent(query) + '&' : '' %>page=<%= page - 1 %>">Previous</a>
      </li>
      <% for (let p = 1; p <= totalPages; p++) { %>
        <li class="page-item <%= p === page ? 'active' : '' %>">
          <a class="page-link" href="?<%= query ? 'q=' + encodeURIComponent(query) + '&' : '' %>page=<%= p %>"><%= p %></a>
        </li>
      <% } %>
      <li class="page-item <%= page >= totalPages ? 'disabled' : '' %>">
        <a class="page-link" href="?<%= query ? 'q=' + encodeURIComponent(query) + '&' : '' %>page=<%= page + 1 %>">Next</a>
      </li>
    </ul>
  </nav>
<% } %>
