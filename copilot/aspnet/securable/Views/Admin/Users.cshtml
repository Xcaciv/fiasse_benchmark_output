@model UsersViewModel
@{
    ViewData["Title"] = "Manage users";
}

<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
    <div>
        <h1 class="mb-1">Users</h1>
        <p class="text-muted mb-0">Search users by username or email address.</p>
    </div>
    <a asp-action="Dashboard" class="btn btn-outline-secondary">Back to dashboard</a>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-body p-4">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-10">
                <label for="query" class="form-label">Search</label>
                <input id="query" name="query" value="@Model.Query" class="form-control" placeholder="username or email" />
            </div>
            <div class="col-md-2 d-grid">
                <button type="submit" class="btn btn-primary">Search</button>
            </div>
        </form>
    </div>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-striped align-middle mb-0">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Registered</th>
                    <th>Note count</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>@user.UserName</td>
                        <td>@user.Email</td>
                        <td>@user.RegisteredAtUtc.ToLocalTime().ToString("g")</td>
                        <td>@user.NoteCount</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
