@model NoteDetailsViewModel
@{
    ViewData["Title"] = Model.Note.Title;
    var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
}
<div class="row">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <h2>@Model.Note.Title</h2>
            <span class="badge @(Model.Note.IsPublic ? "bg-success" : "bg-secondary") fs-6">
                @(Model.Note.IsPublic ? "Public" : "Private")
            </span>
        </div>

        <p class="text-muted small">
            By @(Model.Note.User?.UserName ?? "Unknown") &bull;
            Created @Model.Note.CreatedAt.ToString("MMM d, yyyy") &bull;
            Updated @Model.Note.UpdatedAt.ToString("MMM d, yyyy")
        </p>

        <div class="card mb-4">
            <div class="card-body">
                <pre class="mb-0" style="white-space:pre-wrap;font-family:inherit;">@Model.Note.Content</pre>
            </div>
        </div>

        @if (Model.Note.Attachments.Any())
        {
            <h5>Attachments</h5>
            <ul class="list-group mb-4">
                @foreach (var att in Model.Note.Attachments)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <a asp-controller="Attachments" asp-action="Download" asp-route-id="@att.Id">
                            @att.OriginalFileName
                        </a>
                        <div>
                            <small class="text-muted me-3">@(att.FileSizeBytes / 1024) KB</small>
                            @if (Model.CanEdit)
                            {
                                <form asp-controller="Attachments" asp-action="Delete" asp-route-id="@att.Id"
                                      method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this attachment?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            }
                        </div>
                    </li>
                }
            </ul>
        }

        <h5>Ratings (@Model.RatingCount) &mdash; Avg: @Model.AverageRating ⭐</h5>
        @foreach (var rating in Model.Note.Ratings)
        {
            <div class="card mb-2">
                <div class="card-body py-2">
                    <strong>@(rating.User?.UserName ?? "Unknown")</strong>
                    — @rating.Stars / 5 stars
                    @if (!string.IsNullOrEmpty(rating.Comment))
                    {
                        <p class="mb-0 text-muted small mt-1">@rating.Comment</p>
                    }
                </div>
            </div>
        }

        @if (User.Identity?.IsAuthenticated == true && Model.Note.UserId != userId)
        {
            <a asp-controller="Ratings" asp-action="RateNote" asp-route-noteId="@Model.Note.Id"
               class="btn btn-outline-warning mt-3">Rate This Note</a>
        }
        @if (Model.Note.UserId == userId)
        {
            <a asp-controller="Ratings" asp-action="NoteRatings" asp-route-noteId="@Model.Note.Id"
               class="btn btn-outline-info mt-3">Manage Ratings</a>
        }
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">Actions</div>
            <div class="card-body d-grid gap-2">
                @if (Model.CanEdit)
                {
                    <a asp-action="Edit" asp-route-id="@Model.Note.Id" class="btn btn-outline-primary">Edit</a>

                    <form asp-action="GenerateShareLink" asp-route-id="@Model.Note.Id" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-secondary w-100">Generate Share Link</button>
                    </form>

                    @if (Model.ActiveShareToken is not null)
                    {
                        <form asp-action="RevokeShareLink" asp-route-id="@Model.Note.Id" method="post">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-warning w-100">Revoke Share Link</button>
                        </form>
                    }
                }
                @if (Model.CanDelete)
                {
                    <form asp-action="Delete" asp-route-id="@Model.Note.Id" method="post"
                          onsubmit="return confirm('Permanently delete this note and all attachments?')">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-outline-danger w-100">Delete Note</button>
                    </form>
                }
                <a asp-action="Index" class="btn btn-link text-muted">← Back to Notes</a>
            </div>
        </div>
    </div>
</div>
