<%- include('../partials/header') %>
<div class="row justify-content-center">
  <div class="col-md-5">
    <h2 class="mb-4">Forgot Password</h2>
    <p class="text-muted">Enter your email address and we'll send you a reset link.</p>
    <% if (typeof errors !== 'undefined' && errors.length) { %>
      <div class="alert alert-danger"><ul class="mb-0"><% errors.forEach(e => { %><li><%= e.msg %></li><% }) %></ul></div>
    <% } %>
    <form method="POST" action="/auth/forgot">
      <div class="mb-3">
        <label class="form-label">Email Address</label>
        <input type="email" name="email" class="form-control" required />
      </div>
      <button type="submit" class="btn btn-primary w-100">Send Reset Link</button>
    </form>
    <p class="mt-3 text-center"><a href="/auth/login">Back to Login</a></p>
  </div>
</div>
<%- include('../partials/footer') %>
