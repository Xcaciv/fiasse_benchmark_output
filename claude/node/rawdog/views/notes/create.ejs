<%- include('../partials/header', { title: title }) %>

<div class="row justify-content-center">
  <div class="col-lg-9">
    <h1 class="h3 mb-4"><i class="bi bi-plus-circle me-2"></i>Create New Note</h1>
    <div class="card shadow-sm border-0">
      <div class="card-body p-4">
        <form action="/notes/create" method="POST" enctype="multipart/form-data">
          <div class="mb-3">
            <label for="title" class="form-label fw-semibold">Title <span class="text-danger">*</span></label>
            <input type="text" class="form-control form-control-lg" id="title" name="title" required
              placeholder="Note title..." maxlength="255">
          </div>
          <div class="mb-3">
            <label for="content" class="form-label fw-semibold">Content <span class="text-danger">*</span></label>
            <textarea class="form-control" id="content" name="content" rows="12" required
              placeholder="Write your note here..."></textarea>
          </div>
          <div class="mb-3">
            <label class="form-label fw-semibold">Visibility</label>
            <div>
              <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="visibility" id="visPrivate" value="private" checked>
                <label class="form-check-label" for="visPrivate">
                  <i class="bi bi-lock me-1"></i>Private
                </label>
              </div>
              <div class="form-check form-check-inline">
                <input class="form-check-input" type="radio" name="visibility" id="visPublic" value="public">
                <label class="form-check-label" for="visPublic">
                  <i class="bi bi-globe me-1"></i>Public
                </label>
              </div>
            </div>
            <div class="form-text">Public notes appear in search results and can be rated by others.</div>
          </div>
          <div class="mb-4">
            <label for="attachments" class="form-label fw-semibold">Attachments</label>
            <input type="file" class="form-control" id="attachments" name="attachments" multiple
              accept=".pdf,.doc,.docx,.txt,.png,.jpg,.jpeg">
            <div class="form-text">Allowed: PDF, DOC, DOCX, TXT, PNG, JPG, JPEG. Max 10 MB per file.</div>
          </div>
          <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">
              <i class="bi bi-check2 me-1"></i>Create Note
            </button>
            <a href="/notes" class="btn btn-outline-secondary">Cancel</a>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
