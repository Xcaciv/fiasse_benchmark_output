<%- include('../partials/header') %>
<h2 class="mb-4">Search Notes</h2>
<form action="/search" method="GET" class="mb-4">
  <div class="input-group">
    <input type="text" name="q" class="form-control" placeholder="Search by title or content..." value="<%= query %>" maxlength="200">
    <button type="submit" class="btn btn-primary">Search</button>
  </div>
</form>
<% if (query && results.length === 0) { %>
  <div class="alert alert-info">No results found for "<strong><%= query %></strong>".</div>
<% } %>
<% results.forEach(function(result) { %>
  <div class="card mb-3">
    <div class="card-body">
      <h5 class="card-title"><a href="/notes/<%= result.id %>"><%= result.title %></a></h5>
      <p class="card-text text-muted small"><%= result.excerpt %>&hellip;</p>
      <div class="d-flex justify-content-between align-items-center">
        <small class="text-muted">By <strong><%= result.author %></strong> &mdash; <%= new Date(result.createdAt).toLocaleDateString() %></small>
        <% if (result.avgRating) { %>
          <span class="text-warning">★ <%= result.avgRating %> <small class="text-muted">(<%= result.ratingCount %>)</small></span>
        <% } %>
      </div>
    </div>
  </div>
<% }) %>
<%- include('../partials/footer') %>
