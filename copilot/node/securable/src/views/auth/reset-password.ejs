<div class="row justify-content-center">
  <div class="col-md-5">
    <h2>Reset Password</h2>
    <%- include('../partials/errors', { errors }) %>
    <form method="POST" action="/auth/reset-password/<%= token %>">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <div class="mb-3">
        <label class="form-label">New Password (min 8 characters)</label>
        <input type="password" name="password" class="form-control" required autocomplete="new-password">
      </div>
      <div class="mb-3">
        <label class="form-label">Confirm New Password</label>
        <input type="password" name="confirmPassword" class="form-control" required autocomplete="new-password">
      </div>
      <button type="submit" class="btn btn-primary w-100">Reset Password</button>
    </form>
  </div>
</div>
