@{
    ViewData["Title"] = "Check Your Email";
}

<div class="row justify-content-center">
    <div class="col-md-6 text-center mt-4">
        <i class="bi bi-envelope-check display-3 text-success"></i>
        <h2 class="mt-3">Check Your Email</h2>
        <p class="text-muted">If an account with that email exists, a password reset link has been sent. The link expires in 1 hour.</p>
        <a asp-action="Login" class="btn btn-primary">Back to Login</a>
    </div>
</div>
