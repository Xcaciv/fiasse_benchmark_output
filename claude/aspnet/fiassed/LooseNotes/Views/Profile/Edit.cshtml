@model LooseNotes.ViewModels.Profile.EditProfileViewModel
@{
    ViewData["Title"] = "Edit Profile";
}
<div class="profile-edit">
    <h2>Edit Profile</h2>
    <div class="profile-info">
        <p><strong>Current Username:</strong> @Html.Encode(Model.CurrentUsername)</p>
        <p><strong>Current Email:</strong> @Html.Encode(Model.CurrentEmail)</p>
    </div>

    <section class="profile-section">
        <h3>Change Username</h3>
        <form asp-action="UpdateUsername" method="post">
            <div class="form-group">
                <label asp-for="NewUsername">New Username</label>
                <input asp-for="NewUsername" class="form-control" placeholder="@Model.CurrentUsername" />
                <span asp-validation-for="NewUsername" class="field-error"></span>
            </div>
            <button type="submit" class="btn btn-secondary">Update Username</button>
        </form>
    </section>

    <section class="profile-section">
        <h3>Change Email</h3>
        <form asp-action="UpdateEmail" method="post">
            <div class="form-group">
                <label asp-for="NewEmail">New Email</label>
                <input asp-for="NewEmail" class="form-control" type="email" placeholder="@Model.CurrentEmail" />
                <span asp-validation-for="NewEmail" class="field-error"></span>
            </div>
            <button type="submit" class="btn btn-secondary">Update Email</button>
        </form>
    </section>

    <section class="profile-section">
        <h3>Change Password</h3>
        <!-- Current password required to prevent CSRF-based credential takeover (ASVS V6.2.2) -->
        <form asp-action="UpdatePassword" method="post">
            <div class="form-group">
                <label asp-for="CurrentPassword">Current Password</label>
                <input asp-for="CurrentPassword" class="form-control" autocomplete="current-password" />
            </div>
            <div class="form-group">
                <label asp-for="NewPassword">New Password</label>
                <input asp-for="NewPassword" class="form-control password-field" autocomplete="new-password" />
                <button type="button" class="btn-toggle-password" aria-label="Show/hide password">Show</button>
                <small class="help-text">Minimum 8 characters.</small>
            </div>
            <div class="form-group">
                <label asp-for="ConfirmNewPassword">Confirm New Password</label>
                <input asp-for="ConfirmNewPassword" class="form-control" autocomplete="new-password" />
            </div>
            <button type="submit" class="btn btn-warning">Change Password</button>
        </form>
        <p class="help-text">After a successful password change, all other active sessions will be signed out.</p>
    </section>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
