@model EditNoteViewModel
@{
    ViewData["Title"] = "Edit Note";
}

<div class="row">
    <div class="col-lg-8">
        <h2><i class="bi bi-pencil"></i> Edit Note</h2>
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-semibold"></label>
                <input asp-for="Title" class="form-control form-control-lg" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Content" class="form-label fw-semibold"></label>
                <textarea asp-for="Content" class="form-control" rows="12"></textarea>
                <span asp-validation-for="Content" class="text-danger small"></span>
            </div>

            @if (Model.ExistingAttachments.Any())
            {
                <div class="mb-3">
                    <label class="form-label fw-semibold">Existing Attachments</label>
                    <ul class="list-group mb-2">
                        @foreach (var att in Model.ExistingAttachments)
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <span>
                                    <i class="bi bi-paperclip"></i>
                                    <a asp-action="DownloadAttachment" asp-route-id="@att.Id">@att.OriginalFileName</a>
                                    <small class="text-muted ms-2">(@((att.FileSize / 1024.0).ToString("F1")) KB)</small>
                                </span>
                                <form asp-action="DeleteAttachment" method="post" class="d-inline"
                                      onsubmit="return confirm('Delete this attachment?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@att.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </li>
                        }
                    </ul>
                </div>
            }

            <div class="mb-3">
                <label asp-for="Files" class="form-label fw-semibold">Add Attachments</label>
                <input asp-for="Files" class="form-control" type="file" multiple
                       accept=".pdf,.doc,.docx,.txt,.png,.jpg,.jpeg" />
                <div class="form-text">Allowed: PDF, DOC, DOCX, TXT, PNG, JPG, JPEG. Max 10 MB each.</div>
                <span asp-validation-for="Files" class="text-danger small"></span>
            </div>
            <div class="mb-4 form-check">
                <input asp-for="IsPublic" class="form-check-input" type="checkbox" />
                <label asp-for="IsPublic" class="form-check-label">Make this note public</label>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-save"></i> Save Changes
                </button>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts { @await Html.PartialAsync("_ValidationScripts") }
