@model NoteDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}
<div class="mb-3">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">&larr; My Notes</a>
</div>

<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="mb-0">@Model.Title</h3>
        <div class="d-flex gap-2 align-items-center">
            <span class="badge @(Model.IsPublic ? "bg-success" : "bg-secondary")">
                @(Model.IsPublic ? "Public" : "Private")
            </span>
            @if (Model.IsOwner)
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-danger">Delete</a>
            }
        </div>
    </div>
    <div class="card-body">
        <p class="text-muted small mb-3">
            By @Model.OwnerDisplayName &nbsp;|&nbsp;
            Created @Model.CreatedAt.ToString("MMM d, yyyy HH:mm") UTC &nbsp;|&nbsp;
            Updated @Model.UpdatedAt.ToString("MMM d, yyyy HH:mm") UTC
        </p>
        <!-- Content is Razor-encoded automatically (XSS prevention) -->
        <div style="white-space: pre-wrap;">@Model.Content</div>
    </div>
</div>

<!-- Attachments -->
@if (Model.Attachments.Any())
{
    <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Attachments</h5></div>
        <ul class="list-group list-group-flush">
            @foreach (var att in Model.Attachments)
            {
                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <a asp-controller="Attachments" asp-action="Download" asp-route-id="@att.Id">
                        @att.OriginalFileName
                    </a>
                    <span class="text-muted small">@((att.FileSizeBytes / 1024.0).ToString("F1")) KB</span>
                    @if (Model.IsOwner)
                    {
                        <form asp-controller="Attachments" asp-action="Delete" method="post" class="d-inline">
                            <input type="hidden" name="id" value="@att.Id" />
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Delete attachment?')">Delete</button>
                        </form>
                    }
                </li>
            }
        </ul>
    </div>
}

<!-- Share Link (owner only) -->
@if (Model.IsOwner)
{
    <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Share Link</h5></div>
        <div class="card-body">
            @if (Model.ActiveShareToken is not null)
            {
                var shareUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/share/{Model.ActiveShareToken}";
                <div class="input-group mb-2">
                    <input type="text" class="form-control" value="@shareUrl" readonly id="shareUrl" />
                    <button class="btn btn-outline-secondary" onclick="navigator.clipboard.writeText(document.getElementById('shareUrl').value)">Copy</button>
                </div>
                <form asp-action="RevokeShareLink" asp-route-id="@Model.Id" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-outline-danger">Revoke Link</button>
                </form>
            }
            else
            {
                <form asp-action="GenerateShareLink" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-outline-primary">Generate Share Link</button>
                </form>
            }
        </div>
    </div>
}

<!-- Ratings -->
<div class="card mb-4">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="mb-0">
            Ratings
            @if (Model.AverageRating.HasValue)
            {
                <span class="ms-2 text-warning">★ @Model.AverageRating.Value.ToString("F1")</span>
                <small class="text-muted ms-1">(@Model.Ratings.Count)</small>
            }
        </h5>
    </div>
    <div class="card-body">
        @if (Model.CanRate)
        {
            <form asp-controller="Ratings" asp-action="Submit" method="post" class="mb-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="NoteId" value="@Model.Id" />
                <input type="hidden" name="RatingId" value="@(Model.UserRating?.RatingId ?? 0)" />
                <div class="row g-2 align-items-end">
                    <div class="col-auto">
                        <label class="form-label">Your Rating</label>
                        <select name="Value" class="form-select" required>
                            @for (int i = 1; i <= 5; i++)
                            {
                                var selected = Model.UserRating?.Value == i ? "selected" : "";
                                <option value="@i" @selected>@i ★</option>
                            }
                        </select>
                    </div>
                    <div class="col">
                        <label class="form-label">Comment (optional)</label>
                        <input type="text" name="Comment" class="form-control" maxlength="1000"
                               value="@Model.UserRating?.Comment" />
                    </div>
                    <div class="col-auto">
                        <button type="submit" class="btn btn-primary">
                            @(Model.UserRating is not null ? "Update Rating" : "Submit Rating")
                        </button>
                    </div>
                </div>
            </form>
        }

        @if (!Model.Ratings.Any())
        {
            <p class="text-muted">No ratings yet.</p>
        }
        else
        {
            @foreach (var r in Model.Ratings)
            {
                <div class="border-bottom py-2">
                    <strong>@r.RaterDisplayName</strong>
                    <span class="text-warning ms-2">@string.Concat(Enumerable.Repeat("★", r.Value))</span>
                    <small class="text-muted ms-2">@r.CreatedAt.ToString("MMM d, yyyy")</small>
                    @if (!string.IsNullOrWhiteSpace(r.Comment))
                    {
                        <p class="mb-0 mt-1">@r.Comment</p>
                    }
                </div>
            }
        }
    </div>
</div>
