@model LooseNotes.Models.Note
@{
    ViewData["Title"] = Model.Title + " (Shared)";
}
<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="alert alert-info mb-3">
            <strong>Shared Note</strong> — This note was shared with you via a link.
        </div>

        <h2>@Model.Title</h2>
        <p class="text-muted small">
            By @(Model.User?.UserName ?? "Unknown") &bull;
            @Model.CreatedAt.ToString("MMMM d, yyyy")
        </p>

        <div class="card mb-4">
            <div class="card-body">
                <pre style="white-space:pre-wrap;font-family:inherit;">@Model.Content</pre>
            </div>
        </div>

        @if (Model.Attachments.Any())
        {
            <h5>Attachments</h5>
            <ul class="list-group">
                @foreach (var att in Model.Attachments)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <a asp-controller="Attachments" asp-action="Download" asp-route-id="@att.Id">
                            @att.OriginalFileName
                        </a>
                        <small class="text-muted">@(att.FileSizeBytes / 1024) KB</small>
                    </li>
                }
            </ul>
        }
    </div>
</div>
