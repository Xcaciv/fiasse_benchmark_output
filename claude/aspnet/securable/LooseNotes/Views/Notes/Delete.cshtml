@model Note
@{
    ViewData["Title"] = "Delete Note";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">Confirm Deletion</div>
            <div class="card-body">
                <p>Are you sure you want to permanently delete this note?</p>
                <dl>
                    <dt>Title</dt>
                    <dd>@Model.Title</dd>
                    <dt>Created</dt>
                    <dd>@Model.CreatedAt.ToString("MMM d, yyyy")</dd>
                </dl>
                <p class="text-danger small">This will also delete all attachments, ratings, and share links.</p>
            </div>
            <div class="card-footer d-flex gap-2">
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-danger">Yes, Delete</button>
                </form>
                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</div>
