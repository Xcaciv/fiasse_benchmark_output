@model NoteDetailViewModel
@{
    ViewData["Title"] = Model.Title;
}
<div class="row">
    <div class="col-md-8">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
                <h2>@Model.Title</h2>
                <p class="text-muted">By @Model.AuthorName &middot; @Model.CreatedAt.ToString("MMM dd, yyyy")
                    @if (Model.IsPublic)
                    {
                        <span class="badge bg-success ms-1">Public</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary ms-1">Private</span>
                    }
                </p>
            </div>
            @if (Model.IsOwner)
            {
                <div>
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger"
                                onclick="return confirm('Delete this note?')">Delete</button>
                    </form>
                </div>
            }
        </div>
        <div class="card mb-4">
            <div class="card-body" style="white-space: pre-wrap;">@Model.Content</div>
        </div>

        @if (Model.IsOwner)
        {
            <!-- Share link management -->
            <div class="card mb-4">
                <div class="card-header">Share Link</div>
                <div class="card-body">
                    @if (Model.HasActiveShareLink && Model.ShareToken != null)
                    {
                        var shareUrl = $"{Context.Request.Scheme}://{Context.Request.Host}/share/{Model.ShareToken}";
                        <p><input type="text" class="form-control" value="@shareUrl" readonly /></p>
                        <form asp-action="RevokeShareLink" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="noteId" value="@Model.Id" />
                            <button type="submit" class="btn btn-sm btn-warning">Revoke</button>
                        </form>
                    }
                    else
                    {
                        <form asp-action="GenerateShareLink" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="noteId" value="@Model.Id" />
                            <button type="submit" class="btn btn-sm btn-primary">Generate Share Link</button>
                        </form>
                    }
                </div>
            </div>

            <!-- Attachment upload -->
            <div class="card mb-4">
                <div class="card-header">Upload Attachment</div>
                <div class="card-body">
                    <form asp-action="UploadAttachment" method="post" enctype="multipart/form-data">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="noteId" value="@Model.Id" />
                        <div class="mb-2">
                            <input type="file" name="file" class="form-control" accept=".pdf,.doc,.docx,.txt,.png,.jpg,.jpeg" />
                            <small class="text-muted">Allowed: PDF, DOC, DOCX, TXT, PNG, JPG, JPEG. Max 10MB.</small>
                        </div>
                        <button type="submit" class="btn btn-sm btn-secondary">Upload</button>
                    </form>
                </div>
            </div>
        }

        @if (Model.Attachments.Any())
        {
            <div class="card mb-4">
                <div class="card-header">Attachments</div>
                <ul class="list-group list-group-flush">
                    @foreach (var att in Model.Attachments)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <a asp-controller="Notes" asp-action="DownloadAttachment" asp-route-id="@att.Id">
                                @att.OriginalFileName
                            </a>
                            <span class="text-muted small">@((att.FileSize / 1024.0).ToString("F1")) KB</span>
                            @if (Model.IsOwner)
                            {
                                <form asp-action="DeleteAttachment" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="attachmentId" value="@att.Id" />
                                    <input type="hidden" name="noteId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            }
                        </li>
                    }
                </ul>
            </div>
        }

        <!-- Ratings section -->
        <div class="card mb-4">
            <div class="card-header">
                Ratings
                @if (Model.RatingCount > 0)
                {
                    <span class="ms-2 badge bg-warning text-dark">&#11088; @Model.AverageRating.ToString("F1") (@Model.RatingCount)</span>
                }
            </div>
            <div class="card-body">
                @if (User.Identity?.IsAuthenticated == true && !Model.IsOwner && !Model.CurrentUserHasRated)
                {
                    <form asp-action="Rate" method="post" class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="NoteId" value="@Model.Id" />
                        <div class="mb-2">
                            <label class="form-label">Your Rating (1-5)</label>
                            <input type="number" name="Value" min="1" max="5" class="form-control" style="width:80px" required />
                        </div>
                        <div class="mb-2">
                            <label class="form-label">Comment (optional)</label>
                            <textarea name="Comment" class="form-control" rows="2" maxlength="1000"></textarea>
                        </div>
                        <button type="submit" class="btn btn-sm btn-primary">Submit Rating</button>
                    </form>
                }
                @if (!Model.Ratings.Any())
                {
                    <p class="text-muted">No ratings yet.</p>
                }
                else
                {
                    @foreach (var rating in Model.Ratings)
                    {
                        <div class="border-bottom pb-2 mb-2">
                            <strong>@(rating.Rater?.DisplayName ?? "Anonymous")</strong>
                            <span class="badge bg-warning text-dark ms-1">&#11088; @rating.Value</span>
                            @if (!string.IsNullOrWhiteSpace(rating.Comment))
                            {
                                <p class="mb-0 text-muted small">@rating.Comment</p>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
