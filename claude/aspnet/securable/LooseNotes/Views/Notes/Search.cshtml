@model LooseNotes.ViewModels.Notes.NoteSearchViewModel
@{
    ViewData["Title"] = "Search Notes";
}

<h2>Search Notes</h2>

<form asp-action="Search" method="get" class="mb-4">
    <div class="input-group">
        <input type="search" name="q" value="@Model.Query"
               class="form-control" placeholder="Search by title or content…" />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@if (Model.Query is not null)
{
    <p class="text-muted">
        @Model.Results.Count result(s) for "<strong>@Model.Query</strong>"
    </p>

    @if (!Model.Results.Any())
    {
        <div class="alert alert-info">No notes found.</div>
    }
    else
    {
        <div class="list-group">
            @foreach (var note in Model.Results)
            {
                <a asp-action="Details" asp-route-id="@note.Id"
                   class="list-group-item list-group-item-action">
                    <div class="d-flex w-100 justify-content-between">
                        <h5 class="mb-1">@note.Title</h5>
                        <small class="text-muted">@note.CreatedAt.ToString("d")</small>
                    </div>
                    <p class="mb-1 text-muted small">
                        @(note.Content.Length > 200 ? note.Content.Substring(0, 200) + "…" : note.Content)
                    </p>
                    <small>by @note.Owner.UserName</small>
                </a>
            }
        </div>
    }
}
