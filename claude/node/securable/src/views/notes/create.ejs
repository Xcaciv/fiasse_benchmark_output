<div class="card form-card form-card-wide">
  <h1>New Note</h1>
  <form method="POST" action="/notes">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>" />

    <div class="form-group">
      <label for="title">Title <span class="required">*</span></label>
      <input type="text" id="title" name="title" required maxlength="255" />
    </div>

    <div class="form-group">
      <label for="content">Content <span class="required">*</span></label>
      <textarea id="content" name="content" rows="12" required></textarea>
    </div>

    <div class="form-group form-check">
      <input type="checkbox" id="isPublic" name="isPublic" value="on" />
      <label for="isPublic">Make this note public</label>
    </div>

    <div class="form-actions">
      <button type="submit" class="btn btn-primary">Create Note</button>
      <a href="/notes" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>
