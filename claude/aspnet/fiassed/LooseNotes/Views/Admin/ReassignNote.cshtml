@model LooseNotes.ViewModels.Admin.ReassignNoteViewModel
@{
    ViewData["Title"] = "Reassign Note";
}
<div class="form-container">
    <h2>Reassign Note</h2>
    <div class="info-box">
        <p><strong>Note:</strong> @Html.Encode(Model.CurrentTitle)</p>
        <p><strong>Current Owner:</strong> @Html.Encode(Model.CurrentOwnerUsername)</p>
    </div>
    <!-- GET request to this URL does NOT execute reassignment (ASVS V3.5) -->
    <!-- Anti-forgery token required via AutoValidateAntiforgeryToken (GSR-03) -->
    <form asp-action="ReassignNote" method="post">
        <input type="hidden" asp-for="NoteId" />
        <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>
        <div class="form-group">
            <label asp-for="TargetUsername">New Owner Username</label>
            <input asp-for="TargetUsername" class="form-control" />
            <span asp-validation-for="TargetUsername" class="field-error"></span>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-warning">Reassign Ownership</button>
            <a asp-action="Dashboard" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
