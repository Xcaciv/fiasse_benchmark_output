@model NoteDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="d-flex justify-content-between align-items-start mb-3">
    <div>
        <h2>@Model.Title</h2>
        <small class="text-muted">
            By <strong>@Model.AuthorUserName</strong> ·
            Created @Model.CreatedAt.ToString("MMM d, yyyy") ·
            Updated @Model.UpdatedAt.ToString("MMM d, yyyy") ·
            <span class="badge @(Model.Visibility == NoteVisibility.Public ? "bg-success" : "bg-secondary")">
                @Model.Visibility
            </span>
        </small>
    </div>
    @if (Model.IsOwner)
    {
        <div class="d-flex gap-2">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm">Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger btn-sm">Delete</a>
        </div>
    }
</div>

<div class="card mb-4">
    <div class="card-body">
        <pre class="mb-0" style="white-space: pre-wrap; font-family: inherit;">@Model.Content</pre>
    </div>
</div>

@* ── Attachments ── *@
@if (Model.Attachments.Any())
{
    <h5>Attachments</h5>
    <ul class="list-group mb-4">
        @foreach (var att in Model.Attachments)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span>
                    📎 @att.OriginalFileName
                    <small class="text-muted ms-2">(@(att.FileSizeBytes / 1024) KB)</small>
                </span>
                <div class="d-flex gap-2">
                    <a asp-controller="Attachments" asp-action="Download" asp-route-id="@att.Id"
                       class="btn btn-sm btn-outline-secondary">Download</a>
                    @if (Model.IsOwner)
                    {
                        <form asp-controller="Attachments" asp-action="Delete" asp-route-id="@att.Id"
                              method="post">
                            <button type="submit" class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Delete this attachment?')">Remove</button>
                        </form>
                    }
                </div>
            </li>
        }
    </ul>
}

@* ── Share link management (owner only) ── *@
@if (Model.IsOwner)
{
    <div class="card mb-4">
        <div class="card-header">Share Link</div>
        <div class="card-body">
            @if (Model.ActiveShareToken is not null)
            {
                var shareUrl = Url.Action("View", "Share",
                    new { token = Model.ActiveShareToken }, protocol: Request.Scheme);
                <div class="input-group mb-2">
                    <input type="text" class="form-control" value="@shareUrl" readonly id="shareUrl" />
                    <button class="btn btn-outline-secondary" type="button"
                            onclick="navigator.clipboard.writeText(document.getElementById('shareUrl').value)">
                        Copy
                    </button>
                </div>
                <form asp-action="RevokeShareLink" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-sm btn-outline-danger">Revoke Link</button>
                </form>
                <form asp-action="GenerateShareLink" asp-route-id="@Model.Id" method="post" class="d-inline ms-2">
                    <button type="submit" class="btn btn-sm btn-outline-secondary">Regenerate</button>
                </form>
            }
            else
            {
                <form asp-action="GenerateShareLink" asp-route-id="@Model.Id" method="post">
                    <button type="submit" class="btn btn-primary btn-sm">Generate Share Link</button>
                </form>
            }
        </div>
    </div>
}

@* ── Ratings ── *@
<div class="row">
    <div class="col-md-8">
        <h5>
            Ratings
            @if (Model.RatingCount > 0)
            {
                <span class="text-warning ms-2">★ @Model.AverageRating.ToString("F1")</span>
                <small class="text-muted">(@Model.RatingCount)</small>
            }
        </h5>

        @* Rate form (authenticated users who don't own the note) *@
        @if (User.Identity?.IsAuthenticated == true && !Model.IsOwner)
        {
            <form asp-action="Rate" method="post" class="card mb-3">
                <div class="card-body">
                    <input type="hidden" name="NoteId" value="@Model.Id" />
                    <div class="mb-2">
                        <label class="form-label fw-bold">
                            @(Model.CurrentUserRating.HasValue ? "Update your rating" : "Rate this note")
                        </label>
                        <select name="Value" class="form-select form-select-sm w-auto">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <option value="@i" @(Model.CurrentUserRating == i ? "selected" : "")>
                                    @i ★
                                </option>
                            }
                        </select>
                    </div>
                    <div class="mb-2">
                        <textarea name="Comment" class="form-control" rows="2"
                                  placeholder="Optional comment (max 1000 chars)" maxlength="1000"></textarea>
                    </div>
                    <button type="submit" class="btn btn-sm btn-primary">Submit Rating</button>
                </div>
            </form>
        }

        @if (!Model.Ratings.Any())
        {
            <p class="text-muted">No ratings yet.</p>
        }
        else
        {
            @foreach (var rating in Model.Ratings)
            {
                <div class="card mb-2">
                    <div class="card-body py-2">
                        <div class="d-flex justify-content-between">
                            <strong>@rating.RaterUserName</strong>
                            <span class="text-warning">@string.Concat(Enumerable.Repeat("★", rating.Value))</span>
                        </div>
                        @if (!string.IsNullOrEmpty(rating.Comment))
                        {
                            <p class="mb-0 text-muted small mt-1">@rating.Comment</p>
                        }
                        <small class="text-muted">@rating.CreatedAt.ToString("MMM d, yyyy")</small>
                    </div>
                </div>
            }
        }
    </div>
</div>
