<div class="alert alert-info">
  <strong>Shared Note</strong> — You are viewing this note via a share link.
</div>

<h2>{{note.title}}</h2>
<small class="text-muted">By {{note.owner.username}}</small>

<div class="card mt-3 mb-4">
  <div class="card-body">
    <pre style="white-space:pre-wrap">{{note.content}}</pre>
  </div>
</div>

{{#if note.attachments.length}}
  <h5>Attachments</h5>
  <ul class="list-group">
    {{#each note.attachments}}
      <li class="list-group-item">{{this.originalFilename}} <small class="text-muted">({{this.mimeType}})</small></li>
    {{/each}}
  </ul>
{{/if}}

<p class="mt-4 text-center">
  <a href="/auth/register" class="btn btn-primary">Create your own notes</a>
  <a href="/auth/login" class="btn btn-outline-secondary ms-2">Login</a>
</p>
