@model Note
@{
    ViewData["Title"] = "Delete Note";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow-sm border-danger">
            <div class="card-body p-4">
                <h1 class="h3 text-danger">Delete note</h1>
                <p>You are about to permanently delete <strong>@Model.Title</strong>.</p>
                <p class="mb-4">This action removes the note, all attachments, ratings, and share links.</p>

                <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">Delete permanently</button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
