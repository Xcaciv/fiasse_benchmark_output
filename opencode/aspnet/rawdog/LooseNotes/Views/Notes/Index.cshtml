@model IEnumerable<LooseNotes.Models.Note>
@{
    ViewData["Title"] = "My Notes";
}

<h1>@ViewData["Title"]</h1>

<div class="mb-3">
    <a asp-action="Create" class="btn btn-primary">Create New Note</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

@if (Model.Any())
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Title</th>
                <th>Visibility</th>
                <th>Created</th>
                <th>Updated</th>
                <th>Ratings</th>
                <th>Attachments</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var note in Model)
            {
                <tr>
                    <td>
                        <a asp-action="Details" asp-route-id="@note.Id">@note.Title</a>
                    </td>
                    <td>
                        @if (note.IsPublic)
                        {
                            <span class="badge bg-success">Public</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Private</span>
                        }
                    </td>
                    <td>@note.CreatedAt.ToString("MMM dd, yyyy")</td>
                    <td>@note.UpdatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                    <td>
                        @if (note.Ratings.Count > 0)
                        {
                            <span>@note.Ratings.Average(r => r.Value).ToString("F1") / 5</span>
                        }
                        else
                        {
                            <span class="text-muted">No ratings</span>
                        }
                    </td>
                    <td>@note.Attachments.Count</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@note.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Share" asp-route-id="@note.Id" class="btn btn-sm btn-outline-secondary">Share</a>
                        <a asp-action="Delete" asp-route-id="@note.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        You haven't created any notes yet. <a asp-action="Create">Create your first note</a>
    </div>
}
