<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card shadow-sm text-center">
      <div class="card-body p-5">
        <i class="bi bi-envelope-check text-success display-3 mb-3"></i>
        <h2 class="card-title mb-3">Check Your Email</h2>
        <p class="card-text text-muted mb-4">
          If an account exists for that email address, you'll receive a password reset link shortly.
          Please check your inbox (and spam folder).
        </p>
        <p class="text-muted small mb-4">
          <strong>Note:</strong> In this demo, the reset link is printed to the server console.
        </p>
        <div class="d-flex gap-2 justify-content-center">
          <a href="/auth/login" class="btn btn-primary">
            <i class="bi bi-box-arrow-in-right me-2"></i>Back to Login
          </a>
          <a href="/auth/forgot-password" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-repeat me-2"></i>Try Again
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
