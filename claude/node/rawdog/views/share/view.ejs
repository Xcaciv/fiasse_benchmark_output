<%- include('../partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-8">
    <!-- Shared Note Banner -->
    <div class="alert alert-info d-flex align-items-center mb-4" role="alert">
      <i class="bi bi-share-fill me-3 fs-5"></i>
      <div>
        <strong>Shared Note</strong> &mdash; This note was shared with you via a link.
        <% if (!user) { %>
        <a href="/auth/login" class="ms-2">Login</a> or <a href="/auth/register">register</a> to create your own notes.
        <% } %>
      </div>
    </div>

    <!-- Note Header -->
    <div class="mb-3">
      <h1 class="mb-1"><%= note.title %></h1>
      <div class="text-muted small">
        <i class="bi bi-person me-1"></i>
        <strong><%= note.author ? note.author.username : 'Unknown' %></strong>
        &bull;
        <i class="bi bi-calendar me-1"></i><%= new Date(note.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %>
        <% if (avgRating) { %>
        &bull;
        <i class="bi bi-star-fill text-warning me-1"></i><span class="text-warning fw-semibold"><%= avgRating %></span>/5
        <span class="text-muted">(<%= ratings.length %> rating<%= ratings.length !== 1 ? 's' : '' %>)</span>
        <% } %>
      </div>
    </div>

    <!-- Note Content -->
    <div class="card shadow-sm mb-4">
      <div class="card-body p-4">
        <div class="note-content" style="white-space: pre-wrap; line-height: 1.7;"><%= note.content %></div>
      </div>
    </div>

    <!-- Attachments -->
    <% if (note.Attachments && note.Attachments.length > 0) { %>
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-transparent">
        <h5 class="mb-0"><i class="bi bi-paperclip me-2"></i>Attachments (<%= note.Attachments.length %>)</h5>
      </div>
      <div class="list-group list-group-flush">
        <% note.Attachments.forEach(function(att) { %>
        <div class="list-group-item d-flex justify-content-between align-items-center">
          <div>
            <i class="bi bi-file-earmark me-2 text-muted"></i>
            <a href="/uploads/<%= att.storedName %>" download="<%= att.originalName %>" class="text-decoration-none">
              <%= att.originalName %>
            </a>
            <small class="text-muted ms-2">(<%= (att.size / 1024).toFixed(1) %> KB)</small>
          </div>
          <a href="/uploads/<%= att.storedName %>" download="<%= att.originalName %>" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-download me-1"></i>Download
          </a>
        </div>
        <% }); %>
      </div>
    </div>
    <% } %>

    <!-- Ratings -->
    <% if (ratings && ratings.length > 0) { %>
    <div class="card shadow-sm mb-4">
      <div class="card-header bg-transparent d-flex justify-content-between">
        <h5 class="mb-0"><i class="bi bi-star me-2"></i>Ratings</h5>
        <% if (avgRating) { %>
        <div class="text-warning fw-bold">
          <i class="bi bi-star-fill me-1"></i><%= avgRating %> / 5.0
          <span class="text-muted fw-normal small">(<%= ratings.length %>)</span>
        </div>
        <% } %>
      </div>
      <div class="card-body">
        <% ratings.forEach(function(rating) { %>
        <div class="d-flex align-items-start mb-3 pb-3 border-bottom">
          <div class="me-3">
            <i class="bi bi-person-circle text-muted fs-4"></i>
          </div>
          <div class="flex-grow-1">
            <div class="d-flex justify-content-between align-items-center">
              <strong><%= rating.rater ? rating.rater.username : 'Anonymous' %></strong>
              <div class="text-warning">
                <% for (var i = 1; i <= 5; i++) { %>
                <i class="bi bi-star<%= i <= rating.stars ? '-fill' : '' %>"></i>
                <% } %>
              </div>
            </div>
            <% if (rating.comment) { %>
            <p class="mb-0 mt-1 text-muted small"><%= rating.comment %></p>
            <% } %>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
    <% } %>

    <!-- CTA -->
    <div class="text-center mt-4">
      <p class="text-muted">Want to create your own notes?</p>
      <% if (!user) { %>
      <a href="/auth/register" class="btn btn-primary me-2">
        <i class="bi bi-person-plus me-2"></i>Create Free Account
      </a>
      <a href="/auth/login" class="btn btn-outline-primary">
        <i class="bi bi-box-arrow-in-right me-2"></i>Login
      </a>
      <% } else { %>
      <a href="/notes/create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-2"></i>Create a Note
      </a>
      <% } %>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
