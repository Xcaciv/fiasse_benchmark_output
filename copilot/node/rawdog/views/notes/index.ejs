<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>My Notes</h2>
  <a href="/notes/new" class="btn btn-primary">+ New Note</a>
</div>

<% if (notes.length === 0) { %>
  <div class="alert alert-info">You have no notes yet. <a href="/notes/new">Create one!</a></div>
<% } else { %>
  <div class="row g-3">
    <% notes.forEach(note => { %>
      <div class="col-md-6 col-lg-4">
        <div class="card h-100 shadow-sm">
          <div class="card-body">
            <h5 class="card-title">
              <a href="/notes/<%= note.id %>" class="text-decoration-none text-dark"><%= note.title %></a>
            </h5>
            <p class="card-text text-muted small"><%= note.content.substring(0, 150) %><%= note.content.length > 150 ? '…' : '' %></p>
          </div>
          <div class="card-footer d-flex justify-content-between align-items-center">
            <span class="badge bg-<%= note.visibility === 'public' ? 'success' : 'secondary' %>">
              <%= note.visibility %>
            </span>
            <small class="text-muted"><%= new Date(note.createdAt).toLocaleDateString() %></small>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
<% } %>
