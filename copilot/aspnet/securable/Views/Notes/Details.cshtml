@model NoteDetailsViewModel
@{
    ViewData["Title"] = Model.Title;
}

<div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-4">
    <div>
        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
            <h1 class="mb-0">@Model.Title</h1>
            <span class="badge @(Model.IsPublic ? "text-bg-success" : "text-bg-secondary")">@(Model.IsPublic ? "Public" : "Private")</span>
        </div>
        <p class="text-muted mb-1">By @Model.OwnerUserName</p>
        <p class="text-muted mb-0">Created @Model.CreatedAtUtc.ToLocalTime().ToString("f") · Updated @Model.UpdatedAtUtc.ToLocalTime().ToString("f")</p>
    </div>
    <div class="d-flex flex-wrap gap-2 align-self-start">
        @if (Model.CanEdit)
        {
            <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        }
        @if (Model.CanManageShares)
        {
            <a class="btn btn-outline-secondary" asp-action="ManageShareLinks" asp-route-id="@Model.Id">Share links</a>
        }
        @if (Model.CanViewRatings)
        {
            <a class="btn btn-outline-secondary" asp-action="Ratings" asp-route-id="@Model.Id">Ratings</a>
        }
        @if (Model.CanDelete)
        {
            <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Id">Delete</a>
        }
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Content</h2>
                <div class="note-content">@Model.Content</div>
            </div>
        </div>

        <div class="card shadow-sm" id="ratings">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h4 mb-0">Ratings</h2>
                    <div>
                        <span class="badge text-bg-warning">@Model.AverageRating.ToString("0.0") / 5</span>
                        <span class="badge text-bg-light">@Model.RatingCount total</span>
                    </div>
                </div>

                @if (Model.CanRate)
                {
                    <form asp-action="Rate" method="post" class="border rounded-3 p-3 mb-4 bg-light-subtle">
                        <input asp-for="RatingForm.NoteId" type="hidden" />
                        <div class="row g-3 align-items-end">
                            <div class="col-md-3">
                                <label asp-for="RatingForm.Value" class="form-label"></label>
                                <select asp-for="RatingForm.Value" class="form-select">
                                    @for (var i = 1; i <= 5; i++)
                                    {
                                        <option value="@i">@i</option>
                                    }
                                </select>
                            </div>
                            <div class="col-md-9">
                                <label asp-for="RatingForm.Comment" class="form-label"></label>
                                <input asp-for="RatingForm.Comment" class="form-control" />
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary mt-3">Save rating</button>
                    </form>
                }

                @if (Model.Ratings.Count == 0)
                {
                    <p class="text-muted mb-0">This note has not been rated yet.</p>
                }
                else
                {
                    <div class="vstack gap-3">
                        @foreach (var rating in Model.Ratings)
                        {
                            <div class="border rounded-3 p-3">
                                <div class="d-flex justify-content-between align-items-start gap-3">
                                    <div>
                                        <strong>@rating.UserName</strong>
                                        @if (rating.IsCurrentUsersRating)
                                        {
                                            <span class="badge text-bg-primary ms-2">Your rating</span>
                                        }
                                        <div class="text-muted small">@rating.CreatedAtUtc.ToLocalTime().ToString("g")</div>
                                    </div>
                                    <span class="badge text-bg-warning">@rating.Value / 5</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(rating.Comment))
                                {
                                    <p class="mb-0 mt-2">@rating.Comment</p>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm mb-4">
            <div class="card-body p-4">
                <h2 class="h4 mb-3">Attachments</h2>
                @if (Model.Attachments.Count == 0)
                {
                    <p class="text-muted mb-0">No attachments uploaded.</p>
                }
                else
                {
                    <div class="list-group">
                        @foreach (var attachment in Model.Attachments)
                        {
                            <a asp-action="DownloadAttachment" asp-route-id="@attachment.Id" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                                <span>@attachment.OriginalFileName</span>
                                <span class="text-muted small">@(attachment.SizeBytes / 1024.0).ToString("0.0") KB</span>
                            </a>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>
