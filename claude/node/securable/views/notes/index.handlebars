<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>My Notes</h2>
  <a href="/notes/create" class="btn btn-primary">+ New Note</a>
</div>

{{#if notes.length}}
  <div class="list-group">
    {{#each notes}}
      <a href="/notes/{{this.id}}" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
        <div>
          <strong>{{this.title}}</strong>
          <small class="text-muted ms-2">{{formatDate this.updatedAt}}</small>
        </div>
        <span class="badge {{#if this.isPublic}}bg-success{{else}}bg-secondary{{/if}}">
          {{#if this.isPublic}}Public{{else}}Private{{/if}}
        </span>
      </a>
    {{/each}}
  </div>
{{else}}
  <p class="text-muted">No notes yet. <a href="/notes/create">Create your first note.</a></p>
{{/if}}
