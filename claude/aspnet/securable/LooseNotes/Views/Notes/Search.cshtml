@model NoteSearchViewModel
@{
    ViewData["Title"] = "Search Notes";
}
<h2>Search Notes</h2>
<form asp-action="Search" method="get" class="mb-4">
    <div class="input-group">
        <input asp-for="Query" class="form-control" placeholder="Search by title or content..." />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

@if (Model.Query is not null)
{
    @if (Model.Results.Any())
    {
        <p class="text-muted">@Model.Results.Count result(s) for "@Model.Query"</p>
        <div class="row g-3">
            @foreach (var note in Model.Results)
            {
                <div class="col-md-6">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">
                                <a asp-action="Details" asp-route-id="@note.Id" class="text-decoration-none">@note.Title</a>
                            </h5>
                            <p class="card-text text-muted small">@note.Excerpt</p>
                        </div>
                        <div class="card-footer text-muted small d-flex justify-content-between">
                            <span>@note.OwnerUserName &bull; @note.CreatedAt.ToString("MMM d, yyyy")</span>
                            @if (note.RatingCount > 0)
                            {
                                <span>&#9733; @note.AverageRating.ToString("F1")</span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <p class="text-muted">No notes found matching "@Model.Query".</p>
    }
}
