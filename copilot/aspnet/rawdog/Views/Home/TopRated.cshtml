@model IReadOnlyList<TopRatedNoteViewModel>
@{
    ViewData["Title"] = "Top Rated";
}

<div class="mb-4">
    <h1 class="h2 mb-1">Top rated public notes</h1>
    <p class="text-muted mb-0">Only public notes with at least 3 ratings appear here.</p>
</div>

@if (Model.Count == 0)
{
    <div class="alert alert-info">There are not enough rated notes to show a leaderboard yet.</div>
}
else
{
    <div class="vstack gap-3">
        @{
            var rank = 1;
        }
        @foreach (var note in Model)
        {
            <article class="card shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start gap-3">
                        <div class="d-flex gap-3">
                            <div class="leader-rank">#@rank</div>
                            <div>
                                <h2 class="h5 mb-1">
                                    <a asp-controller="Notes" asp-action="Details" asp-route-id="@note.Id" class="text-decoration-none">@note.Title</a>
                                </h2>
                                <p class="text-muted small mb-2">By @note.Author</p>
                            </div>
                        </div>
                        <div class="text-end">
                            <div class="fw-semibold">@note.AverageRating.ToString("0.0") / 5</div>
                            <div class="text-muted small">@note.RatingCount ratings</div>
                        </div>
                    </div>
                    <p class="mb-0 note-preview">@note.Preview</p>
                </div>
            </article>

            rank++;
        }
    </div>
}
