<%
function renderStars(avg) {
  if (!avg) return '';
  let stars = '';
  for (let i = 1; i <= 5; i++) {
    stars += i <= Math.round(parseFloat(avg)) ? '<span class="star">★</span>' : '<span class="star-empty">★</span>';
  }
  return stars;
}
%>
<h2 class="mb-4">Top Rated Notes</h2>
<p class="text-muted">Public notes with at least 3 ratings, sorted by average rating.</p>

<% if (notes.length === 0) { %>
  <div class="alert alert-info">No top-rated notes yet. Be the first to rate!</div>
<% } else { %>
  <div class="list-group">
    <% notes.forEach(note => { %>
      <a href="/notes/<%= note.id %>" class="list-group-item list-group-item-action">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <h6 class="mb-1"><%= note.title %></h6>
            <small class="text-muted">By <%= note.User ? note.User.username : 'Unknown' %></small>
          </div>
          <div class="text-end">
            <%- renderStars(note.getDataValue('avgRating')) %>
            <small class="text-muted d-block"><%= parseFloat(note.getDataValue('avgRating')).toFixed(1) %> avg · <%= note.getDataValue('ratingCount') %> ratings</small>
          </div>
        </div>
        <p class="mb-0 text-muted small mt-1"><%= note.content.substring(0, 150) %><%= note.content.length > 150 ? '…' : '' %></p>
      </a>
    <% }) %>
  </div>
<% } %>
