@model List<NoteListItemViewModel>
@{
    ViewData["Title"] = "My Notes";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My Notes</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Note</a>
</div>
@if (!Model.Any())
{
    <p class="text-muted">You have no notes yet. <a asp-action="Create">Create your first note</a>.</p>
}
else
{
    <div class="row">
        @foreach (var note in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">
                            <a asp-action="Detail" asp-route-id="@note.Id">@note.Title</a>
                        </h5>
                        <p class="card-text text-muted small">@note.Excerpt</p>
                    </div>
                    <div class="card-footer text-muted small d-flex justify-content-between">
                        <span>@note.CreatedAt.ToString("MMM dd, yyyy")</span>
                        <span>
                            @if (note.IsPublic)
                            {
                                <span class="badge bg-success">Public</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Private</span>
                            }
                            @if (note.RatingCount > 0)
                            {
                                <span class="badge bg-warning text-dark">&#11088; @note.AverageRating.ToString("F1")</span>
                            }
                        </span>
                    </div>
                </div>
            </div>
        }
    </div>
}
