<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - Loose Notes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>
<body>
  <%- include ../partials/navbar %>
  <%- include ../partials/flash %>
  <main class="container py-4">
    <h1 class="mb-4">Admin Dashboard</h1>

    <div class="row g-4 mb-4">
      <div class="col-md-4">
        <div class="card bg-primary text-white">
          <div class="card-body">
            <h5 class="card-title">Total Users</h5>
            <p class="display-4 mb-0"><%= userCount %></p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card bg-success text-white">
          <div class="card-body">
            <h5 class="card-title">Total Notes</h5>
            <p class="display-4 mb-0"><%= noteCount %></p>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card bg-info text-white">
          <div class="card-body">
            <h5 class="card-title">Recent Activity</h5>
            <p class="display-4 mb-0"><%= recentActivity.length %></p>
          </div>
        </div>
      </div>
    </div>

    <div class="row">
      <div class="col-md-6 mb-4">
        <div class="card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Quick Actions</h5>
          </div>
          <div class="card-body">
            <div class="d-grid gap-2">
              <a href="/admin/users" class="btn btn-outline-primary">Manage Users</a>
              <a href="/admin/notes" class="btn btn-outline-success">View All Notes</a>
              <a href="/admin/activity" class="btn btn-outline-info">Activity Log</a>
            </div>
          </div>
        </div>
      </div>
      
      <div class="col-md-6 mb-4">
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0">Recent Activity</h5>
          </div>
          <div class="card-body">
            <% if (recentActivity && recentActivity.length > 0) { %>
              <div class="list-group list-group-flush">
                <% recentActivity.slice(0, 5).forEach(function(act) { %>
                  <div class="list-group-item px-0">
                    <small class="text-muted"><%= new Date(act.created_at).toLocaleString() %></small>
                    <br>
                    <strong><%= act.action %></strong>
                    <%= act.username ? 'by ' + act.username : '' %>
                  </div>
                <% }); %>
              </div>
            <% } else { %>
              <p class="text-muted">No recent activity</p>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>
  <%- include ../partials/footer %>
</body>
</html>
