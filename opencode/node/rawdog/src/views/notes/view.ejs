<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= note.title %> - Loose Notes</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.2/font/bootstrap-icons.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container">
      <a class="navbar-brand" href="/"><i class="bi bi-journal-text"></i> Loose Notes</a>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/notes">My Notes</a>
        <a class="nav-link" href="/search">Search</a>
        <div class="dropdown">
          <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
            <i class="bi bi-person-circle"></i> <%= user.username %>
          </a>
          <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="/auth/profile">Profile</a></li>
            <li><hr class="dropdown-divider"></li>
            <li>
              <form action="/auth/logout" method="POST" class="d-inline">
                <button type="submit" class="dropdown-item">Logout</button>
              </form>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </nav>

  <div class="container mt-4">
    <div class="row">
      <div class="col-lg-8">
        <div class="card mb-4">
          <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-3">
              <h1 class="card-title"><%= note.title %></h1>
              <% if (note.is_public) { %>
                <span class="badge bg-success">Public</span>
              <% } else { %>
                <span class="badge bg-secondary">Private</span>
              <% } %>
            </div>
            
            <p class="text-muted mb-3">
              By <strong><%= note.author %></strong> | 
              <%= new Date(note.created_at).toLocaleDateString() %>
              <% if (note.created_at !== note.updated_at) { %>
                (Updated: <%= new Date(note.updated_at).toLocaleDateString() %>)
              <% } %>
            </p>

            <% if (avgRating && avgRating.count > 0) { %>
              <div class="mb-3">
                <span class="text-warning">
                  <% for (let i = 1; i <= 5; i++) { %>
                    <% if (i <= Math.round(avgRating.avg)) { %>
                      <i class="bi bi-star-fill"></i>
                    <% } else { %>
                      <i class="bi bi-star"></i>
                    <% } %>
                  <% } %>
                </span>
                <span class="text-muted">
                  <%= parseFloat(avgRating.avg).toFixed(1) %> (<%= avgRating.count %> rating<%= avgRating.count > 1 ? 's' : '' %>)
                </span>
              </div>
            <% } %>

            <hr>

            <div class="card-text note-content">
              <%= note.content %>
            </div>

            <% if (attachments.length > 0) { %>
              <hr>
              <h5>Attachments</h5>
              <div class="list-group">
                <% attachments.forEach(function(attachment) { %>
                  <div class="list-group-item d-flex justify-content-between align-items-center">
                    <div>
                      <i class="bi bi-paperclip"></i>
                      <%= attachment.original_filename %>
                      <small class="text-muted">(<%= (attachment.file_size / 1024).toFixed(1) %> KB)</small>
                    </div>
                    <div>
                      <a href="/uploads/<%= attachment.stored_filename %>" class="btn btn-sm btn-outline-primary" download="<%= attachment.original_filename %>">
                        <i class="bi bi-download"></i> Download
                      </a>
                      <% if (isOwner) { %>
                        <form action="/notes/<%= note.id %>/attachments/<%= attachment.id %>/delete" method="POST" class="d-inline">
                          <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this attachment?')">
                            <i class="bi bi-trash"></i>
                          </button>
                        </form>
                      <% } %>
                    </div>
                  </div>
                <% }); %>
              </div>
            <% } %>

            <% if (isOwner) { %>
              <hr>
              <div class="d-flex gap-2">
                <a href="/notes/<%= note.id %>/edit" class="btn btn-primary">
                  <i class="bi bi-pencil"></i> Edit
                </a>
                <a href="/notes/<%= note.id %>/share" class="btn btn-outline-primary">
                  <i class="bi bi-share"></i> Share
                </a>
                <form action="/notes/<%= note.id %>/delete" method="POST" class="d-inline">
                  <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to delete this note?')">
                    <i class="bi bi-trash"></i> Delete
                  </button>
                </form>
              </div>
            <% } %>
          </div>
        </div>

        <% if (isOwner) { %>
          <div class="card mb-4">
            <div class="card-header">
              <h5 class="mb-0">Upload Attachment</h5>
            </div>
            <div class="card-body">
              <form method="POST" action="/notes/<%= note.id %>/attachments" enctype="multipart/form-data">
                <div class="mb-3">
                  <input type="file" class="form-control" name="attachment" accept=".pdf,.doc,.docx,.txt,.png,.jpg,.jpeg" required>
                  <div class="form-text">Allowed: PDF, DOC, DOCX, TXT, PNG, JPG, JPEG (Max 10MB)</div>
                </div>
                <button type="submit" class="btn btn-outline-primary">Upload File</button>
              </form>
            </div>
          </div>
        <% } %>

        <div class="card">
          <div class="card-header">
            <h5 class="mb-0">Ratings & Reviews</h5>
          </div>
          <div class="card-body">
            <% if (userRating) { %>
              <div class="mb-4 p-3 bg-light rounded">
                <h6>Your Rating</h6>
                <div class="text-warning mb-2">
                  <% for (let i = 1; i <= 5; i++) { %>
                    <% if (i <= userRating.rating) { %>
                      <i class="bi bi-star-fill"></i>
                    <% } else { %>
                      <i class="bi bi-star"></i>
                    <% } %>
                  <% } %>
                </div>
                <% if (userRating.comment) { %>
                  <p class="mb-0"><%= userRating.comment %></p>
                <% } %>
              </div>
            <% } %>

            <% if (!isOwner && note.is_public) { %>
              <form method="POST" action="/notes/<%= note.id %>/rate" class="mb-4">
                <h6>Rate this Note</h6>
                <div class="mb-3">
                  <select class="form-select" name="rating" required>
                    <option value="">Select rating</option>
                    <option value="1">1 Star</option>
                    <option value="2">2 Stars</option>
                    <option value="3">3 Stars</option>
                    <option value="4">4 Stars</option>
                    <option value="5">5 Stars</option>
                  </select>
                </div>
                <div class="mb-3">
                  <textarea class="form-control" name="comment" rows="2" placeholder="Add a comment (optional)"></textarea>
                </div>
                <button type="submit" class="btn btn-primary">Submit Rating</button>
              </form>
            <% } %>

            <% if (ratings.length > 0) { %>
              <h6>All Ratings (<%= ratings.length %>)</h6>
              <% ratings.forEach(function(rating) { %>
                <div class="border-bottom pb-3 mb-3">
                  <div class="d-flex justify-content-between">
                    <strong><%= rating.username %></strong>
                    <small class="text-muted"><%= new Date(rating.created_at).toLocaleDateString() %></small>
                  </div>
                  <div class="text-warning">
                    <% for (let i = 1; i <= 5; i++) { %>
                      <% if (i <= rating.rating) { %>
                        <i class="bi bi-star-fill"></i>
                      <% } else { %>
                        <i class="bi bi-star"></i>
                      <% } %>
                    <% } %>
                  </div>
                  <% if (rating.comment) { %>
                    <p class="mb-0 mt-2"><%= rating.comment %></p>
                  <% } %>
                </div>
              <% }); %>
            <% } else { %>
              <p class="text-muted">No ratings yet.</p>
            <% } %>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card">
          <div class="card-header">
            <h5 class="mb-0">Note Info</h5>
          </div>
          <div class="card-body">
            <ul class="list-unstyled mb-0">
              <li class="mb-2">
                <i class="bi bi-person"></i> Author: <%= note.author %>
              </li>
              <li class="mb-2">
                <i class="bi bi-calendar"></i> Created: <%= new Date(note.created_at).toLocaleDateString() %>
              </li>
              <li class="mb-0">
                <i class="bi bi-clock-history"></i> Updated: <%= new Date(note.updated_at).toLocaleDateString() %>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
