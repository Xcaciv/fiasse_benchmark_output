@model List<LooseNotes.Models.Note>
@{
    ViewData["Title"] = "My Notes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>My Notes</h2>
    <a asp-action="Create" class="btn btn-primary">+ New Note</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">You haven't created any notes yet. <a asp-action="Create">Create your first note!</a></div>
}
else
{
    <div class="row">
        @foreach (var note in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <h5 class="card-title">
                                <a asp-action="Details" asp-route-id="@note.Id">@note.Title</a>
                            </h5>
                            <span class="badge @(note.IsPublic ? "bg-success" : "bg-secondary")">
                                @(note.IsPublic ? "Public" : "Private")
                            </span>
                        </div>
                        <p class="card-text text-muted small">
                            @(note.Content.Length > 100 ? note.Content.Substring(0, 100) + "..." : note.Content)
                        </p>
                        <p class="card-text"><small class="text-muted">Updated @note.UpdatedAt.ToString("MMM d, yyyy")</small></p>
                        @if (note.Ratings.Any())
                        {
                            <div class="star-rating small">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span>@(i <= Math.Round(note.AverageRating) ? "★" : "☆")</span>
                                }
                                <span class="text-muted">(@note.Ratings.Count)</span>
                            </div>
                        }
                    </div>
                    <div class="card-footer d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@note.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@note.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </div>
                </div>
            </div>
        }
    </div>
}
